<view class="profile-page">
  <view class="page-loading" wx:if="{{pageLoading}}">
    <van-loading size="28px" color="#d84f45" vertical>{{copy.loading}}</van-loading>
  </view>

  <block wx:else>
    <view class="hero-shell {{headerBackdrop ? 'has-cover' : 'is-default-cover'}}">
      <image
        wx:if="{{headerBackdrop}}"
        class="hero-backdrop-image"
        src="{{headerBackdrop}}"
        mode="aspectFill"
      />
      <view class="hero-backdrop-mask {{headerBackdrop ? 'has-image' : 'is-default'}}"></view>
      <view class="hero-orb hero-orb-a"></view>
      <view class="hero-orb hero-orb-b"></view>

      <view class="hero-safe" style="padding-top: {{statusBarHeight}}px;">
        <view class="hero-topbar">
          <view
            class="hero-menu-btn"
            bindtap="onHeroMenuTap"
          >
            <van-icon name="edit" size="18" color="#ffffff" />
          </view>
          <view class="hero-top-spacer"></view>
        </view>

        <view class="hero-main-card">
          <view class="hero-profile-row">
            <view class="avatar-wrap">
              <view class="avatar-ring">
                <image
                  class="avatar-image"
                  src="{{isLoggedIn ? (userInfo.avatar_url || userInfo.avatar_file_id || userInfo.avatar || '/images/icons/avatar.png') : '/images/icons/avatar.png'}}"
                  mode="aspectFill"
                />
              </view>
            </view>

            <view class="hero-content">
              <view class="name-row">
                <text class="display-name">{{displayName}}</text>
              </view>
              <text class="profile-bio" wx:if="{{profileBio}}">{{profileBio}}</text>
            </view>
          </view>

          <view class="stats-strip">
            <view
              class="stat-card"
              wx:for="{{statItems}}"
              wx:key="key"
              wx:for-item="stat"
              data-action="{{stat.action}}"
              bindtap="handleActionTap"
            >
              <text class="stat-value">{{stat.value}}</text>
              <text class="stat-label">{{stat.label}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="page-body" style="padding-bottom: {{safeAreaBottom + 36}}px;">
      <view class="identity-card creator-card" wx:if="{{showCreatorCard}}">
        <view class="section-head">
          <view class="section-head-text">
            <text class="section-title">{{workshopData && workshopData.name ? workshopData.name : copy.creatorDefaultName}}</text>
            <text class="section-desc">{{copy.creatorDesc}}</text>
          </view>
          <view class="section-link" bindtap="goToMyWorkshop">
            <text>{{copy.viewWorkshop}}</text>
            <van-icon name="arrow" size="14" color="#2b2724" />
          </view>
        </view>

        <view class="creator-metrics">
          <view
            class="metric-item"
            wx:for="{{creatorMetrics}}"
            wx:key="label"
            wx:for-item="metric"
          >
            <text class="metric-value {{metric.highlight ? 'metric-value-hot' : ''}}">{{metric.value}}</text>
            <text class="metric-label">{{metric.label}}</text>
          </view>
        </view>

        <view class="creator-actions">
          <view
            class="creator-action-card"
            wx:for="{{creatorActions}}"
            wx:key="key"
            wx:for-item="actionItem"
            data-action="{{actionItem.action}}"
            bindtap="handleActionTap"
          >
            <view class="creator-action-icon {{actionItem.tone}}">
              <van-icon name="{{actionItem.icon}}" size="20" color="#2b2724" />
              <view class="creator-action-badge" wx:if="{{actionItem.badge}}">{{actionItem.badge}}</view>
            </view>
            <text class="creator-action-title">{{actionItem.title}}</text>
          </view>
        </view>
      </view>

      <view class="identity-card upgrade-card" wx:if="{{showUpgradeCard}}">
        <view class="section-head compact">
          <view class="section-head-text">
            <text class="section-eyebrow">{{copy.upgradeEyebrow}}</text>
            <text class="section-title">{{copy.upgradeTitle}}</text>
            <text class="section-desc">{{copy.upgradeDesc}}</text>
          </view>
          <view class="upgrade-mark">
            <van-icon name="certificate" size="22" color="#d84f45" />
          </view>
        </view>

        <view class="benefit-list">
          <view
            class="benefit-pill"
            wx:for="{{upgradeBenefits}}"
            wx:key="*this"
            wx:for-item="benefit"
          >
            <view class="benefit-dot"></view>
            <text>{{benefit}}</text>
          </view>
        </view>

        <view class="upgrade-footer">
          <view class="upgrade-cta" bindtap="goToCertify">
            <text>{{copy.upgradeCta}}</text>
            <van-icon name="arrow" size="14" color="#fff" />
          </view>
        </view>
      </view>

      <view class="identity-card guest-card" wx:if="{{showGuestCard}}">
        <view class="section-head compact">
          <view class="section-head-text">
            <text class="section-eyebrow">{{copy.guestEyebrow}}</text>
            <text class="section-title">{{copy.guestTitle}}</text>
            <text class="section-desc">{{copy.guestDesc}}</text>
          </view>
          <view class="guest-mark">
            <van-icon name="friends-o" size="22" color="#d84f45" />
          </view>
        </view>

        <view class="guest-actions">
          <view class="guest-btn guest-btn-primary" bindtap="goToLogin">
            <text>{{copy.guestPrimary}}</text>
          </view>
          <view class="guest-btn guest-btn-secondary" bindtap="goToCommunity">
            <text>{{copy.guestSecondary}}</text>
          </view>
        </view>
      </view>

      <view class="panel-card">
        <view class="section-head">
          <view class="section-head-text">
            <text class="section-title">{{copy.ordersTitle}}</text>
            <text class="section-desc">{{copy.ordersDesc}}</text>
          </view>
          <view class="section-link" bindtap="goToAllOrders">
            <text>{{copy.allOrders}}</text>
            <van-icon name="arrow" size="14" color="#2b2724" />
          </view>
        </view>

        <view class="order-grid">
          <view
            class="order-entry"
            wx:for="{{orderEntries}}"
            wx:key="key"
            wx:for-item="entry"
            data-status="{{entry.status}}"
            bindtap="onOrderEntryTap"
          >
            <view class="order-icon {{entry.tone}}">
              <van-icon name="{{entry.icon}}" size="20" color="#2b2724" />
              <view class="order-badge" wx:if="{{entry.count > 0}}">{{entry.count}}</view>
            </view>
            <text class="order-label">{{entry.label}}</text>
          </view>
        </view>
      </view>

      <view class="panel-card">
        <view class="section-head">
          <view class="section-head-text">
            <text class="section-title">{{copy.servicesTitle}}</text>
            <text class="section-desc">{{copy.servicesDesc}}</text>
          </view>
        </view>

        <view
          class="service-group"
          wx:for="{{serviceGroups}}"
          wx:key="key"
          wx:for-item="group"
        >
          <text class="service-group-title">{{group.title}}</text>
          <view class="service-list">
            <view
              class="service-row"
              wx:for="{{group.items}}"
              wx:key="title"
              wx:for-item="serviceItem"
              data-action="{{serviceItem.action}}"
              bindtap="handleActionTap"
            >
              <view class="service-row-left">
                <view class="service-icon {{serviceItem.tone}}">
                  <van-icon name="{{serviceItem.icon}}" size="18" color="#2b2724" />
                </view>
                <view class="service-text">
                  <text class="service-title {{serviceItem.danger ? 'service-title-danger' : ''}}">{{serviceItem.title}}</text>
                  <text class="service-desc">{{serviceItem.desc}}</text>
                </view>
              </view>
              <van-icon name="arrow" size="14" color="#9b938c" />
            </view>
          </view>
        </view>
      </view>

      <view class="panel-card content-card">
        <view class="section-head">
          <view class="section-head-text">
            <text class="section-title">{{copy.contentTitle}}</text>
            <text class="section-desc">{{copy.contentDesc}}</text>
          </view>
          <view
            class="content-head-action"
            wx:if="{{isLoggedIn}}"
            bindtap="goToPost"
          >
            <van-icon name="plus" size="14" color="#d84f45" />
            <text>{{copy.writeNote}}</text>
          </view>
          <view
            class="content-head-action"
            wx:if="{{!isLoggedIn}}"
            bindtap="goToCommunity"
          >
            <text>{{copy.goCommunity}}</text>
          </view>
        </view>

        <view class="content-tabs">
          <view
            class="content-tab {{activeTabKey === tab.key ? 'is-active' : ''}}"
            wx:for="{{contentTabs}}"
            wx:key="key"
            wx:for-item="tab"
            data-key="{{tab.key}}"
            bindtap="switchContentTab"
          >
            <text class="content-tab-label">{{tab.label}}</text>
            <text class="content-tab-count" wx:if="{{tab.countText}}">{{tab.countText}}</text>
          </view>
        </view>

        <view class="content-loading" wx:if="{{contentLoading}}">
          <van-loading size="22px" color="#d84f45" vertical>{{copy.loadingContent}}</van-loading>
        </view>

        <view class="waterfall-wrap" wx:elif="{{displayLeftPosts.length || displayRightPosts.length}}">
          <view class="waterfall-column">
            <view
              class="note-card"
              wx:for="{{displayLeftPosts}}"
              wx:key="_id"
              wx:for-item="note"
              bindtap="goToPostDetail"
              data-id="{{note._id}}"
            >
              <view class="note-cover-wrap">
                <image
                  class="note-cover"
                  src="{{note.coverImage || note.authorAvatar || '/images/icons/avatar.png'}}"
                  mode="widthFix"
                  lazy-load
                />
                <view class="note-tag" wx:if="{{note.tagText}}">
                  <text>{{note.tagText}}</text>
                </view>
                <view class="note-photo-count" wx:if="{{note.images.length > 1}}">
                  <van-icon name="photo-o" size="12" color="#fff" />
                  <text>{{note.images.length}}</text>
                </view>
              </view>
              <view class="note-body">
                <text class="note-title">{{note.title}}</text>
                <view class="note-footer" wx:if="{{activeTabKey === 'collections'}}">
                  <view class="note-author">
                    <image class="note-author-avatar" src="{{note.authorAvatar}}" mode="aspectFill" />
                    <text class="note-author-name">{{note.authorName}}</text>
                  </view>
                  <view class="note-like">
                    <van-icon name="like-o" size="14" color="#7d756e" />
                    <text>{{note.likeCount}}</text>
                  </view>
                </view>
                <view class="note-footer" wx:else>
                  <text class="note-date">{{note.dateLabel || copy.updatedNow}}</text>
                  <view class="note-like">
                    <van-icon name="like-o" size="14" color="#7d756e" />
                    <text>{{note.likeCount}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>

          <view class="waterfall-column">
            <view
              class="note-card"
              wx:for="{{displayRightPosts}}"
              wx:key="_id"
              wx:for-item="note"
              bindtap="goToPostDetail"
              data-id="{{note._id}}"
            >
              <view class="note-cover-wrap">
                <image
                  class="note-cover"
                  src="{{note.coverImage || note.authorAvatar || '/images/icons/avatar.png'}}"
                  mode="widthFix"
                  lazy-load
                />
                <view class="note-tag" wx:if="{{note.tagText}}">
                  <text>{{note.tagText}}</text>
                </view>
                <view class="note-photo-count" wx:if="{{note.images.length > 1}}">
                  <van-icon name="photo-o" size="12" color="#fff" />
                  <text>{{note.images.length}}</text>
                </view>
              </view>
              <view class="note-body">
                <text class="note-title">{{note.title}}</text>
                <view class="note-footer" wx:if="{{activeTabKey === 'collections'}}">
                  <view class="note-author">
                    <image class="note-author-avatar" src="{{note.authorAvatar}}" mode="aspectFill" />
                    <text class="note-author-name">{{note.authorName}}</text>
                  </view>
                  <view class="note-like">
                    <van-icon name="like-o" size="14" color="#7d756e" />
                    <text>{{note.likeCount}}</text>
                  </view>
                </view>
                <view class="note-footer" wx:else>
                  <text class="note-date">{{note.dateLabel || copy.updatedNow}}</text>
                  <view class="note-like">
                    <van-icon name="like-o" size="14" color="#7d756e" />
                    <text>{{note.likeCount}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>

        <view class="empty-panel" wx:else>
          <view class="empty-icon">
            <van-icon name="notes-o" size="24" color="#d84f45" />
          </view>
          <text class="empty-title">{{contentEmptyTitle}}</text>
          <text class="empty-desc">{{contentEmptyDesc}}</text>
          <view
            class="empty-btn"
            data-action="{{contentEmptyAction}}"
            bindtap="handleActionTap"
          >
            <text>{{contentEmptyActionText}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
