.profile-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(216, 79, 69, 0.08), transparent 28%),
    linear-gradient(180deg, #f7f4ef 0%, #f4f1ec 46%, #f7f6f3 100%);
  color: #201d1b;
  font-family: "Avenir Next", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-loading {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-shell {
  position: relative;
  min-height: 560rpx;
  padding: 0 28rpx 60rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #403632 0%, #655956 48%, #8a7e7a 100%);
}

.hero-safe {
  position: relative;
  z-index: 2;
  min-height: 560rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  padding-bottom: 0;
}

.hero-shell.is-default-cover .hero-orb {
  display: none;
}

.hero-backdrop-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  filter: blur(4px);
  transform: scale(1.06);
}

.hero-backdrop-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(26, 24, 24, 0.34) 0%, rgba(26, 24, 24, 0.22) 40%, rgba(26, 24, 24, 0.16) 100%),
    linear-gradient(135deg, rgba(52, 47, 45, 0.5) 0%, rgba(95, 84, 79, 0.22) 100%);
}

.hero-backdrop-mask.is-default {
  background:
    linear-gradient(180deg, rgba(41, 36, 34, 0.28) 0%, rgba(41, 36, 34, 0.12) 54%, rgba(41, 36, 34, 0.04) 100%),
    radial-gradient(circle at 84% 14%, rgba(255, 255, 255, 0.12), transparent 26%),
    radial-gradient(circle at 12% 76%, rgba(255, 245, 236, 0.08), transparent 20%);
}

.hero-orb {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  filter: blur(8px);
}

.hero-orb-a {
  width: 260rpx;
  height: 260rpx;
  top: 118rpx;
  right: -60rpx;
}

.hero-orb-b {
  width: 180rpx;
  height: 180rpx;
  left: -40rpx;
  bottom: 176rpx;
  background: rgba(255, 232, 214, 0.16);
}

.hero-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 12rpx;
  flex-shrink: 0;
}

.hero-menu-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.hero-menu-btn:active {
  transform: scale(0.94);
}

.hero-top-spacer {
  width: 72rpx;
  height: 72rpx;
}

.hero-main-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  margin-top: auto;
  padding: 0 4rpx 0rpx;
}

.hero-profile-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.avatar-wrap {
  flex-shrink: 0;
}

.avatar-ring {
  width: 144rpx;
  height: 144rpx;
  padding: 4rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  box-sizing: border-box;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
  display: block;
  background: rgba(255, 255, 255, 0.24);
}

.hero-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  padding-top: 8rpx;
}

.name-row {
  display: flex;
  align-items: center;
  min-height: 52rpx;
}

.display-name {
  max-width: 100%;
  font-size: 52rpx;
  line-height: 1.08;
  font-weight: 700;
  color: #fffefb;
}

.profile-bio {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.stats-strip {
  position: relative;
  display: flex;
  flex-wrap: wrap;
  gap: 26rpx;
  margin-top: 0;
}

.stat-card {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  min-width: 0;
}

.stat-value {
  display: inline;
  font-family: "DIN Alternate", "Avenir Next", sans-serif;
  font-size: 42rpx;
  font-weight: 700;
  color: #fffefb;
}

.stat-label {
  display: inline;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.84);
}

.page-body {
  padding: 0 24rpx 0;
  margin-top: 18rpx;
  position: relative;
  z-index: 4;
}

.panel-card,
.identity-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 34rpx;
  background: rgba(255, 252, 248, 0.96);
  box-shadow: 0 18rpx 50rpx rgba(38, 28, 21, 0.08);
}

.creator-card {
  background: rgba(255, 252, 248, 0.96);
  padding: 22rpx;
}

.upgrade-card,
.guest-card {
  background: linear-gradient(180deg, rgba(255, 251, 247, 0.98) 0%, rgba(250, 245, 240, 0.98) 100%);
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.section-head-text {
  min-width: 0;
  flex: 1;
}

.section-head.compact {
  align-items: center;
}

.section-eyebrow {
  display: block;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #bb7a65;
}

.section-title {
  display: block;
  margin-top: 4rpx;
  font-size: 32rpx;
  line-height: 1.28;
  font-weight: 700;
  color: #1e1a17;
}

.section-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #7d736c;
}

.section-link {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: #f2ece4;
  font-size: 22rpx;
  color: #2b2724;
}

.upgrade-mark,
.guest-mark {
  width: 84rpx;
  height: 84rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fff1ed 0%, #ffe6dd 100%);
}

.creator-metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6rpx;
  margin-top: 16rpx;
}

.metric-item {
  padding: 12rpx 8rpx;
  border-radius: 18rpx;
  background: #fff8f3;
  text-align: center;
}

.metric-value {
  display: block;
  font-family: "DIN Alternate", "Avenir Next", sans-serif;
  font-size: 34rpx;
  font-weight: 700;
  color: #231f1c;
}

.metric-value-hot {
  color: #d84f45;
}

.metric-label {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #8a7e75;
}

.creator-actions {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 14rpx;
  justify-items: center;
}

.creator-action-card {
  position: relative;
  width: 100%;
  max-width: 110rpx;
  min-height: auto;
  padding: 0;
  border-radius: 0;
  background: transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
  text-align: center;
}

.creator-action-icon {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.creator-action-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #d84f45;
  color: #fff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}

.creator-action-title {
  display: block;
  font-size: 22rpx;
  line-height: 1.35;
  color: #6e645d;
}

.benefit-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 26rpx;
}

.benefit-pill {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #fffaf6;
  font-size: 24rpx;
  color: #5a514b;
}

.benefit-dot {
  width: 14rpx;
  height: 14rpx;
  flex-shrink: 0;
  border-radius: 999rpx;
  background: #d84f45;
}

.upgrade-footer,
.guest-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.upgrade-cta,
.guest-btn {
  height: 76rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.upgrade-cta,
.guest-btn-primary {
  background: #d84f45;
  color: #fff;
}

.guest-btn-secondary {
  background: #f2ece4;
  color: #2b2724;
}

.order-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 24rpx;
}

.order-entry {
  padding: 12rpx 6rpx 6rpx;
  text-align: center;
}

.order-icon {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  margin: 0 auto;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #d84f45;
  color: #fff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}

.order-label {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #6e645d;
}

.service-group + .service-group {
  margin-top: 22rpx;
}

.service-group-title {
  display: block;
  margin-bottom: 14rpx;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #9a8f86;
}

.service-list {
  overflow: hidden;
  border-radius: 28rpx;
  background: #fffdfb;
}

.service-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 22rpx;
}

.service-row + .service-row {
  border-top: 1rpx solid rgba(60, 43, 31, 0.06);
}

.service-row-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
  flex: 1;
}

.service-icon {
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.service-text {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.service-title {
  font-size: 28rpx;
  color: #241f1b;
}

.service-title-danger {
  color: #cf4b40;
}

.service-desc {
  font-size: 22rpx;
  line-height: 1.5;
  color: #8a7f77;
}

.content-card {
  overflow: hidden;
}

.content-head-action {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #fff1ed;
  color: #d84f45;
  font-size: 22rpx;
}

.content-tabs {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.content-tab {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 999rpx;
  background: #f1ece6;
  color: #7b7068;
  font-size: 24rpx;
}

.content-tab.is-active {
  background: #2b2724;
  color: #fff7ef;
}

.content-tab-label {
  font-weight: 600;
}

.content-tab-count {
  font-size: 20rpx;
  opacity: 0.8;
}

.content-loading {
  padding: 88rpx 0;
  display: flex;
  justify-content: center;
}

.waterfall-wrap {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.note-card {
  overflow: hidden;
  border-radius: 28rpx;
  background: #fffdfb;
  box-shadow: 0 12rpx 30rpx rgba(31, 26, 23, 0.06);
}

.note-cover-wrap {
  position: relative;
}

.note-cover {
  width: 100%;
  display: block;
  background: #ebe5df;
}

.note-tag {
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  max-width: 76%;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(32, 29, 27, 0.58);
  color: #fffaf5;
  font-size: 20rpx;
}

.note-photo-count {
  position: absolute;
  right: 14rpx;
  top: 14rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(32, 29, 27, 0.58);
  color: #fff;
  font-size: 20rpx;
}

.note-body {
  padding: 18rpx 18rpx 20rpx;
}

.note-title {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #251f1b;
}

.note-footer {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.note-author {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  flex: 1;
}

.note-author-avatar {
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: #efe6de;
}

.note-author-name,
.note-date {
  min-width: 0;
  font-size: 21rpx;
  color: #877b73;
}

.note-author-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  font-size: 21rpx;
  color: #7d756e;
}

.empty-panel {
  padding: 96rpx 20rpx 54rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff1ed;
}

.empty-title {
  margin-top: 22rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #241f1b;
}

.empty-desc {
  margin-top: 14rpx;
  max-width: 480rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #83776f;
}

.empty-btn {
  margin-top: 26rpx;
  min-width: 196rpx;
  height: 72rpx;
  padding: 0 26rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #2b2724;
  color: #fff7ef;
  font-size: 25rpx;
  font-weight: 600;
}

.tone-red {
  background: linear-gradient(180deg, #fff1ed 0%, #ffe4dc 100%);
}

.tone-amber {
  background: linear-gradient(180deg, #fff5e8 0%, #ffead0 100%);
}

.tone-blue {
  background: linear-gradient(180deg, #eef4ff 0%, #dde8ff 100%);
}

.tone-emerald {
  background: linear-gradient(180deg, #eef9f4 0%, #daf0e7 100%);
}

.tone-ink {
  background: linear-gradient(180deg, #f0eeeb 0%, #e6e2dc 100%);
}

.tone-gray {
  background: linear-gradient(180deg, #f4f2ef 0%, #ece8e2 100%);
}
