<view class="detail-page">
  <nav-bar title="售后详情" showTitle="{{true}}" showBack="{{true}}" background="solid" dark="{{true}}" placeholder="{{true}}" />

  <view class="loading-wrap" wx:if="{{loading}}">
    <van-loading size="24px" color="#A12D27">加载中...</van-loading>
  </view>

  <block wx:if="{{!loading && detail}}">
    <view class="status-stage">
      <view class="status-ticket {{ticketEntered ? 'ticket-entered' : 'ticket-entering'}} banner-{{detail.status}}">
        <view class="ticket-surface">
          <view class="ticket-upper">
            <view class="ticket-copy">
              <text class="ticket-title">{{statusInfo.text}}</text>
              <text class="ticket-desc">{{statusInfo.desc}}</text>
              <view class="ticket-meta-row">
                <text class="ticket-meta-pill">{{detail.type === 'refund_only' ? '仅退款' : '退货退款'}}</text>
                <text class="ticket-meta-note" wx:if="{{detail.reapply_count > 0}}">第 {{detail.reapply_count + 1}} 次申请</text>
              </view>
            </view>
            <view class="ticket-side">
              <view class="ticket-amount-block">
                <text class="ticket-amount-label">退款</text>
                <view class="ticket-amount-line">
                  <text class="ticket-amount-currency">¥</text>
                  <text class="ticket-amount-value">{{detail.refundDisplay}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="ticket-seam">
            <view class="ticket-dash"></view>
          </view>

          <view class="ticket-lower">
            <text class="ticket-order-caption">售后单号</text>
            <text class="ticket-order-id">{{detail._id}}</text>
          </view>
        </view>

        <view class="ticket-teeth">
          <view class="ticket-tooth" wx:for="{{ticketTeeth}}" wx:key="*this"></view>
        </view>
      </view>
    </view>

    <view class="content-wrap">
      <view class="panel panel-product" wx:if="{{order}}">
        <view class="panel-head">
          <view class="panel-title-wrap">
            <text class="panel-index">01</text>
            <view class="panel-copy">
              <text class="panel-title">关联商品</text>
              <text class="panel-desc">{{order.product_snapshot.workshop_name || '湘韵遗珍文创商城'}}</text>
            </view>
          </view>
          <view class="panel-meta">售后关联商品</view>
        </view>
        <view class="product-shell">
          <image class="product-image" src="{{order.product_snapshot.sku_image || order.product_snapshot.cover_img}}" mode="aspectFill" />
          <view class="product-main">
            <text class="product-title">{{order.product_snapshot.title}}</text>
            <text class="product-sku" wx:if="{{order.product_snapshot.sku_name}}">款式：{{order.product_snapshot.sku_name}}</text>
            <view class="product-tags">
              <text class="product-tag product-tag-brand">{{detail.type === 'refund_only' ? '仅退款' : '退货退款'}}</text>
              <text class="product-tag">{{statusInfo.text}}</text>
            </view>
          </view>
          <view class="product-side">
            <text class="product-price">¥{{orderTotalDisplay}}</text>
            <text class="product-count">x {{order.quantity}}</text>
          </view>
        </view>
      </view>

      <view class="panel">
        <view class="panel-head">
          <view class="panel-title-wrap">
            <text class="panel-index">02</text>
            <view class="panel-copy">
              <text class="panel-title">售后信息</text>
              <text class="panel-desc">本次售后申请的类型、金额与提交原因</text>
            </view>
          </view>
          <text class="panel-meta" wx:if="{{detail.reapply_count > 0}}">第 {{detail.reapply_count + 1}} 次申请</text>
        </view>

        <view class="field-grid">
          <view class="field-block info-grid-item">
            <view class="field-head">
              <text class="field-label">售后类型</text>
            </view>
            <text class="grid-value">{{detail.type === 'refund_only' ? '仅退款' : '退货退款'}}</text>
          </view>
          <view class="field-block info-grid-item">
            <view class="field-head">
              <text class="field-label">退款金额</text>
            </view>
            <text class="grid-value price-val">¥{{detail.refundDisplay}}</text>
          </view>
          <view class="field-block info-grid-item grid-span-full">
            <view class="field-head">
              <text class="field-label">申请原因</text>
            </view>
            <text class="grid-value">{{detail.reason}}</text>
          </view>
        </view>
      </view>

      <view class="panel" wx:if="{{detail.proof_imgs && detail.proof_imgs.length > 0}}">
        <view class="panel-head">
          <view class="panel-title-wrap">
            <text class="panel-index">03</text>
            <view class="panel-copy">
              <text class="panel-title">凭证图片</text>
              <text class="panel-desc">买家上传的申请凭证，点击可查看大图</text>
            </view>
          </view>
        </view>
        <view class="proof-imgs">
          <image
            wx:for="{{detail.proof_imgs}}"
            wx:key="index"
            class="proof-img"
            src="{{item}}"
            mode="aspectFill"
            bindtap="previewImg"
            data-src="{{item}}"
          />
        </view>
      </view>

      <view class="panel" wx:if="{{!isPickupReturn && detail.return_address && detail.status >= 1}}">
        <view class="panel-head">
          <view class="panel-title-wrap">
            <text class="panel-index">04</text>
            <view class="panel-copy">
              <text class="panel-title">退货地址</text>
              <text class="panel-desc">卖家确认退货后返回给买家的收件地址</text>
            </view>
          </view>
        </view>
        <view class="field-block address-shell">
          <text class="addr-name">{{detail.return_address.name}} {{detail.return_address.phone}}</text>
          <text class="addr-detail">{{detail.return_address.province || ''}}{{detail.return_address.city || ''}}{{detail.return_address.district || ''}} {{detail.return_address.detail}}</text>
        </view>
      </view>

      <view class="panel" wx:if="{{isPickupReturn && detail.status >= 1}}">
        <view class="panel-head">
          <view class="panel-title-wrap">
            <text class="panel-index">04</text>
            <view class="panel-copy">
              <text class="panel-title">交还方式</text>
              <text class="panel-desc">该订单通过同城自提方式完成退货交接，无需填写退货单号</text>
            </view>
          </view>
        </view>
        <view class="field-block address-shell">
          <text class="addr-name">同城自提交还</text>
          <text class="addr-detail">{{detail.status >= 2 ? '买家已确认交还商品，等待商家确认收回并退款。' : '卖家已同意退货，买家可与商家约定时间当面交还商品。'}}</text>
        </view>
      </view>

      <view class="panel" wx:if="{{operationLogs.length > 0}}">
        <view class="panel-head">
          <view class="panel-title-wrap">
            <text class="panel-index">05</text>
            <view class="panel-copy">
              <text class="panel-title">处理进度</text>
              <text class="panel-desc">按时间倒序记录买家、卖家与系统的处理动作</text>
            </view>
          </view>
        </view>
        <view class="timeline-shell op-timeline">
          <view class="op-tl-item {{index === 0 ? 'op-active' : ''}}" wx:for="{{operationLogs}}" wx:key="index">
            <view class="op-tl-left">
              <view class="op-tl-dot {{item.operator === 'system' ? 'dot-sys' : item.operator === 'seller' ? 'dot-seller' : 'dot-buyer'}}"></view>
              <view class="op-tl-line" wx:if="{{index < operationLogs.length - 1}}"></view>
            </view>
            <view class="op-tl-right">
              <view class="op-tl-header">
                <text class="op-tl-role {{item.operator}}">{{item.operatorLabel}}</text>
                <text class="op-tl-time">{{item.timeDisplay}}</text>
              </view>
              <text class="op-tl-content">{{item.content}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="action-bar">
      <block wx:if="{{role === 'buyer'}}">
        <block wx:if="{{detail.status === 0}}">
          <view class="footer-btn footer-btn-secondary" bindtap="cancelAftersale">撤销申请</view>
          <view class="footer-note">等待卖家审核中</view>
        </block>
        <block wx:elif="{{detail.status === 1}}">
          <view class="footer-btn footer-btn-secondary" bindtap="cancelAftersale">撤销申请</view>
          <view class="footer-btn footer-btn-primary" bindtap="openShipPopup">{{isPickupReturn ? '确认已交还商品' : '填写退货单号'}}</view>
        </block>
        <block wx:elif="{{detail.status === 2}}">
          <view class="footer-note footer-note-full">{{isPickupReturn ? '已确认交还商品，等待商家确认' : '退货已寄出，等待卖家验收'}}</view>
        </block>
        <block wx:elif="{{detail.status === -1}}">
          <view class="footer-btn footer-btn-primary" bindtap="reapply">修改后重新申请</view>
        </block>
        <block wx:elif="{{detail.status === 3}}">
          <view class="footer-note footer-note-full">退款已到账</view>
        </block>
        <block wx:elif="{{detail.status === -2}}">
          <view class="footer-btn footer-btn-primary" bindtap="reapply">重新发起申请</view>
        </block>
      </block>

      <block wx:elif="{{role === 'seller'}}">
        <block wx:if="{{detail.status === 0}}">
          <view class="footer-btn footer-btn-danger" bindtap="openRejectPopup">拒绝申请</view>
          <view class="footer-btn footer-btn-success" bindtap="openApprovePopup">{{detail.type === 'refund_only' ? '同意退款' : '同意退货'}}</view>
        </block>
        <block wx:elif="{{detail.status === 1}}">
          <view class="footer-note footer-note-full">{{isPickupReturn ? '等待买家交还商品' : '等待买家寄回退货'}}</view>
        </block>
        <block wx:elif="{{detail.status === 2}}">
          <view class="footer-btn footer-btn-primary" bindtap="confirmReturn">{{isPickupReturn ? '确认收到商品并退款' : '确认收到退货并退款'}}</view>
        </block>
        <block wx:elif="{{detail.status === -1}}">
          <view class="footer-note footer-note-full">已拒绝，等待买家决定</view>
        </block>
        <block wx:elif="{{detail.status === 3}}">
          <view class="footer-note footer-note-full">退款已完成</view>
        </block>
      </block>
    </view>
  </block>
</view>

<van-popup show="{{role === 'buyer' && showShipPopup}}" position="bottom" round bind:close="closeShipPopup">
  <view class="popup-content">
    <view class="popup-handle"></view>
    <view class="popup-title">填写退货物流</view>
    <view class="carrier-grid">
      <view class="carrier-item {{shipForm.com === item.code ? 'carrier-active' : ''}}" wx:for="{{carriers}}" wx:key="code" bindtap="selectCarrier" data-code="{{item.code}}">
        {{item.name}}
      </view>
    </view>
    <van-field value="{{shipForm.num}}" label="快递单号" placeholder="请输入退货快递单号" border="{{false}}" custom-class="popup-field" bind:change="onTrackingInput" />
    <view class="popup-actions">
      <view class="popup-btn popup-btn-primary" bindtap="submitShipReturn">{{shipSubmitting ? '提交中...' : '提交物流信息'}}</view>
    </view>
  </view>
</van-popup>

<van-popup show="{{role === 'seller' && showRejectPopup}}" position="bottom" round bind:close="closeRejectPopup">
  <view class="popup-content">
    <view class="popup-handle"></view>
    <view class="popup-title">拒绝售后</view>
    <textarea class="reject-input" placeholder="请填写拒绝原因（必填）" value="{{rejectReason}}" bindinput="onRejectInput" maxlength="200" />
    <view class="popup-actions">
      <view class="popup-btn popup-btn-danger" bindtap="submitReject">{{rejectSubmitting ? '提交中...' : '确认拒绝'}}</view>
    </view>
  </view>
</van-popup>

<van-popup show="{{role === 'seller' && showApprovePopup}}" position="bottom" round bind:close="closeApprovePopup" custom-style="max-height:85vh;">
  <view class="popup-content">
    <view class="popup-handle"></view>
    <view class="popup-title">同意退货</view>
    <text class="popup-subtitle">为买家确认退货路径，可从已保存地址中选择，也可填写新地址。</text>

    <view class="saved-addr-list" wx:if="{{savedAddresses.length > 0 && !showManualAddr}}">
      <view class="saved-addr-item {{selectedAddrIdx === index ? 'addr-selected' : ''}}" wx:for="{{savedAddresses}}" wx:key="_id" bindtap="selectSavedAddr" data-idx="{{index}}">
        <view class="addr-check">
          <van-icon name="{{selectedAddrIdx === index ? 'checked' : 'circle'}}" size="20" color="{{selectedAddrIdx === index ? '#10b981' : '#ccc'}}" />
        </view>
        <view class="addr-info-wrap">
          <view class="addr-user">
            <text class="addr-u-name">{{item.name}}</text>
            <text class="addr-u-phone">{{item.phone}}</text>
            <van-tag color="#ff9500" plain size="mini" wx:if="{{item.is_default}}">默认</van-tag>
          </view>
          <text class="addr-full">{{item.province}}{{item.city}}{{item.district}} {{item.detail}}</text>
        </view>
      </view>
      <view class="manual-switch" bindtap="switchToManual">
        <van-icon name="plus" size="16" color="#8B6F47" />
        <text>使用新地址</text>
      </view>
    </view>

    <view wx:if="{{showManualAddr}}">
      <view class="manual-switch back" bindtap="switchBackToList" wx:if="{{savedAddresses.length > 0}}">
        <van-icon name="arrow-left" size="14" color="#8B6F47" />
        <text>返回选择已有地址</text>
      </view>
      <van-field value="{{returnAddr.name}}" label="收件人" placeholder="姓名" border="{{false}}" custom-class="popup-field" bind:change="onAddrName" />
      <van-field value="{{returnAddr.phone}}" label="手机号" placeholder="手机号码" type="number" border="{{false}}" custom-class="popup-field" bind:change="onAddrPhone" />
      <view class="region-picker">
        <text class="region-label">所在地区</text>
        <picker mode="region" bindchange="onAddrRegion">
          <text class="region-val {{returnAddr.province ? '' : 'placeholder'}}">
            {{returnAddr.province ? returnAddr.province + ' ' + returnAddr.city + ' ' + returnAddr.district : '请选择省市区'}}
          </text>
        </picker>
      </view>
      <van-field value="{{returnAddr.detail}}" label="详细地址" placeholder="街道/门牌号" border="{{false}}" custom-class="popup-field" bind:change="onAddrDetail" />
    </view>

    <view class="popup-actions">
      <view class="popup-btn popup-btn-success" bindtap="submitApprove">
        {{approveSubmitting ? '提交中...' : '确认同意退货'}}
      </view>
    </view>
  </view>
</van-popup>

<van-dialog id="van-dialog" />
