<!--pages/aftersale/detail.wxml-->
<view class="detail-page">
  <nav-bar title="售后详情" showTitle="{{true}}" showBack="{{true}}" background="solid" dark="{{true}}" placeholder="{{true}}" />

  <view class="loading-wrap" wx:if="{{loading}}">
    <van-loading size="24px" color="#8B2E2A">加载中...</van-loading>
  </view>

  <block wx:if="{{!loading && detail}}">
    <!-- ===== 状态横幅 ===== -->
    <view class="status-banner banner-{{detail.status}}">
      <van-icon name="{{statusInfo.icon}}" size="44" color="#fff" />
      <view class="status-text-wrap">
        <text class="status-main">{{statusInfo.text}}</text>
        <text class="status-sub">{{statusInfo.desc}}</text>
      </view>
    </view>

    <!-- ===== 售后信息 ===== -->
    <view class="info-card">
      <view class="card-title">售后信息</view>
      <view class="info-row">
        <text class="info-label">售后类型</text>
        <van-tag color="{{detail.type === 'refund_only' ? '#1989fa' : '#8B2E2A'}}" plain>
          {{detail.type === 'refund_only' ? '仅退款' : '退货退款'}}
        </van-tag>
      </view>
      <view class="info-row">
        <text class="info-label">退款金额</text>
        <text class="info-val price-val">¥{{detail.refundDisplay}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">申请原因</text>
        <text class="info-val">{{detail.reason}}</text>
      </view>
      <view class="info-row" wx:if="{{detail.reapply_count > 0}}">
        <text class="info-label">申请次数</text>
        <text class="info-val">第 {{detail.reapply_count + 1}} 次（上限 3 次）</text>
      </view>
    </view>

    <!-- 凭证图片 -->
    <view class="info-card" wx:if="{{detail.proof_imgs && detail.proof_imgs.length > 0}}">
      <view class="card-title">凭证图片</view>
      <view class="proof-imgs">
        <image wx:for="{{detail.proof_imgs}}" wx:key="index" class="proof-img" src="{{item}}" mode="aspectFill" bindtap="previewImg" data-src="{{item}}" />
      </view>
    </view>

    <!-- 退货地址 -->
    <view class="info-card" wx:if="{{detail.return_address && detail.status >= 1}}">
      <view class="card-title">退货地址</view>
      <view class="return-addr">
        <text class="addr-name">{{detail.return_address.name}} {{detail.return_address.phone}}</text>
        <text class="addr-detail">{{detail.return_address.province || ''}}{{detail.return_address.city || ''}}{{detail.return_address.district || ''}} {{detail.return_address.detail}}</text>
      </view>
    </view>

    <!-- 商品信息 -->
    <view class="info-card" wx:if="{{order}}">
      <view class="card-title">商品信息</view>
      <view class="product-row">
        <image class="product-img" src="{{order.product_snapshot.cover_img}}" mode="aspectFill" />
        <view class="product-info">
          <text class="product-title">{{order.product_snapshot.title}}</text>
          <text class="product-price">¥{{orderTotalDisplay}} × {{order.quantity}}</text>
        </view>
      </view>
    </view>

    <!-- ===== 处理进度（operation_logs 时间轴） ===== -->
    <view class="info-card" wx:if="{{operationLogs.length > 0}}">
      <view class="card-title">处理进度</view>
      <view class="op-timeline">
        <view class="op-tl-item {{index === 0 ? 'op-active' : ''}}" wx:for="{{operationLogs}}" wx:key="index">
          <view class="op-tl-left">
            <view class="op-tl-dot {{item.operator === 'system' ? 'dot-sys' : item.operator === 'seller' ? 'dot-seller' : 'dot-buyer'}}"></view>
            <view class="op-tl-line" wx:if="{{index < operationLogs.length - 1}}"></view>
          </view>
          <view class="op-tl-right">
            <view class="op-tl-header">
              <text class="op-tl-role {{item.operator}}">{{item.operatorLabel}}</text>
              <text class="op-tl-time">{{item.timeDisplay}}</text>
            </view>
            <text class="op-tl-content">{{item.content}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ===== 底部操作区（角色由云函数返回，严格互斥） ===== -->
    <view class="action-bar">
      <!-- ===== 买家视角 ===== -->
      <block wx:if="{{role === 'buyer'}}">
        <block wx:if="{{detail.status === 0}}">
          <van-button round plain color="#999" size="small" bind:click="cancelAftersale">撤销申请</van-button>
          <text class="action-hint">等待卖家审核中</text>
        </block>
        <block wx:elif="{{detail.status === 1}}">
          <van-button round plain color="#999" size="small" bind:click="cancelAftersale">撤销申请</van-button>
          <van-button round color="#8B2E2A" size="small" bind:click="openShipPopup">填写退货单号</van-button>
        </block>
        <block wx:elif="{{detail.status === 2}}">
          <text class="action-hint">退货已寄出，等待卖家验收</text>
        </block>
        <block wx:elif="{{detail.status === -1}}">
          <van-button round color="#8B2E2A" size="small" bind:click="reapply">修改后重新申请</van-button>
        </block>
        <block wx:elif="{{detail.status === 3}}">
          <text class="action-hint">退款已到账</text>
        </block>
        <block wx:elif="{{detail.status === -2}}">
          <van-button round color="#8B6F47" size="small" bind:click="reapply">重新发起申请</van-button>
        </block>
      </block>

      <!-- ===== 卖家视角（wx:elif 保证互斥） ===== -->
      <block wx:elif="{{role === 'seller'}}">
        <block wx:if="{{detail.status === 0}}">
          <van-button round plain color="#ee0a24" size="small" bind:click="openRejectPopup">拒绝申请</van-button>
          <van-button round color="#10b981" size="small" bind:click="openApprovePopup">同意退货</van-button>
        </block>
        <block wx:elif="{{detail.status === 1}}">
          <text class="action-hint">等待买家寄回退货</text>
        </block>
        <block wx:elif="{{detail.status === 2}}">
          <van-button round color="#8B2E2A" size="small" bind:click="confirmReturn">确认收到退货并退款</van-button>
        </block>
        <block wx:elif="{{detail.status === -1}}">
          <text class="action-hint">已拒绝，等待买家决定</text>
        </block>
        <block wx:elif="{{detail.status === 3}}">
          <text class="action-hint">退款已完成</text>
        </block>
      </block>
    </view>
  </block>
</view>

<!-- 买家退货物流弹窗 -->
<van-popup show="{{role === 'buyer' && showShipPopup}}" position="bottom" round bind:close="closeShipPopup">
  <view class="popup-content">
    <view class="popup-title">填写退货物流</view>
    <view class="carrier-grid">
      <view class="carrier-item {{shipForm.com === item.code ? 'carrier-active' : ''}}" wx:for="{{carriers}}" wx:key="code" bindtap="selectCarrier" data-code="{{item.code}}">{{item.name}}</view>
    </view>
    <van-field value="{{shipForm.num}}" label="快递单号" placeholder="请输入退货快递单号" bind:change="onTrackingInput" />
    <view class="popup-actions">
      <van-button round block color="#8B2E2A" loading="{{shipSubmitting}}" bind:click="submitShipReturn">提交</van-button>
    </view>
  </view>
</van-popup>

<!-- 卖家拒绝弹窗 -->
<van-popup show="{{role === 'seller' && showRejectPopup}}" position="bottom" round bind:close="closeRejectPopup">
  <view class="popup-content">
    <view class="popup-title">拒绝售后</view>
    <textarea class="reject-input" placeholder="请填写拒绝原因（必填）" value="{{rejectReason}}" bindinput="onRejectInput" maxlength="200" />
    <view class="popup-actions">
      <van-button round block color="#ee0a24" loading="{{rejectSubmitting}}" bind:click="submitReject">确认拒绝</van-button>
    </view>
  </view>
</van-popup>

<!-- 卖家同意弹窗 -->
<van-popup show="{{role === 'seller' && showApprovePopup}}" position="bottom" round bind:close="closeApprovePopup" custom-style="max-height:85vh;">
  <view class="popup-content">
    <view class="popup-title">同意退货 — 选择退货地址</view>

    <!-- 已保存地址列表 -->
    <view class="saved-addr-list" wx:if="{{savedAddresses.length > 0 && !showManualAddr}}">
      <view class="saved-addr-item {{selectedAddrIdx === index ? 'addr-selected' : ''}}" wx:for="{{savedAddresses}}" wx:key="_id" bindtap="selectSavedAddr" data-idx="{{index}}">
        <view class="addr-check">
          <van-icon name="{{selectedAddrIdx === index ? 'checked' : 'circle'}}" size="20" color="{{selectedAddrIdx === index ? '#10b981' : '#ccc'}}" />
        </view>
        <view class="addr-info-wrap">
          <view class="addr-user">
            <text class="addr-u-name">{{item.name}}</text>
            <text class="addr-u-phone">{{item.phone}}</text>
            <van-tag color="#ff9500" plain size="mini" wx:if="{{item.is_default}}">默认</van-tag>
          </view>
          <text class="addr-full">{{item.province}}{{item.city}}{{item.district}} {{item.detail}}</text>
        </view>
      </view>
      <view class="manual-switch" bindtap="switchToManual">
        <van-icon name="plus" size="16" color="#8B6F47" />
        <text>使用新地址</text>
      </view>
    </view>

    <!-- 手动填写 -->
    <view wx:if="{{showManualAddr}}">
      <view class="manual-switch back" bindtap="switchBackToList" wx:if="{{savedAddresses.length > 0}}">
        <van-icon name="arrow-left" size="14" color="#8B6F47" />
        <text>返回选择已有地址</text>
      </view>
      <van-field value="{{returnAddr.name}}" label="收件人" placeholder="姓名" bind:change="onAddrName" />
      <van-field value="{{returnAddr.phone}}" label="手机号" placeholder="手机号码" type="number" bind:change="onAddrPhone" />
      <view class="region-picker">
        <text class="region-label">所在地区</text>
        <picker mode="region" bindchange="onAddrRegion">
          <text class="region-val {{returnAddr.province ? '' : 'placeholder'}}">
            {{returnAddr.province ? returnAddr.province + ' ' + returnAddr.city + ' ' + returnAddr.district : '请选择省市区'}}
          </text>
        </picker>
      </view>
      <van-field value="{{returnAddr.detail}}" label="详细地址" placeholder="街道/门牌号" bind:change="onAddrDetail" />
    </view>

    <view class="popup-actions">
      <van-button round block color="#10b981" loading="{{approveSubmitting}}" disabled="{{!returnAddr.name}}" bind:click="submitApprove">确认同意退货</van-button>
    </view>
  </view>
</van-popup>

<van-dialog id="van-dialog" />
