.detail-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #faf7f0 0%, #f3ede3 46%, #ebe1d2 100%);
  padding-bottom: 160rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.status-stage {
  position: relative;
  background: #f3ede3;
  padding: 0 22rpx 38rpx;
}

.status-ticket {
  position: relative;
  overflow: visible;
  z-index: 1;
  transition:
    transform 520ms cubic-bezier(0.2, 0.82, 0.24, 1),
    opacity 420ms ease,
    filter 520ms cubic-bezier(0.2, 0.82, 0.24, 1);
  transform-origin: top center;
  will-change: transform, opacity;
}

.ticket-entering {
  opacity: 0;
  transform: translateY(-56rpx) scale(0.985);
  filter: saturate(0.94);
}

.ticket-entered {
  opacity: 1;
  transform: translateY(0) scale(1);
  filter: saturate(1);
}

.ticket-surface,
.ticket-teeth {
  position: relative;
  z-index: 1;
}

.ticket-surface {
  overflow: hidden;
  box-shadow:
    0 18rpx 34rpx rgba(74, 58, 42, 0.16),
    0 28rpx 52rpx rgba(74, 58, 42, 0.08);
}

.banner-0 .ticket-surface {
  background: #ffac33;
}

.banner-1 .ticket-surface {
  background: #3a9fff;
}

.banner-2 .ticket-surface {
  background: #9d7a57;
}

.banner-3 .ticket-surface {
  background: #2fcd97;
}

.banner--1 .ticket-surface {
  background: #ff5a57;
}

.banner--2 .ticket-surface {
  background: #c5c5c5;
}

.ticket-upper {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx 30rpx 24rpx;
}

.ticket-copy {
  flex: 1;
  min-width: 0;
  padding-top: 10rpx;
}

.ticket-side {
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  flex-shrink: 0;
  min-width: 188rpx;
  padding-top: 10rpx;
}

.ticket-title {
  display: block;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: #ffffff;
}

.ticket-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.85);
}

.ticket-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.ticket-meta-pill,
.ticket-meta-note {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.92);
}

.ticket-meta-pill {
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.ticket-meta-note {
  background: rgba(255, 255, 255, 0.1);
}

.ticket-amount-block {
  position: relative;
  padding-top: 24rpx;
  text-align: right;
}

.ticket-amount-label {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 22rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.72);
  letter-spacing: 2rpx;
}

.ticket-amount-line {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  margin-top: 10rpx;
}

.ticket-amount-currency {
  font-size: 26rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
  margin-right: 4rpx;
}

.ticket-amount-value {
  display: block;
  font-size: 48rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
  font-family: Georgia, "Times New Roman", serif;
}

.ticket-seam {
  position: relative;
  height: 34rpx;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.ticket-seam::before,
.ticket-seam::after {
  content: '';
  position: absolute;
  top: 0;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #f3ede3;
  z-index: 2;
}

.ticket-seam::before {
  left: -17rpx;
}

.ticket-seam::after {
  right: -17rpx;
}

.ticket-dash {
  position: relative;
  z-index: 1;
  flex: 1;
  height: 4rpx;
  margin: 0 18rpx;
  background: repeating-linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.88) 0 18rpx,
    rgba(255, 255, 255, 0) 18rpx 34rpx
  );
  opacity: 0.95;
}

.ticket-lower {
  padding: 6rpx 30rpx 14rpx;
  text-align: center;
}

.ticket-order-caption {
  display: block;
  font-size: 20rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.72);
  letter-spacing: 8rpx;
  text-indent: 8rpx;
}

.ticket-order-id {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 2rpx;
  word-break: break-all;
}

.ticket-teeth {
  display: flex;
  align-items: flex-start;
  height: 22rpx;
  margin-top: -1rpx;
  padding: 0 2rpx;
  overflow: hidden;
  line-height: 0;
  font-size: 0;
}

.ticket-tooth {
  flex: 1 1 0;
  height: 22rpx;
  margin-left: -1rpx;
  -webkit-clip-path: polygon(0 0, 100% 0, 50% 100%);
  clip-path: polygon(0 0, 100% 0, 50% 100%);
}

.ticket-tooth:first-child {
  margin-left: 0;
}

.banner-0 .ticket-tooth {
  background: #ffac33;
}

.banner-1 .ticket-tooth {
  background: #3a9fff;
}

.banner-2 .ticket-tooth {
  background: #9d7a57;
}

.banner-3 .ticket-tooth {
  background: #2fcd97;
}

.banner--1 .ticket-tooth {
  background: #ff5a57;
}

.banner--2 .ticket-tooth {
  background: #c5c5c5;
}

.content-wrap {
  padding: 22rpx 24rpx 0;
}

.panel {
  margin-bottom: 24rpx;
  padding: 26rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow:
    0 14rpx 34rpx rgba(66, 48, 34, 0.05),
    0 1rpx 0 rgba(255, 255, 255, 0.85) inset;
}

.panel-product {
  background: linear-gradient(180deg, rgba(255, 250, 247, 0.98) 0%, rgba(255, 255, 255, 0.94) 100%);
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.panel-title-wrap {
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.panel-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: #f7eee8;
  color: #b63b36;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
  flex-shrink: 0;
}

.panel-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.panel-title {
  font-size: 30rpx;
  line-height: 1.2;
  color: #2c231e;
  font-weight: 700;
}

.panel-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #9b8e83;
}

.panel-meta {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f7f2ed;
  color: #8a7a6e;
  font-size: 20rpx;
  line-height: 1;
}

.product-shell {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fbfaf8;
  border: 1rpx solid rgba(125, 100, 81, 0.08);
}

.product-image {
  width: 166rpx;
  height: 166rpx;
  border-radius: 22rpx;
  background: #ede4db;
  flex-shrink: 0;
}

.product-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.product-title {
  font-size: 28rpx;
  line-height: 1.45;
  color: #2d241f;
  font-weight: 700;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-sku {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #94877b;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.product-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f5f2ee;
  font-size: 20rpx;
  line-height: 1;
  color: #7c7066;
}

.product-tag-brand {
  background: linear-gradient(135deg, rgba(182, 59, 54, 0.12) 0%, rgba(212, 87, 79, 0.18) 100%);
  color: #b63b36;
}

.product-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
}

.product-price {
  font-size: 34rpx;
  line-height: 1;
  color: #9f2b24;
  font-weight: 700;
}

.product-count {
  font-size: 22rpx;
  color: #9f9489;
}

.field-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx 14rpx;
  margin-top: 22rpx;
}

.field-block,
.select-block {
  margin-top: 22rpx;
  padding: 22rpx 22rpx 18rpx;
  border-radius: 22rpx;
  background: #fbfaf8;
  border: 1rpx solid rgba(125, 100, 81, 0.06);
}

.field-grid .field-block {
  margin-top: 0;
}

.field-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.field-label {
  font-size: 24rpx;
  line-height: 1.2;
  color: #5b5048;
  font-weight: 600;
}

.info-grid-item {
  min-width: 0;
}

.grid-span-full {
  grid-column: 1 / -1;
}

.grid-value {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #342d28;
  font-weight: 600;
}

.price-val {
  color: #9f2b24;
}

.proof-imgs {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 22rpx;
}

.proof-img {
  width: 198rpx;
  height: 198rpx;
  border-radius: 24rpx;
  background: #ede4db;
  box-shadow: 0 14rpx 28rpx rgba(66, 48, 34, 0.08);
}

.address-shell {
  margin-top: 22rpx;
}

.addr-name {
  display: block;
  font-size: 28rpx;
  line-height: 1.4;
  color: #342d28;
  font-weight: 700;
}

.addr-detail {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #7f7369;
}

.timeline-shell {
  margin-top: 22rpx;
  padding: 12rpx 18rpx;
  border-radius: 24rpx;
  background: #fbfaf8;
  border: 1rpx solid rgba(125, 100, 81, 0.08);
}

.op-timeline {
  margin-top: 0;
}

.op-tl-item {
  display: flex;
  gap: 16rpx;
  min-height: 90rpx;
}

.op-tl-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20rpx;
  flex-shrink: 0;
}

.op-tl-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.dot-buyer {
  background: #1989fa;
}

.dot-seller {
  background: #8b2e2a;
}

.dot-sys {
  background: #ff9500;
}

.op-active .op-tl-dot {
  width: 20rpx;
  height: 20rpx;
  box-shadow: 0 0 0 6rpx rgba(182, 59, 54, 0.1);
  margin-top: 6rpx;
}

.op-tl-line {
  width: 3rpx;
  flex: 1;
  background: #e8e0d4;
  min-height: 20rpx;
}

.op-tl-right {
  flex: 1;
  padding-bottom: 20rpx;
}

.op-tl-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.op-tl-role {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.op-tl-role.buyer {
  color: #1989fa;
  background: #e8f3ff;
}

.op-tl-role.seller {
  color: #8b2e2a;
  background: #fef5f5;
}

.op-tl-role.system {
  color: #ff9500;
  background: #fff8f0;
}

.op-tl-time {
  font-size: 20rpx;
  color: #b9aea3;
}

.op-tl-content {
  font-size: 24rpx;
  line-height: 1.65;
  color: #6b6057;
}

.op-active .op-tl-content {
  color: #333333;
  font-weight: 500;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 -6rpx 24rpx rgba(92, 79, 66, 0.08);
}

.footer-note {
  margin-right: auto;
  font-size: 24rpx;
  color: #8f8378;
}

.footer-note-full {
  width: 100%;
  margin-right: 0;
  text-align: center;
}

.footer-btn {
  min-width: 168rpx;
  height: 68rpx;
  padding: 0 30rpx;
  border-radius: 34rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid transparent;
  background: rgba(255, 255, 255, 0.92);
  transition:
    transform 0.18s ease,
    box-shadow 0.18s ease,
    border-color 0.18s ease,
    color 0.18s ease;
}

.footer-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 14rpx rgba(92, 79, 66, 0.06);
}

.footer-btn-secondary {
  color: #5f5249;
  border: 1rpx solid rgba(129, 107, 89, 0.24);
}

.footer-btn-primary {
  color: #b63b36;
  border-color: rgba(182, 59, 54, 0.56);
}

.footer-btn-success {
  color: #2f9b74;
  border-color: rgba(47, 155, 116, 0.5);
}

.footer-btn-danger {
  color: #b63b36;
  border-color: rgba(182, 59, 54, 0.56);
}

.popup-content {
  padding: 20rpx 28rpx calc(36rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #fffdfa 0%, #f8f2ea 100%);
}

.popup-handle {
  width: 80rpx;
  height: 8rpx;
  background: #e0d6c8;
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  text-align: center;
}

.popup-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #9c8e82;
  text-align: center;
}

.popup-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 32rpx;
}

.popup-btn {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  padding: 0 28rpx;
  border-radius: 34rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid transparent;
  transition:
    transform 0.18s ease,
    box-shadow 0.18s ease,
    border-color 0.18s ease,
    color 0.18s ease;
}

.popup-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 14rpx rgba(92, 79, 66, 0.06);
}

.popup-btn-primary {
  color: #b63b36;
  border-color: rgba(182, 59, 54, 0.56);
}

.popup-btn-danger {
  color: #b63b36;
  border-color: rgba(182, 59, 54, 0.56);
}

.popup-btn-success {
  color: #2f9b74;
  border-color: rgba(47, 155, 116, 0.5);
}

.carrier-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 28rpx;
}

.carrier-item {
  padding: 12rpx 28rpx;
  border: 2rpx solid #e8e0d4;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666666;
  background: rgba(255, 255, 255, 0.92);
}

.carrier-active {
  border-color: #8b2e2a;
  color: #8b2e2a;
  background: #fef5f5;
}

.popup-field {
  margin-top: 22rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 18rpx;
  padding: 10rpx 20rpx !important;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.reject-input {
  width: 100%;
  min-height: 220rpx;
  margin-top: 26rpx;
  padding: 18rpx;
  border: 2rpx solid #f0ebe3;
  border-radius: 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
  background: rgba(255, 255, 255, 0.92);
  box-sizing: border-box;
}

.saved-addr-list {
  max-height: 50vh;
  margin-top: 26rpx;
  overflow-y: auto;
}

.saved-addr-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #f5f0e8;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 18rpx;
  margin-bottom: 12rpx;
}

.saved-addr-item.addr-selected {
  background: #f0fdf4;
}

.addr-check {
  flex-shrink: 0;
  padding-top: 4rpx;
}

.addr-info-wrap {
  flex: 1;
  min-width: 0;
}

.addr-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.addr-u-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.addr-u-phone {
  font-size: 26rpx;
  color: #666666;
}

.addr-full {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8f8378;
}

.manual-switch {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  font-size: 26rpx;
  color: #8b6f47;
}

.manual-switch.back {
  justify-content: flex-start;
  padding: 16rpx 0 8rpx;
}

.region-picker {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.region-label {
  font-size: 28rpx;
  color: #646566;
  width: 180rpx;
  flex-shrink: 0;
}

.region-val {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.placeholder {
  color: #c8c9cc;
}
