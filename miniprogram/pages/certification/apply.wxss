.page {
  min-height: 100vh;
  background-color: #f6f6f6;
}

.content {
  padding: 24rpx 28rpx 40rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.tip {
  background: linear-gradient(135deg, #fff4f4, #ffeaea);
}

.tip-title {
  font-size: 30rpx;
  color: #b63b36;
  font-weight: 600;
}

.tip-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #444;
  line-height: 1.6;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.section-desc {
  margin: 12rpx 0 20rpx;
  font-size: 24rpx;
  color: #888;
}

.counter {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.value-placeholder {
  color: #c8c9cc;
}

.value-text {
  color: #333;
}

.footer {
  margin-top: 36rpx;
}

/* ========== 自定义证书上传区域 ========== */
.cert-upload-area {
  margin-top: 16rpx;
}

.cert-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.cert-item {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #f5f5f5;
}

.cert-image {
  width: 100%;
  height: 100%;
}

.cert-delete-btn {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cert-delete-icon {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1;
  margin-top: -4rpx;
}

.add-cert-btn {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.add-cert-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

