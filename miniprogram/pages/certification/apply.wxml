<view class="page">
  <nav-bar
    title="传承人认证"
    showTitle="{{true}}"
    showBack="{{true}}"
    background="solid"
    dark="{{true}}"
    placeholder="{{true}}"
  />

  <view class="content">
    <view class="card tip">
      <text class="tip-title">认证说明</text>
      <text class="tip-desc">认证通过后将按你填写的工坊名称、Logo 和寄语直接创建工坊，不再默认沿用个人昵称和头像。</text>
    </view>

    <view class="card">
      <van-cell-group border="{{false}}">
        <van-field
          label="真实姓名"
          placeholder="请输入真实姓名"
          value="{{realName}}"
          required
          maxlength="20"
          bind:change="onRealNameInput"
        />
        <van-cell
          title="非遗类别"
          is-link
          clickable
          value="{{ichCategory || '请选择'}}"
          value-class="{{ichCategory ? 'value-text' : 'value-placeholder'}}"
          bind:click="openCategorySheet"
        />
        <van-field
          label="工坊名称"
          placeholder="请输入唯一工坊名称"
          value="{{workshopName}}"
          required
          maxlength="20"
          bind:change="onWorkshopNameInput"
        />
      </van-cell-group>
    </view>

    <view class="card">
      <view class="section-title">工坊 Logo</view>
      <view class="section-desc">请上传独立的工坊头像，不再与个人头像绑定。</view>

      <view class="single-upload">
        <view class="logo-preview" wx:if="{{logoFiles.length > 0}}">
          <image class="logo-image" src="{{logoFiles[0].url}}" mode="aspectFill" />
          <view class="cert-delete-btn" catchtap="handleDeleteLogo">
            <text class="cert-delete-icon">×</text>
          </view>
        </view>

        <view class="add-cert-btn logo-add" wx:else bindtap="chooseLogoImage">
          <van-icon name="plus" size="28" color="#999" />
          <text class="add-cert-text">上传 Logo</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="section-title">证书证明</view>
      <view class="section-desc">请上传资质证明（1-3张）</view>

      <view class="cert-upload-area">
        <view class="cert-list">
          <view
            class="cert-item"
            wx:for="{{certFiles}}"
            wx:key="url"
          >
            <image class="cert-image" src="{{item.url}}" mode="aspectFill" />
            <view class="cert-delete-btn" data-index="{{index}}" catchtap="handleDeleteCert">
              <text class="cert-delete-icon">×</text>
            </view>
          </view>

          <view class="add-cert-btn" wx:if="{{certFiles.length < 3}}" bindtap="chooseCertImages">
            <van-icon name="plus" size="28" color="#999" />
            <text class="add-cert-text">{{certFiles.length}}/3</text>
          </view>
        </view>
      </view>
    </view>

    <view class="card">
      <van-field
        label="主理人寄语"
        type="textarea"
        autosize
        maxlength="300"
        required
        placeholder="写下工坊的故事、技艺温度与想传递给大家的话（至少10字）"
        value="{{workshopDesc}}"
        bind:change="onWorkshopDescInput"
      />
      <view class="counter">{{workshopDesc.length}} / 300</view>
    </view>

    <view class="footer">
      <van-button
        type="primary"
        block
        round
        color="#b63b36"
        loading="{{submitting}}"
        disabled="{{submitting}}"
        bind:click="submitApplication"
      >
        {{submitting ? '提交中...' : '提交认证申请'}}
      </van-button>
    </view>
  </view>
</view>

<van-action-sheet
  show="{{showCategorySheet}}"
  actions="{{categoryActions}}"
  cancel-text="取消"
  bind:close="onCloseCategorySheet"
  bind:select="onSelectCategory"
/>
