<!--pages/home/home.wxml-->

<view class="page">

  <!-- ═══════════ 底层：地图探索区（全屏上划手势绑定在此） ═══════════ -->
  <view class="base-layer"
    bindtouchstart="onPageSwipeStart"
    bindtouchend="onPageSwipeEnd"
  >

    <view class="top-bar" style="padding-top: {{statusBarHeight}}px;">
      <view class="brand">
        <text class="brand-name">湘韵遗珍</text>
        <text class="brand-tagline">湖南非遗地图</text>
      </view>
    </view>

    <!-- 地图区域 -->
    <view class="map-wrap" style="height: {{mapHeight}}px;">

      <view class="map-loading-cover" wx:if="{{mapLoading}}">
        <van-loading type="spinner" size="26px" color="#b63b36" />
        <text class="map-loading-text">地图加载中...</text>
      </view>

      <ec-canvas
        wx:if="{{showCanvas}}"
        id="hunan-map"
        canvas-id="hunan-map-canvas"
        ec="{{ec}}"
        class="ec-canvas"
      ></ec-canvas>

      <view wx:if="{{!showCanvas}}" class="map-placeholder"></view>

    </view>

    <!-- 数据概览 -->
    <view class="stats-zone">
      <view class="stats-loading-wrap" wx:if="{{statsLoading}}">
        <van-loading type="spinner" size="18px" color="#b63b36" />
      </view>
      <view class="stats-content" wx:else>
        <view class="stats-region-row">
          <view class="region-dot"></view>
          <text class="region-name">{{selectedCity || '湖南省'}}</text>
          <text class="region-hint">非遗概览</text>
          <view class="region-clear-btn" wx:if="{{selectedCity}}" bindtap="_deselectCity">
            <text>✕ 清除</text>
          </view>
        </view>
        <view class="stats-numbers-row">
          <view class="stat-block">
            <text class="stat-num">{{statsData.projectCount}}</text>
            <text class="stat-label">非遗项目</text>
          </view>
          <view class="stat-sep"></view>
          <view class="stat-block">
            <text class="stat-num">{{statsData.inheritorCount}}</text>
            <text class="stat-label">传承人</text>
          </view>
          <view class="stat-view-all" wx:if="{{selectedCity}}" bindtap="goToProjects">
            <text>查看全部</text>
            <van-icon name="arrow" size="12" color="#b63b36" />
          </view>
        </view>

        <view class="quote-zone {{quoteVisible ? 'quote-visible' : ''}}">
          <text class="quote-icon">"</text>
          <text class="quote-text">{{cityQuote}}</text>
        </view>
      </view>
    </view>

    <!-- 快捷导航 -->
    <view class="quick-nav-row">
      <view class="nav-capsule nav-capsule--primary" bindtap="goToProjects">
        <van-icon name="records-o" size="18" color="#ffffff" />
        <text>非遗项目</text>
      </view>
      <view class="nav-capsule nav-capsule--secondary" bindtap="goToInheritors">
        <van-icon name="friends-o" size="18" color="#8b6f47" />
        <text>非遗传承人</text>
      </view>
    </view>

    <view style="height: {{baseBottomSpace}}px; flex-shrink: 0;"></view>
  </view>

  <!-- ═══════════ 遮罩 ═══════════ -->
  <view
    class="backdrop"
    wx:if="{{showBackdrop}}"
    style="opacity: {{backdropOpacity}};"
    bindtap="collapseSheet"
  ></view>

  <!-- ═══════════ 底部资讯面板 ═══════════ -->
  <view
    class="bottom-sheet"
    style="transform: translateY({{sheetTranslateY}}px); transition: {{sheetTransition}}; height: {{sheetHeight}}px; bottom: {{tabBarHeight}}px;"
  >
    <view class="sheet-header">
      <!-- 扁平向上箭头，引导用户上划 -->
      <view class="swipe-hint-wrap">
        <view class="swipe-up-chevron">
          <view class="chevron-line chevron-left"></view>
          <view class="chevron-line chevron-right"></view>
        </view>
      </view>
      <view class="news-tab-bar">
        <view class="news-tab {{activeTab === 'flash' ? 'news-tab--active' : ''}}" bindtap="switchTab" data-tab="flash">
          <text>非遗快讯</text>
          <view class="tab-underline" wx:if="{{activeTab === 'flash'}}"></view>
        </view>
        <view class="news-tab {{activeTab === 'policy' ? 'news-tab--active' : ''}}" bindtap="switchTab" data-tab="policy">
          <text>政策法规</text>
          <view class="tab-underline" wx:if="{{activeTab === 'policy'}}"></view>
        </view>
      </view>
    </view>

    <scroll-view class="news-scroll" style="height: {{newsScrollHeight}}px;" scroll-y="{{isExpanded}}" show-scrollbar="{{false}}" enhanced>
      <view class="news-loading-wrap" wx:if="{{newsLoading}}">
        <van-loading type="spinner" size="28px" color="#b63b36" />
        <text class="news-loading-text">加载资讯中...</text>
      </view>
      <van-empty wx:elif="{{!newsLoading && newsList.length === 0}}" description="暂无相关资讯" />
      <block wx:else>
        <view class="news-item" wx:for="{{newsList}}" wx:key="_id" bindtap="goToNewsDetail" data-id="{{item.news_id}}">
          <view class="news-item-main">
            <text class="news-title">{{item.title}}</text>
            <view class="news-meta-row">
              <text class="news-meta">{{item.publish_date_str}}</text>
              <text class="news-meta news-meta--source" wx:if="{{item.source}}">来源：{{item.source}}</text>
            </view>
          </view>
          <image wx:if="{{item.cover_image}}" class="news-thumb" src="{{item.cover_image}}" mode="aspectFill" lazy-load />
        </view>
        <view class="list-bottom-safe"></view>
      </block>
    </scroll-view>
  </view>

</view>
