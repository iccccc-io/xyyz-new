/* pages/home/home.wxss */
/* 沉浸式首页样式 */

page {
  background: #b63b36;
  min-height: 100vh;
}

.home-container {
  min-height: 100vh;
}

/* ========== 沉浸式顶部区域 ========== */
.hero-section {
  position: relative;
  padding-bottom: 60rpx;
  overflow: hidden;
}

/* 背景 */
.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #c94843 0%, #b63b36 50%, #8b2e2a 100%);
}

/* 装饰性覆盖层 */
.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at top right, rgba(255,255,255,0.15) 0%, transparent 60%);
}

/* 状态栏占位 */
.status-bar-placeholder {
  width: 100%;
}

/* 顶部内容 */
.hero-content {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx 60rpx;
}

.title-group {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 60rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}

.user-entry {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.user-entry:active {
  transform: scale(0.92);
  background: rgba(255, 255, 255, 0.3);
}

/* ========== 白色内容卡片 ========== */
.content-card {
  position: relative;
  background: #f5f5f5;
  border-radius: 40rpx 40rpx 0 0;
  margin-top: -40rpx;
  padding: 40rpx 30rpx;
  min-height: 800rpx;
  z-index: 20;
}

/* ========== 导航区块 ========== */
.nav-section {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 24rpx;
  position: relative;
  padding-bottom: 16rpx;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(to right, #b63b36, #d4574f);
  border-radius: 3rpx;
}

/* Vant Grid 自定义样式 */
.van-grid-item__content {
  padding: 24rpx 16rpx !important;
  background: #fafafa;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.van-grid-item__content:active {
  background: #f0f0f0;
  transform: scale(0.96);
}

.van-grid-item__icon {
  font-size: 44rpx !important;
  margin-bottom: 12rpx;
}

.van-grid-item__text {
  font-size: 26rpx !important;
  color: #333333 !important;
  margin-top: 6rpx;
  font-weight: 500;
}

/* ========== Banner 通用样式 ========== */
.community-banner,
.mall-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-top: 16rpx;
  transition: all 0.2s;
}

.community-banner:active,
.mall-banner:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 社区入口 */
.community-banner {
  background: linear-gradient(135deg, #8b6f47 0%, #6d5636 100%);
}

/* 商城入口 */
.mall-banner {
  background: linear-gradient(135deg, #b63b36 0%, #8b2e2a 100%);
}

.banner-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.banner-icon {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.banner-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.mall-icon {
  background: rgba(255, 215, 160, 0.3);
}

/* ========== 安全区域 ========== */
.safe-area-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
