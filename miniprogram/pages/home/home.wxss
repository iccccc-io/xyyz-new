/* pages/home/home.wxss */

page {
  background: #f0e6cf;
  height: 100vh;
  overflow: hidden;
}

.page {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background: linear-gradient(170deg, #fdf4e3 0%, #f0e8d0 55%, #e5d9b8 100%);
}

.base-layer {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
  display: flex;
  flex-direction: column;
}

/* ─── 顶部品牌栏 ─── */
.top-bar {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 40rpx 12rpx;
  flex-shrink: 0;
}

.brand {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.brand-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #3a1a0a;
  letter-spacing: 8rpx;
}

.brand-tagline {
  font-size: 22rpx;
  color: #8b6f47;
  letter-spacing: 3rpx;
}

/* ─── 地图：flex:1 自动填充剩余空间 ─── */
.map-wrap {
  position: relative;
  width: 100%;
  flex: 1;
  min-height: 400rpx;
  overflow: visible;
}

.ec-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.map-loading-cover {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(253, 244, 227, 0.85);
  gap: 16rpx;
}

.map-loading-text {
  font-size: 24rpx;
  color: #8b6f47;
}

.map-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(170deg, #fdf4e3 0%, #f0e8d0 55%, #e5d9b8 100%);
}

/* ─── 数据概览：固定内容高度，紧贴地图下方 ─── */
/* .stats-zone {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  padding: 16rpx 40rpx 16rpx;
  overflow: hidden;
} */
.stats-zone {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  padding: 20rpx 40rpx 50rpx;
  background: transparent;
  overflow: hidden;
}

.stats-loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.stats-content {
  width: 100%;
}

.stats-region-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.region-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #b63b36;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(182, 59, 54, 0.2);
}

.region-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #3a1a0a;
  letter-spacing: 2rpx;
}

.region-hint {
  font-size: 22rpx;
  color: #a08868;
}

.region-clear-btn {
  margin-left: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(182, 59, 54, 0.3);
  background: rgba(182, 59, 54, 0.06);
}

.region-clear-btn:active {
  background: rgba(182, 59, 54, 0.15);
}

.region-clear-btn text {
  font-size: 20rpx;
  color: #b63b36;
  line-height: 1;
}

.stats-numbers-row {
  display: flex;
  align-items: center;
  gap: 36rpx;
  flex-wrap: wrap;
}

.stat-block {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

/* ─── 机械翻页滚轮计数器 ─── */
.roll-number {
  display: flex;
  align-items: flex-end;
}

.roll-digit-wrap {
  height: 60rpx;
  overflow: hidden;
}

.roll-digit-col {
  transition: transform 0.6s cubic-bezier(0.22, 0.68, 0.35, 1);
}

.roll-d {
  display: block;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 52rpx;
  font-weight: bold;
  color: #b63b36;
  text-align: center;
  font-variant-numeric: tabular-nums;
}

.stat-label {
  font-size: 22rpx;
  color: #8b6f47;
  font-weight: 500;
  line-height: 60rpx;
}

.stat-sep {
  width: 2rpx;
  height: 48rpx;
  margin-bottom: 6rpx;
  background: rgba(139, 111, 71, 0.25);
  border-radius: 1rpx;
}

.stat-view-all {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stat-view-all text {
  font-size: 24rpx;
  color: #b63b36;
  font-weight: 500;
}

.stat-view-all:active {
  opacity: 0.6;
}

/* ─── 文化名片 ─── */
.quote-zone {
  margin-top: 14rpx;
  min-height: 84rpx;
  opacity: 0;
  transition: opacity 0.35s ease;
  display: flex;
  align-items: flex-start;
  gap: 4rpx;
}

.quote-zone.quote-visible {
  opacity: 1;
}

.quote-icon {
  font-size: 32rpx;
  color: #c4a882;
  line-height: 1;
  margin-top: -4rpx;
  flex-shrink: 0;
  font-family: Georgia, serif;
}

.quote-text {
  font-size: 24rpx;
  color: #8b7d6b;
  font-style: italic;
  line-height: 1.7;
  letter-spacing: 1rpx;
  flex: 1;
}

/* ─── 快捷导航 ─── */
.quick-nav-row {
  display: flex;
  gap: 20rpx;
  padding: 0 40rpx 36rpx;
  flex-shrink: 0;
}

.nav-capsule {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.nav-capsule:active {
  transform: scale(0.95);
  opacity: 0.85;
}

.nav-capsule--primary {
  background: linear-gradient(135deg, #d4534a 0%, #b63b36 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(182, 59, 54, 0.38);
}

.nav-capsule--secondary {
  background: rgba(255, 255, 255, 0.7);
  color: #8b6f47;
  border: 1.5rpx solid rgba(139, 111, 71, 0.35);
  backdrop-filter: blur(8px);
}

/* ═══════════ 遮罩 ═══════════ */
.backdrop {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 999;
  transition: opacity 0.35s ease;
}

/* ═══════════ 底部资讯面板 ═══════════ */
.bottom-sheet {
  position: fixed;
  left: 0; right: 0;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  box-shadow: 0 -10rpx 30rpx rgba(0, 0, 0, 0.1);
  z-index: 1000;
  will-change: transform;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.sheet-header {
  flex-shrink: 0;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  position: relative;
  z-index: 2;
}

/* 上划引导箭头区域 */
.swipe-hint-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 0 10rpx;
}

/* 双线条对称 V 形箭头（默认朝上，展开后朝下，过渡经过水平横杠态） */
.swipe-up-chevron {
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.chevron-line {
  width: 26rpx;
  height: 6rpx;
  background: #bfb5a2;
  border-radius: 3rpx;
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.chevron-left {
  transform-origin: right center;
  transform: rotate(-18deg);
}

.chevron-right {
  transform-origin: left center;
  transform: rotate(18deg);
}

.chevron-expanded .chevron-left {
  transform: rotate(18deg);
}

.chevron-expanded .chevron-right {
  transform: rotate(-18deg);
}

.news-tab-bar {
  display: flex;
  padding: 0 40rpx;
  border-bottom: 1.5rpx solid #f0ebe3;
  gap: 8rpx;
}

.news-tab {
  position: relative;
  padding: 12rpx 24rpx 20rpx;
  font-size: 28rpx;
  color: #9a8878;
  font-weight: 400;
  transition: color 0.2s ease;
}

.news-tab--active {
  color: #2c1a0e;
  font-weight: 600;
}

.tab-underline {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 44rpx;
  height: 5rpx;
  border-radius: 2.5rpx;
  background: #b63b36;
}

.news-scroll {
  flex: 1;
  overflow: hidden;
  background: #faf8f4;
}

.news-loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  gap: 20rpx;
}

.news-loading-text {
  font-size: 24rpx;
  color: #9a8878;
}

.news-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 28rpx 40rpx;
  background: #ffffff;
  border-bottom: 1.5rpx solid #f5f0e8;
  transition: background 0.15s ease;
}

.news-item:active {
  background: #fdf8f0;
}

.news-item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.news-title {
  font-size: 28rpx;
  color: #2c1a0e;
  line-height: 1.65;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.news-meta {
  font-size: 22rpx;
  color: #b0a090;
}

.news-meta--source {
  color: #c4a882;
}

.news-thumb {
  width: 168rpx;
  height: 120rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: #f0ebe3;
  object-fit: cover;
}

.list-bottom-safe {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
