.review-detail-page {
  min-height: 100vh;
  background: #f6f0e8;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.page-body {
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.product-card,
.section-card,
.readonly-tip {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.product-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
}

.product-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background: #f5f0e8;
  flex-shrink: 0;
}

.product-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.product-title {
  font-size: 30rpx;
  line-height: 1.5;
  color: #2f241e;
  font-weight: 700;
}

.product-sku,
.product-meta {
  font-size: 24rpx;
  color: #8b7b6f;
}

.section-card {
  margin-top: 20rpx;
  padding: 24rpx;
}

.score-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.user-box {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ead9c9;
}

.user-meta {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.name {
  font-size: 28rpx;
  color: #2f241e;
  font-weight: 600;
}

.time {
  font-size: 22rpx;
  color: #9b8a7d;
}

.score-box {
  flex-shrink: 0;
  text-align: right;
}

.score-number {
  display: block;
  font-size: 44rpx;
  color: #b63b36;
  font-weight: 800;
}

.score-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9b8a7d;
}

.rating-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.rating-item {
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  background: #faf7f3;
  text-align: center;
}

.rating-name {
  display: block;
  font-size: 22rpx;
  color: #8b7b6f;
}

.rating-value {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  color: #2f241e;
  font-weight: 700;
}

.section-title {
  font-size: 30rpx;
  color: #2f241e;
  font-weight: 700;
}

.review-content,
.reply-content {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #4f4036;
}

.image-grid {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.review-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 18rpx;
  background: #eee4d9;
}

.reply-card {
  background: #fff6f1;
}

.reply-time {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9b8a7d;
}

.readonly-tip {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #8b6f47;
}
