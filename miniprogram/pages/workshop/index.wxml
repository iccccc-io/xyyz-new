<!--pages/workshop/index.wxml-->
<view class="workshop-container">
  <!-- 导航栏 -->
  <nav-bar
    title="非遗工坊"
    showTitle="{{true}}"
    showBack="{{true}}"
    background="solid"
    dark="{{true}}"
    placeholder="{{true}}"
  />

  <view wx:if="{{!loading && workshopInfo}}">
    <!-- 工坊头部信息 -->
    <view class="workshop-header">
      <image class="workshop-bg" src="{{workshopInfo.logo || '/images/default-goods-image.png'}}" mode="aspectFill" />
      <view class="workshop-info">
        <view class="info-top">
          <image class="workshop-logo" src="{{workshopInfo.logo || '/images/default-goods-image.png'}}" mode="aspectFill" />
          <view class="info-content">
            <view class="workshop-name">{{workshopInfo.name}}</view>
            <view class="workshop-category">
              <van-tag type="danger" size="medium">{{workshopInfo.ich_category}}</van-tag>
              <van-tag plain type="primary" size="medium" wx:if="{{isOwner}}">主理人</van-tag>
            </view>
          </view>
        </view>
        
        <!-- 工坊统计 -->
        <view class="workshop-stats">
          <view class="stat-item">
            <text class="stat-num">{{workshopInfo.product_count || 0}}</text>
            <text class="stat-label">商品</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-num">{{workshopInfo.total_sales || 0}}</text>
            <text class="stat-label">销量</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-num">{{workshopInfo.rating || '5.0'}}</text>
            <text class="stat-label">评分</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 工坊简介 -->
    <view class="section-card">
      <view class="section-title">
        <view class="title-line"></view>
        <text>工坊简介</text>
      </view>
      <text class="workshop-desc">{{workshopInfo.desc || '暂无简介'}}</text>
    </view>

    <!-- 操作按钮区 -->
    <view class="action-bar" wx:if="{{isOwner}}">
      <van-button 
        icon="plus" 
        type="primary" 
        round
        block
        bind:click="navigateToPublish"
        color="#b63b36"
      >
        发布商品
      </van-button>
    </view>

    <!-- 商品列表 -->
    <view class="section-card">
      <view class="section-title">
        <view class="title-line"></view>
        <text>工坊商品</text>
        <text class="title-count">({{products.length}})</text>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{products.length === 0}}">
        <van-empty description="暂无商品" />
        <view class="empty-tip" wx:if="{{isOwner}}">
          <text>快去发布您的第一件非遗作品吧！</text>
        </view>
      </view>

      <!-- 商品列表 -->
      <view class="product-grid" wx:else>
        <view 
          class="product-item" 
          wx:for="{{products}}" 
          wx:key="_id"
          bindtap="navigateToProductDetail"
          data-id="{{item._id}}"
        >
          <image class="product-image" src="{{item.cover_img}}" mode="aspectFill" />
          <!-- 主理人可见：状态徽标 -->
          <view class="status-badge status-on" wx:if="{{isOwner && item.status === 1}}">上架</view>
          <view class="status-badge status-off" wx:if="{{isOwner && item.status !== 1}}">下架</view>
          <view class="product-info">
            <text class="product-name">{{item.title}}</text>
            <view class="product-footer">
              <text class="product-price">¥{{item.priceDisplay}}</text>
              <text class="product-sales">已售{{item.sales || 0}}</text>
            </view>
            <!-- 库存提示（仅主理人可见） -->
            <view class="stock-tip" wx:if="{{isOwner && item.stock <= 5}}">
              <text class="stock-warn">库存仅剩 {{item.stock}} 件</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-wrapper" wx:if="{{loading}}">
    <van-loading size="24px" vertical>加载中...</van-loading>
  </view>

  <!-- 错误状态 -->
  <view class="error-wrapper" wx:if="{{!loading && !workshopInfo}}">
    <van-empty description="工坊不存在或已被删除" />
    <van-button 
      round 
      type="primary" 
      size="small"
      bind:click="goBack"
      color="#b63b36"
    >
      返回
    </van-button>
  </view>
</view>

