.finance-page {
  min-height: 100vh;
  background: #f6f0e8;
}

.loading-wrap,
.empty-wrap {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.finance-scroll {
  height: calc(100vh - 88rpx);
}

.hero-card {
  margin: 24rpx 28rpx 20rpx;
  padding: 34rpx 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #6b1f1c 0%, #8b2e2a 55%, #b63b36 100%);
  box-shadow: 0 18rpx 44rpx rgba(139, 46, 42, 0.26);
}

.hero-copy {
  margin-bottom: 24rpx;
}

.hero-eyebrow {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 8rpx;
}

.hero-title {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.86);
}

.hero-balance-row {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  margin-top: 18rpx;
}

.hero-balance-symbol {
  color: #fff;
  font-size: 36rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.hero-balance-value {
  color: #fff;
  font-size: 78rpx;
  line-height: 1;
  font-weight: 700;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.hero-stat {
  padding: 18rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.12);
  border: 2rpx solid rgba(255,255,255,0.12);
}

.hero-stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.66);
  margin-bottom: 10rpx;
}

.hero-stat-value {
  display: block;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.panel-card {
  margin: 0 28rpx 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.94);
  box-shadow: 0 10rpx 30rpx rgba(111, 83, 48, 0.08);
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.section-copy {
  flex: 1;
}

.section-title {
  display: block;
  font-size: 32rpx;
  color: #2f2823;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.section-desc {
  display: block;
  font-size: 24rpx;
  color: #8b7b69;
  line-height: 1.7;
}

.section-link {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f9f2eb;
  border: 2rpx solid #eadbcf;
  color: #8b6f47;
  font-size: 24rpx;
  white-space: nowrap;
}

.withdraw-main {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.withdraw-input-shell {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 96rpx;
  padding: 0 26rpx;
  border-radius: 24rpx;
  background: #fbf7f2;
  border: 2rpx solid #eee2d6;
}

.withdraw-prefix {
  font-size: 36rpx;
  color: #8b2e2a;
  font-weight: 700;
}

.withdraw-input {
  flex: 1;
  font-size: 34rpx;
  color: #2f2823;
}

.withdraw-tips {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.withdraw-tips text {
  font-size: 24rpx;
  color: #8b7b69;
}

.line-btn {
  min-height: 84rpx;
  border-radius: 999rpx;
  border: 2rpx solid #d6c0af;
  background: linear-gradient(180deg, #fffdfa 0%, #f8efe6 100%);
  color: #8b2e2a;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.line-btn-primary {
  border-color: #b63b36;
  box-shadow: 0 10rpx 24rpx rgba(182, 59, 54, 0.12);
}

.line-btn-small {
  min-height: 66rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
  width: fit-content;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #5c5046;
  font-weight: 600;
}

.picker-row,
.form-input {
  min-height: 88rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: #fbf7f2;
  border: 2rpx solid #eee2d6;
  font-size: 28rpx;
  color: #2f2823;
  display: flex;
  align-items: center;
}

.picker-row {
  justify-content: space-between;
}

.picker-value {
  color: #2f2823;
}

.ledger-list,
.withdraw-records {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.ledger-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1e7dc;
}

.ledger-main {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.ledger-badge {
  flex-shrink: 0;
  min-width: 92rpx;
  height: 56rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
}

.badge-in {
  background: rgba(16,185,129,0.12);
  color: #0f9c6b;
}

.badge-out {
  background: rgba(182,59,54,0.1);
  color: #b63b36;
}

.badge-neutral {
  background: rgba(139,111,71,0.1);
  color: #8b6f47;
}

.ledger-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.ledger-desc {
  font-size: 28rpx;
  color: #2f2823;
  line-height: 1.5;
}

.ledger-time {
  font-size: 22rpx;
  color: #a19181;
}

.ledger-amount {
  flex-shrink: 0;
  font-size: 30rpx;
  font-weight: 700;
}

.amount-in {
  color: #0f9c6b;
}

.amount-out {
  color: #b63b36;
}

.amount-neutral {
  color: #2f2823;
}

.withdraw-record {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f1e7dc;
}

.withdraw-record-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.withdraw-record-amount {
  font-size: 34rpx;
  color: #2f2823;
  font-weight: 700;
}

.withdraw-record-status {
  font-size: 24rpx;
  font-weight: 600;
}

.status-pending {
  color: #8b6f47;
}

.status-success {
  color: #0f9c6b;
}

.status-rejected {
  color: #b63b36;
}

.withdraw-record-line {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8b7b69;
  line-height: 1.6;
}

.record-actions {
  margin-top: 18rpx;
}

.more-btn {
  min-height: 76rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  border: 2rpx solid #e6d7cb;
  background: #fcf8f3;
  font-size: 26rpx;
  color: #8b6f47;
  display: flex;
  align-items: center;
  justify-content: center;
}
