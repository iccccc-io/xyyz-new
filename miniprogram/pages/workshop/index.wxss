.workshop-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.workshop-header {
  position: relative;
  background-color: #fff;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.workshop-bg {
  width: 100%;
  height: 260rpx;
  filter: blur(20rpx);
  opacity: 0.3;
}

.workshop-info {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx 30rpx;
}

.info-top {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.workshop-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.info-content {
  flex: 1;
  margin-left: 24rpx;
}

.workshop-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.workshop-category {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.workshop-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: linear-gradient(135deg, #fff 0%, #f7f8fa 100%);
  border-radius: 16rpx;
  padding: 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 180rpx;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #b63b36;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.stat-divider {
  width: 2rpx;
  height: 40rpx;
  background-color: #e5e5e5;
}

.section-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.title-line {
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #b63b36 0%, #ff6b6b 100%);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.title-count {
  font-size: 28rpx;
  color: #999;
  font-weight: 400;
  margin-left: 8rpx;
}

.workshop-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
  word-break: break-all;
  white-space: pre-wrap;
}

.action-bar {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.product-item {
  position: relative;
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.product-item:active {
  transform: scale(0.98);
}

.product-image {
  width: 100%;
  height: 300rpx;
  background-color: #f5f5f5;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.5;
  min-height: 84rpx;
}

.product-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.product-sales {
  font-size: 24rpx;
  color: #999;
}

.status-badge {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  z-index: 2;
}

.status-on {
  background: rgba(22, 163, 74, 0.85);
  color: #fff;
}

.status-off {
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
}

.stock-tip {
  margin-top: 6rpx;
}

.stock-warn {
  font-size: 22rpx;
  color: #f59e0b;
}

.review-loading {
  padding: 40rpx 0;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.review-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #faf7f3;
}

.review-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.review-user {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.review-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #ead9c9;
  flex-shrink: 0;
}

.review-meta {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.review-name {
  font-size: 26rpx;
  color: #2f241e;
  font-weight: 600;
}

.review-time {
  font-size: 22rpx;
  color: #9a8b80;
}

.review-score {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #b63b36;
  font-weight: 700;
}

.review-product-title {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #2f241e;
  font-weight: 600;
}

.review-content {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #4f4036;
  line-height: 1.8;
}

.review-images {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.review-image {
  width: 148rpx;
  height: 148rpx;
  border-radius: 16rpx;
  background: #eee4d9;
}

.seller-reply {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #fff1eb;
}

.seller-reply-title {
  display: block;
  font-size: 24rpx;
  color: #b63b36;
  font-weight: 700;
}

.seller-reply-content {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6b5247;
}

.seller-reply-time {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #a18d82;
}

.review-action-row {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
}

.reply-btn {
  min-width: 160rpx;
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #b63b36;
  color: #fff;
  font-size: 24rpx;
  line-height: 60rpx;
  text-align: center;
}

.review-more {
  margin-top: 12rpx;
  padding: 20rpx 0 6rpx;
  text-align: center;
  font-size: 24rpx;
  color: #8b6f47;
}

.empty-state {
  padding: 80rpx 0;
  text-align: center;
}

.empty-tip {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}

.loading-wrapper,
.error-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  gap: 40rpx;
}

.reply-popup {
  background: #fff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
}

.reply-popup-title {
  text-align: center;
  font-size: 30rpx;
  color: #2f241e;
  font-weight: 700;
}

.reply-textarea {
  width: 100%;
  min-height: 220rpx;
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #faf7f3;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #2f241e;
  line-height: 1.7;
}

.reply-popup-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.reply-popup-btn {
  flex: 1;
  height: 82rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 82rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.reply-popup-btn.cancel {
  background: #f0ebe6;
  color: #8d7d70;
}

.reply-popup-btn.confirm {
  background: #b63b36;
  color: #fff;
}
