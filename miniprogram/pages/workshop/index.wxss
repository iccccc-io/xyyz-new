/* pages/workshop/index.wxss */
.workshop-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 工坊头部 */
.workshop-header {
  position: relative;
  background-color: #fff;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.workshop-bg {
  width: 100%;
  height: 260rpx;
  filter: blur(20rpx);
  opacity: 0.3;
}

.workshop-info {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx 30rpx;
}

.info-top {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.workshop-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.info-content {
  flex: 1;
  margin-left: 24rpx;
}

.workshop-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.workshop-category {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 统计数据 */
.workshop-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: linear-gradient(135deg, #fff 0%, #f7f8fa 100%);
  border-radius: 16rpx;
  padding: 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #b63b36;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.stat-divider {
  width: 2rpx;
  height: 40rpx;
  background-color: #e5e5e5;
}

/* 区块卡片 */
.section-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.title-line {
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #b63b36 0%, #ff6b6b 100%);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.title-count {
  font-size: 28rpx;
  color: #999;
  font-weight: 400;
  margin-left: 8rpx;
}

.workshop-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
  word-break: break-all;
  white-space: pre-wrap;
}

/* 操作按钮区 */
.action-bar {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

/* 商品网格 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.product-item {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.product-item:active {
  transform: scale(0.98);
}

.product-image {
  width: 100%;
  height: 300rpx;
  background-color: #f5f5f5;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.5;
  min-height: 84rpx;
}

.product-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.product-sales {
  font-size: 24rpx;
  color: #999;
}

/* 状态徽标（主理人视角） */
.product-item {
  position: relative;
}

.status-badge {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  z-index: 2;
}

.status-on {
  background: rgba(22, 163, 74, 0.85);
  color: #fff;
}

.status-off {
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
}

/* 库存预警 */
.stock-tip {
  margin-top: 6rpx;
}

.stock-warn {
  font-size: 22rpx;
  color: #f59e0b;
}

/* 空状态 */
.empty-state {
  padding: 80rpx 0;
  text-align: center;
}

.empty-tip {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}

/* 加载/错误状态 */
.loading-wrapper,
.error-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  gap: 40rpx;
}

