<!-- pages/community/user-profile.wxml -->
<!-- 深色头图 + 白色内容面板 -->

<view class="profile-page">
  <view class="custom-nav {{navSolid ? 'is-solid' : ''}}" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-back" bindtap="goBack">
        <van-icon name="arrow-left" size="20px" color="{{navSolid ? '#18191c' : '#ffffff'}}" />
      </view>
      <text class="nav-title {{navSolid ? 'is-show' : ''}}">{{userInfo.nickname || '用户主页'}}</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <view class="page-loading" wx:if="{{pageLoading}}">
    <van-loading size="28px" color="#ff5f73" vertical>加载主页中...</van-loading>
  </view>

  <view class="page-error" wx:elif="{{pageError}}">
    <view class="error-illustration"></view>
    <text class="error-title">主页暂时打不开</text>
    <text class="error-desc">{{errorText || '请稍后再试。'}}</text>
    <view class="error-btn" bindtap="goBack">返回上一页</view>
  </view>

  <block wx:else>
    <view class="hero-section">
      <image class="hero-cover" src="{{coverImage}}" mode="aspectFill" />
      <view class="hero-overlay"></view>
      <view class="hero-grid"></view>

      <view class="hero-body" style="padding-top: {{statusBarHeight + 56}}px;">
        <view class="hero-stack">
          <view class="identity-row">
            <view class="avatar-wrap">
              <image class="user-avatar" src="{{userInfo.avatar_url}}" mode="aspectFill" />
              <view class="avatar-mark" wx:if="{{userInfo.is_certified}}">
                <text>传</text>
              </view>
            </view>

            <view class="identity-main">
              <view class="name-row">
                <text class="user-name">{{userInfo.nickname || '用户'}}</text>
                <view class="name-badge" wx:if="{{userInfo.is_certified}}">
                  <text>认证</text>
                </view>
              </view>
              <text class="profile-id">湘韵遗珍号：{{profileIdText || '未设置'}}</text>
              <text class="profile-role">{{roleText}}</text>
            </view>

            <view class="follow-side-btn {{isFollowing ? 'is-following' : ''}}" wx:if="{{!isSelf}}" bindtap="toggleFollow">
              <text>{{isMutual ? '互相关注' : (isFollowing ? '已关注' : '关注')}}</text>
            </view>
          </view>

          <view class="stats-row">
            <view class="stat-item" bindtap="goToFollowing">
              <text class="stat-value">{{followingText}}</text>
              <text class="stat-label">关注</text>
            </view>
            <view class="stat-item" bindtap="goToFollowers">
              <text class="stat-value">{{followersText}}</text>
              <text class="stat-label">粉丝</text>
            </view>
            <view class="stat-item">
              <text class="stat-value">{{appreciationText}}</text>
              <text class="stat-label">获赞与收藏</text>
            </view>
          </view>

          <text class="bio-text">{{bioText}}</text>

          <view class="meta-row" wx:if="{{userInfo.ich_category || userInfo.is_certified || showWorkshopEntry}}">
            <text class="meta-chip" wx:if="{{userInfo.ich_category}}">{{userInfo.ich_category}}</text>
            <text class="meta-chip" wx:if="{{userInfo.is_certified}}">非遗传承人</text>
            <text class="meta-chip" wx:if="{{showWorkshopEntry}}">已开设工坊</text>
          </view>

          <view class="feature-row hero-action-row" wx:if="{{!isSelf && showWorkshopEntry}}">
            <view class="feature-card" bindtap="goToWorkshop">
              <text class="feature-title">工坊</text>
              <text class="feature-desc">{{workshopInfo && workshopInfo.name ? workshopInfo.name : '查看匠心小店'}}</text>
            </view>
            <view class="feature-card" bindtap="goToChat">
              <text class="feature-title">私信</text>
              <text class="feature-desc">和 Ta 开启即时交流</text>
            </view>
          </view>

          <view class="feature-row hero-action-row" wx:if="{{!isSelf && !showWorkshopEntry}}">
            <view class="feature-card is-wide" bindtap="goToChat">
              <text class="feature-title">私信</text>
              <text class="feature-desc">和 Ta 开启即时交流</text>
            </view>
          </view>

          <view class="feature-row hero-action-row self-action-row {{showWorkshopEntry ? 'is-triple' : ''}}" wx:if="{{isSelf}}">
            <view class="feature-card" wx:if="{{showWorkshopEntry}}" bindtap="goToWorkshop">
              <text class="feature-title">我的工坊</text>
              <text class="feature-desc">{{workshopInfo && workshopInfo.name ? workshopInfo.name : '查看工坊'}}</text>
            </view>
            <view class="feature-card" bindtap="goToEditProfile">
              <text class="feature-title">编辑资料</text>
              <text class="feature-desc">编辑头像、简介与背景图</text>
            </view>
            <view class="feature-card" bindtap="goToPost">
              <text class="feature-title">发笔记</text>
              <text class="feature-desc">记录新的非遗灵感与见闻</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="content-shell">
      <view class="tabs-bar">
        <view class="tab-active">
          <text class="tab-text">笔记</text>
          <view class="tab-ink"></view>
        </view>
        <text class="tab-count">{{posts.length}}</text>
      </view>

      <view class="loading-state" wx:if="{{postsLoading}}">
        <van-loading size="24px" color="#ff5f73">加载中...</van-loading>
      </view>

      <block wx:elif="{{posts.length > 0}}">
        <view class="grid-wrap">
          <view class="grid-column">
            <view class="content-card" wx:for="{{leftPosts}}" wx:key="_id" bindtap="goToPostDetail" data-id="{{item._id}}">
              <view class="card-cover {{!item.coverImage ? 'is-placeholder' : ''}}">
                <image wx:if="{{item.coverImage}}" class="cover-image" src="{{item.coverImage}}" mode="aspectFill" lazy-load />
                <view class="placeholder-panel" wx:else>
                  <text class="placeholder-tag">{{item.projectTag || '湘韵遗珍'}}</text>
                  <text class="placeholder-title">{{item.title}}</text>
                </view>
                <view class="image-count" wx:if="{{item.imageCount > 1}}">
                  <van-icon name="photo-o" size="12px" color="#ffffff" />
                  <text class="count-text">{{item.imageCount}}</text>
                </view>
              </view>

              <view class="card-body">
                <view class="card-title-row">
                  <text class="project-tag" wx:if="{{item.projectTag}}">{{item.projectTag}}</text>
                  <text class="card-title">{{item.title}}</text>
                </view>

                <text class="card-excerpt" wx:if="{{item.excerpt}}">{{item.excerpt}}</text>

                <view class="card-footer">
                  <text class="card-time">{{item.timeText}}</text>
                  <view class="like-info">
                    <van-icon name="like-o" size="14px" color="#a8adb4" />
                    <text class="like-count">{{item.likesText}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>

          <view class="grid-column">
            <view class="content-card" wx:for="{{rightPosts}}" wx:key="_id" bindtap="goToPostDetail" data-id="{{item._id}}">
              <view class="card-cover {{!item.coverImage ? 'is-placeholder' : ''}}">
                <image wx:if="{{item.coverImage}}" class="cover-image" src="{{item.coverImage}}" mode="aspectFill" lazy-load />
                <view class="placeholder-panel" wx:else>
                  <text class="placeholder-tag">{{item.projectTag || '湘韵遗珍'}}</text>
                  <text class="placeholder-title">{{item.title}}</text>
                </view>
                <view class="image-count" wx:if="{{item.imageCount > 1}}">
                  <van-icon name="photo-o" size="12px" color="#ffffff" />
                  <text class="count-text">{{item.imageCount}}</text>
                </view>
              </view>

              <view class="card-body">
                <view class="card-title-row">
                  <text class="project-tag" wx:if="{{item.projectTag}}">{{item.projectTag}}</text>
                  <text class="card-title">{{item.title}}</text>
                </view>

                <text class="card-excerpt" wx:if="{{item.excerpt}}">{{item.excerpt}}</text>

                <view class="card-footer">
                  <text class="card-time">{{item.timeText}}</text>
                  <view class="like-info">
                    <van-icon name="like-o" size="14px" color="#a8adb4" />
                    <text class="like-count">{{item.likesText}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>

      <view class="empty-panel" wx:else>
        <view class="empty-icon-wrap">
          <view class="empty-icon"></view>
        </view>
        <text class="empty-title">{{isSelf ? '还没有发布笔记' : 'Ta 还在闭关创作中...'}}</text>
        <text class="empty-desc">{{isSelf ? '去写下第一篇内容，个人主页就会慢慢热闹起来。' : '等下一次分享时，再来看看他的非遗灵感。'}}</text>
        <view class="empty-action" wx:if="{{isSelf}}" bindtap="goToPost">
          <text>去发第一篇</text>
        </view>
      </view>
    </view>

    <view class="safe-area-bottom"></view>
  </block>
</view>
