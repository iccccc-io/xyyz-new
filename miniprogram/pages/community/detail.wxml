<!--pages/community/detail.wxml-->
<!-- 沉浸式帖子详情页 -->

<!-- 自定义导航栏 -->
<nav-bar 
  title="{{postData.title || '帖子详情'}}"
  showTitle="{{navShowTitle}}"
  showBack="{{true}}"
  background="{{navBackground}}"
  dark="{{navDark}}"
  placeholder="{{false}}"
  customStyle="{{navCustomStyle}}"
/>

<scroll-view 
  class="detail-scroll"
  scroll-y="{{true}}"
  enhanced="{{true}}"
  show-scrollbar="{{false}}"
  bindscroll="onPageScroll"
>
  <view class="detail-container">
    <block wx:if="{{postData}}">
      <!-- 图片展示区域（铺满至屏幕顶端） -->
      <view class="images-wrapper" wx:if="{{postData.images && postData.images.length > 0}}">
        <!-- 单图展示 -->
        <view wx:if="{{postData.images.length === 1}}" class="single-image-wrapper">
          <image 
            class="single-image" 
            src="{{postData.images[0]}}" 
            mode="widthFix"
            bindtap="previewImage"
            data-url="{{postData.images[0]}}"
          />
        </view>
        
        <!-- 多图轮播 -->
        <swiper 
          wx:if="{{postData.images.length > 1}}"
          class="image-swiper"
          style="height: {{swiperHeight}}px;"
          indicator-dots
          indicator-color="rgba(255, 255, 255, 0.5)"
          indicator-active-color="#ffffff"
          circular
          current="{{currentImageIndex}}"
          bindchange="onSwiperChange"
        >
          <swiper-item wx:for="{{postData.images}}" wx:key="index">
            <view class="swiper-item-wrapper">
              <image 
                class="swiper-image" 
                src="{{item}}" 
                mode="widthFix"
                bindtap="previewImage"
                data-url="{{item}}"
                bindload="onImageLoad"
                data-index="{{index}}"
              />
            </view>
          </swiper-item>
        </swiper>
        
        <!-- 图片计数 -->
        <view class="image-indicator" wx:if="{{postData.images.length > 1}}">
          <text>{{currentImageIndex + 1}} / {{postData.images.length}}</text>
        </view>
      </view>

      <!-- 无图片时的占位 -->
      <view class="no-image-placeholder" wx:if="{{!postData.images || postData.images.length === 0}}" style="height: {{statusBarHeight + 60}}px;"></view>

      <!-- 白色内容区域（大圆角衔接） -->
      <view class="content-card">
        <!-- 作者栏 -->
        <view class="author-bar">
          <view class="author-left" bindtap="goToUserProfile" data-userid="{{postData.author_id || postData._openid}}">
            <image class="author-avatar" src="{{postData.author_info.avatar_file_id}}" />
            <view class="author-text">
              <text class="author-name {{postData.author_info.is_certified ? 'certified' : ''}}">{{postData.author_info.nickname}}</text>
              <text class="author-title loading" wx:if="{{postData.author_info.is_certified && !authorDataLoaded}}">· · ·</text>
              <text class="author-title" wx:elif="{{postData.author_info.is_certified}}">{{authorData.certified_title || '非遗传承人'}}</text>
              <text class="author-title" wx:else>非遗爱好者</text>
            </view>
          </view>
          <!-- 右侧按钮组 -->
          <view class="author-actions">
            <view 
              class="chat-btn" 
              wx:if="{{!isSelf && followStatusLoaded}}"
              bindtap="goToChat"
            >
              <van-icon name="chat-o" size="16px" color="#b63b36" />
            </view>
            <view 
              class="follow-btn loading" 
              wx:if="{{!isSelf && !followStatusLoaded}}"
            >
              <text>· · ·</text>
            </view>
            <view 
              class="follow-btn {{isFollowing ? 'following' : ''}}" 
              wx:if="{{!isSelf && followStatusLoaded}}"
              bindtap="onFollowTap"
            >
              <text wx:if="{{!isFollowing}}">+ 关注</text>
              <text wx:elif="{{isMutual}}">互相关注</text>
              <text wx:else>已关注</text>
            </view>
          </view>
        </view>

        <!-- 内容区域 -->
        <view class="content-section">
          <view class="post-title">{{postData.title}}</view>
          <view class="post-content">{{postData.content}}</view>

          <!-- 非遗标签 -->
          <view class="project-tags" wx:if="{{postData.related_projects && postData.related_projects.length > 0}}">
            <view 
              class="project-tag-item"
              wx:for="{{postData.related_projects}}"
              wx:key="id"
              bindtap="goToProject"
              data-id="{{item.id}}"
            >
              <text class="tag-icon">🏷️</text>
              <text class="tag-name">{{item.name}}</text>
            </view>
          </view>

          <!-- 普通标签 -->
          <view class="normal-tags" wx:if="{{postData.tags && postData.tags.length > 0}}">
            <view 
              class="normal-tag" 
              wx:for="{{postData.tags}}" 
              wx:key="index"
              bindtap="goToTopic"
              data-tag="{{item}}"
            >#{{item}}</view>
          </view>

          <!-- 位置和时间信息 -->
          <view class="meta-info">
            <view class="location-info" wx:if="{{postData.location && postData.location.name}}" bindtap="openLocation">
              <van-icon name="location-o" size="14" color="#999" />
              <text class="location-text">{{postData.location.name}}</text>
            </view>
            <view class="time-info">
              <text class="time-text">{{formatTime}}</text>
            </view>
          </view>

          <!-- 编辑记录 -->
          <view class="edit-record" wx:if="{{postData.is_edited}}">
            <van-icon name="edit" size="14" color="#b8860b" />
            <text class="edit-record-text">内容已于 {{lastEditTimeFormatted}} 再次编辑</text>
          </view>
        </view>

        <!-- 分隔线 -->
        <view class="divider-line"></view>

        <!-- 评论区 -->
        <view class="comment-section" wx:if="{{postData.comment_status !== false}}">
          <view class="comment-header">
            <text class="comment-title">共 {{commentCount}} 条评论</text>
          </view>

          <view class="comments-loading" wx:if="{{commentsLoading}}">
            <van-loading type="spinner" color="#b63b36" size="24">加载评论中...</van-loading>
          </view>

          <view class="comment-list" wx:if="{{!commentsLoading && commentList.length > 0}}">
            <view class="comment-item-wrapper" wx:for="{{commentList}}" wx:key="_id" wx:for-index="commentIndex">
              <view class="comment-item level-1">
                <image class="comment-avatar" src="{{item.user_info.avatar || '/images/icons/avatar.png'}}" />
                <view class="comment-main">
                  <view class="comment-user-row">
                    <text class="comment-user">{{item.user_info.nickname}}</text>
                  </view>
                  <view class="comment-text" bindtap="onCommentTap" data-comment="{{item}}">{{item.content}}</view>
                  <view class="comment-footer">
                    <text class="comment-time">{{item.create_time_formatted}}</text>
                    <view class="comment-actions">
                      <view class="comment-reply-btn" bindtap="onCommentTap" data-comment="{{item}}">
                        <text>回复</text>
                      </view>
                      <view 
                        class="comment-like-btn {{item.isLiked ? 'liked' : ''}}" 
                        bindtap="onCommentLikeTap" 
                        data-commentid="{{item._id}}" 
                        data-index="{{commentIndex}}"
                      >
                        <van-icon name="{{item.isLiked ? 'like' : 'like-o'}}" size="14" color="{{item.isLiked ? '#b63b36' : '#999'}}" />
                        <text wx:if="{{item.like_count > 0}}">{{item.like_count}}</text>
                      </view>
                      <view 
                        class="comment-delete-btn" 
                        wx:if="{{item.from_uid === currentOpenid}}"
                        bindtap="onDeleteComment" 
                        data-commentid="{{item._id}}" 
                        data-index="{{commentIndex}}"
                      >
                        <text>删除</text>
                      </view>
                    </view>
                  </view>

                  <!-- 二级评论区 -->
                  <view class="replies-section" wx:if="{{item.reply_count > 0}}">
                    <view class="reply-item {{reply.status === 'deleted' ? 'deleted' : ''}}" wx:for="{{item.replies}}" wx:key="_id" wx:for-item="reply">
                      <image class="reply-avatar" src="{{reply.user_info.avatar || '/images/icons/avatar.png'}}" />
                      <view class="reply-main">
                        <view class="reply-content" bindtap="{{reply.status !== 'deleted' ? 'onCommentTap' : ''}}" data-comment="{{reply}}">
                          <text class="reply-user">{{reply.user_info.nickname}}</text>
                          <text class="reply-to" wx:if="{{reply.reply_to && reply.status !== 'deleted'}}"> 回复 <text class="reply-to-name">@{{reply.reply_to.nickname}}</text></text>
                          <text class="reply-text {{reply.status === 'deleted' ? 'deleted-text' : ''}}">：{{reply.content}}</text>
                        </view>
                        <view class="reply-footer">
                          <text class="reply-time">{{reply.create_time_formatted}}</text>
                          <view class="reply-actions">
                            <block wx:if="{{reply.status !== 'deleted'}}">
                              <view class="reply-action" bindtap="onCommentTap" data-comment="{{reply}}">
                                <text>回复</text>
                              </view>
                              <view 
                                class="reply-like-btn {{reply.isLiked ? 'liked' : ''}}" 
                                bindtap="onCommentLikeTap" 
                                data-commentid="{{reply._id}}" 
                                data-index="{{commentIndex}}"
                                data-replyindex="{{index}}"
                              >
                                <van-icon name="{{reply.isLiked ? 'like' : 'like-o'}}" size="12" color="{{reply.isLiked ? '#b63b36' : '#999'}}" />
                                <text wx:if="{{reply.like_count > 0}}">{{reply.like_count}}</text>
                              </view>
                              <view 
                                class="reply-delete-btn" 
                                wx:if="{{reply.from_uid === currentOpenid}}"
                                bindtap="onDeleteComment" 
                                data-commentid="{{reply._id}}" 
                                data-index="{{commentIndex}}"
                                data-replyindex="{{index}}"
                              >
                                <text>删除</text>
                              </view>
                            </block>
                          </view>
                        </view>
                      </view>
                    </view>

                    <view 
                      class="expand-replies" 
                      wx:if="{{item.reply_count > 2 && !item.showAllReplies}}"
                      bindtap="expandReplies"
                      data-commentid="{{item._id}}"
                      data-index="{{commentIndex}}"
                    >
                      <text>展开 {{item.reply_count - 2}} 条回复</text>
                      <van-icon name="arrow-down" size="12" color="#666" />
                    </view>

                    <view 
                      class="collapse-replies" 
                      wx:if="{{item.reply_count > 2 && item.showAllReplies}}"
                      bindtap="collapseReplies"
                      data-index="{{commentIndex}}"
                    >
                      <text>收起</text>
                      <van-icon name="arrow-up" size="12" color="#666" />
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </view>

          <view class="no-comment" wx:if="{{!commentsLoading && commentList.length === 0}}">
            <text class="no-comment-text">暂无评论，快来抢沙发~</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 加载状态 -->
    <view class="loading-wrapper" wx:if="{{loading}}">
      <van-loading type="spinner" color="#b63b36" size="40">加载中...</van-loading>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrapper" wx:if="{{!loading && !postData}}">
      <van-empty description="帖子不存在" />
    </view>
  </view>
</scroll-view>

<!-- 底部互动栏 -->
<view class="action-bar" wx:if="{{postData}}">
  <view class="action-input" wx:if="{{postData.comment_status !== false}}">
    <view class="input-wrapper" bindtap="onInputAreaTap">
      <input 
        class="comment-input" 
        placeholder="{{inputPlaceholder}}"
        value="{{inputValue}}"
        focus="{{inputFocus}}"
        bindinput="onInputChange"
        bindblur="onInputBlur"
        confirm-type="send"
        bindconfirm="sendComment"
        adjust-position="{{true}}"
      />
    </view>
  </view>
  <view class="action-input comment-closed" wx:else>
    <view class="closed-tip">
      <van-icon name="info-o" size="14" color="#999" />
      <text>作者已关闭评论区</text>
    </view>
  </view>

  <view class="action-right">
    <view class="send-btn" wx:if="{{inputValue && postData.comment_status !== false}}" bindtap="sendComment">
      <text>发送</text>
    </view>
    <view class="action-icons" wx:else>
      <view class="action-icon-item {{isLiked ? 'liked' : ''}} {{isSelf ? 'disabled' : ''}}" bindtap="onLikeTap">
        <view class="icon-wrapper">
          <van-icon name="{{isLiked ? 'like' : 'like-o'}}" size="22" color="{{isSelf ? '#ccc' : (isLiked ? '#b63b36' : '#333')}}" />
        </view>
        <text class="action-count {{isLiked ? 'liked' : ''}} {{isSelf ? 'disabled' : ''}}">{{likesFormatted}}</text>
      </view>
      <view class="action-icon-item {{isCollected ? 'collected' : ''}}" wx:if="{{!isSelf}}" bindtap="onCollectionTap">
        <van-icon name="{{isCollected ? 'star' : 'star-o'}}" size="22" color="{{isCollected ? '#FFC83D' : '#333'}}" />
        <text class="action-count {{isCollected ? 'collected' : ''}}">{{collectionFormatted}}</text>
      </view>
      <view class="action-icon-item" wx:if="{{postData.comment_status !== false}}">
        <van-icon name="chat-o" size="22" color="#333" />
        <text class="action-count">{{commentsFormatted}}</text>
      </view>
      <view class="action-icon-item menu-trigger" bindtap="onMenuTap">
        <van-icon name="ellipsis" size="22" color="#333" />
      </view>
    </view>
  </view>
</view>

<!-- 帖子管理菜单组件 -->
<post-menu
  show="{{showPostMenu}}"
  post-id="{{postId}}"
  post-data="{{postData}}"
  is-author="{{isSelf}}"
  bind:close="onMenuClose"
  bind:update="onPostUpdate"
  bind:deleted="onPostDeleted"
/>
