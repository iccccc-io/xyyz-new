page {
  min-height: 100vh;
  background: #0f1012;
}

.profile-page {
  min-height: 100vh;
  color: #ffffff;
  background: #0f1012;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 90;
  transition: background 0.24s ease, box-shadow 0.24s ease;
}

.custom-nav.is-solid {
  background: rgba(17, 18, 22, 0.94);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.16);
}

.nav-inner {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-back,
.nav-placeholder {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nav-back {
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.custom-nav.is-solid .nav-back {
  background: rgba(255, 255, 255, 0.08);
}

.nav-title {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 0 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  opacity: 0;
  transition: opacity 0.24s ease;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-title.is-show {
  opacity: 1;
}

.hero-section {
  position: relative;
  min-height: 760rpx;
  overflow: hidden;
  background: #121316;
  display: flex;
}

.hero-cover {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(7, 8, 11, 0.4) 0%, rgba(10, 11, 14, 0.76) 54%, rgba(15, 16, 18, 0.96) 100%),
    linear-gradient(135deg, rgba(255, 95, 115, 0.08) 0%, rgba(255, 255, 255, 0.02) 100%);
}

.hero-grid {
  position: absolute;
  right: 48rpx;
  top: 210rpx;
  width: 240rpx;
  height: 160rpx;
  background-image: radial-gradient(rgba(255, 255, 255, 0.14) 1px, transparent 1px);
  background-size: 12rpx 12rpx;
  opacity: 0.34;
}

.hero-body {
  position: relative;
  z-index: 2;
  width: 100%;
  min-height: inherit;
  padding: 0 24rpx 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.hero-stack {
  display: flex;
  flex-direction: column;
  width: 100%;
  margin-top: auto;
}

.identity-row {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
}

.avatar-wrap {
  position: relative;
  width: 134rpx;
  height: 134rpx;
  flex-shrink: 0;
}

.user-avatar {
  width: 134rpx;
  height: 134rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.12);
}

.avatar-mark {
  position: absolute;
  right: 2rpx;
  bottom: 4rpx;
  min-width: 38rpx;
  height: 38rpx;
  padding: 0 8rpx;
  border-radius: 20rpx;
  background: #ff5f73;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-mark text {
  font-size: 20rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
}

.identity-main {
  flex: 1;
  min-width: 0;
  padding-top: 8rpx;
}

.follow-side-btn {
  flex-shrink: 0;
  min-width: 150rpx;
  height: 64rpx;
  margin-top: 10rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: #ff5f73;
  box-shadow: 0 12rpx 24rpx rgba(255, 95, 115, 0.2);
}

.follow-side-btn text {
  font-size: 24rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 600;
}

.follow-side-btn.is-following {
  background: rgba(255, 255, 255, 0.12);
  box-shadow: none;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.user-name {
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #ffffff;
}

.name-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  margin-top: 4rpx;
  border-radius: 999rpx;
  background: rgba(255, 95, 115, 0.16);
  border: 1rpx solid rgba(255, 95, 115, 0.36);
}

.name-badge text {
  font-size: 20rpx;
  line-height: 1;
  color: #ff8a98;
  font-weight: 600;
}

.profile-id,
.profile-role {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.58);
}

.profile-id-row {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
  align-self: flex-start;
}

.profile-id-row .profile-id {
  margin-top: 0;
}

.profile-id-copy {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 64rpx;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  font-size: 20rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.76);
  box-sizing: border-box;
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 28rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.stat-value {
  font-size: 46rpx;
  line-height: 1;
  font-weight: 700;
  color: #ffffff;
}

.stat-label {
  font-size: 24rpx;
  line-height: 1.3;
  color: rgba(255, 255, 255, 0.62);
}

.bio-text {
  display: block;
  margin-top: 24rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.9);
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 5;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  font-size: 22rpx;
  line-height: 1.3;
  color: rgba(255, 255, 255, 0.66);
}

.feature-row {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.hero-action-row {
  margin-top: 24rpx;
  padding-top: 0;
}

.self-action-row.is-triple {
  gap: 16rpx;
}

.feature-card {
  flex: 1;
  min-width: 0;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
}

.feature-card.is-wide {
  flex: 1 1 100%;
  width: 100%;
}

.feature-title {
  display: block;
  font-size: 24rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #ffffff;
}

.feature-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 21rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.62);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.self-action-row.is-triple .feature-card {
  padding: 16rpx 14rpx 14rpx;
}

.self-action-row.is-triple .feature-title {
  font-size: 23rpx;
}

.self-action-row.is-triple .feature-desc {
  margin-top: 8rpx;
  font-size: 20rpx;
}

.content-shell {
  position: relative;
  margin-top: -18rpx;
  min-height: 420rpx;
  background: #ffffff;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  overflow: hidden;
}

.tabs-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 22rpx 24rpx 18rpx;
  border-bottom: 1rpx solid #f1f2f3;
}

.tab-active {
  position: relative;
  padding-bottom: 8rpx;
}

.tab-text {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #18191c;
}

.tab-ink {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 48rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #ff5f73;
}

.tab-count {
  font-size: 24rpx;
  color: #9499a0;
}

.content-section,
.grid-wrap {
  width: 100%;
}

.content-shell > .loading-state,
.content-shell > .empty-panel {
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.grid-wrap {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx 96rpx;
  box-sizing: border-box;
}

.grid-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.content-card {
  overflow: hidden;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #eef0f2;
}

.card-cover {
  position: relative;
  height: 236rpx;
  background: #f2f3f5;
  overflow: hidden;
}

.card-cover.is-placeholder {
  height: 236rpx;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.placeholder-panel {
  width: 100%;
  height: 100%;
  padding: 22rpx 18rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: #f7f8fa;
}

.placeholder-tag {
  font-size: 20rpx;
  color: #9499a0;
}

.placeholder-title {
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #18191c;
}

.image-count {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.52);
}

.count-text {
  font-size: 20rpx;
  color: #ffffff;
  line-height: 1;
}

.card-body {
  padding: 16rpx 16rpx 18rpx;
}

.card-title-row {
  line-height: 1.5;
}

.project-tag {
  display: inline;
  margin-right: 8rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  background: #fff1f3;
  font-size: 20rpx;
  color: #ff5f73;
  vertical-align: middle;
}

.card-title {
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 500;
  color: #18191c;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-excerpt {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7d838a;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 14rpx;
}

.card-time,
.like-count {
  font-size: 20rpx;
  color: #a8adb4;
}

.like-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

.empty-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx 140rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f2f3f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #edeef2 0%, #dfe3ea 100%);
}

.empty-title {
  margin-top: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #18191c;
}

.empty-desc {
  margin-top: 12rpx;
  max-width: 520rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.7;
  color: #9499a0;
}

.empty-action {
  margin-top: 28rpx;
  min-width: 220rpx;
  height: 68rpx;
  padding: 0 28rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff5f73;
}

.empty-action text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

.page-loading,
.page-error {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.error-illustration {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.08);
}

.error-title {
  margin-top: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.error-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.62);
  text-align: center;
}

.error-btn {
  margin-top: 28rpx;
  min-width: 220rpx;
  height: 68rpx;
  padding: 0 28rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff5f73;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

.safe-area-bottom {
  height: calc(24rpx + env(safe-area-inset-bottom));
}
