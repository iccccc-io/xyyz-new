/* pages/community/user-profile.wxss */
/* 沉浸式个人主页样式 */

page {
  background-color: #f5f5f5;
}

/* ========== 自定义导航栏 ========== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: transparent;
  transition: background-color 0.3s ease;
}

.custom-nav.solid {
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 50%;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  transition: all 0.3s ease;
}

.nav-back.solid {
  background: transparent;
}

.nav-back:active {
  transform: scale(0.92);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  opacity: 0;
  transition: opacity 0.3s ease;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-title.show {
  opacity: 1;
}

.nav-placeholder {
  width: 64rpx;
}

/* ========== 页面滚动容器 ========== */
.page-scroll {
  background: #f5f5f5;
}

/* ========== 沉浸式头部 ========== */
.hero-header {
  position: relative;
  min-height: 580rpx;
  overflow: hidden;
}

/* 动态模糊背景 */
.backdrop {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
}

.backdrop-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: scale(1.1);
}

/* CSS 高斯模糊层 */
.backdrop-blur {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  backdrop-filter: blur(80px) saturate(180%);
  -webkit-backdrop-filter: blur(80px) saturate(180%);
  background: rgba(0, 0, 0, 0.1);
}

/* 渐变遮罩层 */
.backdrop-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.1) 0%,
    rgba(0, 0, 0, 0.2) 50%,
    rgba(139, 46, 42, 0.35) 100%
  );
}

/* ========== 用户身份信息 ========== */
.identity-section {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 40rpx 32rpx;
}

/* 头像 */
.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  background: #fff;
}

/* 昵称行 */
.user-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.user-nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* 勋章标签 */
.user-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  background: rgba(182, 59, 54, 0.85);
  border-radius: 20rpx;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.user-badge text {
  font-size: 22rpx;
  color: #ffffff;
}

/* 个性签名 */
.user-bio {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 16rpx;
  max-width: 600rpx;
  text-align: center;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.6;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* ========== 社交资产 ========== */
.social-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-top: 32rpx;
}

.stat-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  padding: 0 32rpx;
}

.stat-item:active {
  opacity: 0.7;
}

.stat-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.stat-divider {
  width: 2rpx;
  height: 28rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* ========== 核心交互区 ========== */
.action-bar {
  position: relative;
  z-index: 10;
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 24rpx 40rpx 48rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 72rpx;
  padding: 0 48rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.96);
}

.action-btn text {
  color: #ffffff;
}

/* 关注按钮 - 未关注状态 */
.follow-btn {
  background: linear-gradient(135deg, #d64a45 0%, #b63b36 100%);
  box-shadow: 0 6rpx 20rpx rgba(182, 59, 54, 0.4);
  min-width: 180rpx;
}

/* 关注按钮 - 已关注状态 */
.follow-btn.following {
  background: transparent;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: none;
}

/* 关注按钮 - 互相关注状态 */
.follow-btn.mutual {
  background: transparent;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: none;
}

/* 私聊按钮 - 毛玻璃效果 */
.chat-btn {
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  min-width: 160rpx;
}

/* 编辑资料按钮 */
.edit-btn {
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  min-width: 200rpx;
}

/* ========== 内容展示区 ========== */
.content-section {
  position: relative;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  margin-top: -40rpx;
  min-height: 600rpx;
  z-index: 20;
  overflow: hidden;
}

/* Tab 内容区 */
.tab-content {
  padding: 24rpx;
  min-height: 400rpx;
  background: #f5f5f5;
}

/* ========== 瀑布流 ========== */
.waterfall-container {
  display: flex;
  gap: 20rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 帖子卡片 */
.post-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.post-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 封面区域 */
.card-cover {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: #f0f0f0;
}

/* 多图标识 */
.image-count {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(0, 0, 0, 0.5);
  padding: 8rpx 14rpx;
  border-radius: 20rpx;
}

.count-text {
  font-size: 22rpx;
  color: #ffffff;
}

/* 私密标识 */
.private-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(0, 0, 0, 0.6);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.private-badge text {
  font-size: 20rpx;
  color: #ffffff;
}

/* 内容区域 */
.card-content {
  padding: 20rpx;
}

.title-row {
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.project-tag {
  display: inline;
  font-size: 22rpx;
  color: #b63b36;
  background: rgba(182, 59, 54, 0.1);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-right: 8rpx;
  vertical-align: middle;
}

.post-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 作者信息 */
.author-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  overflow: hidden;
}

.author-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.author-name {
  font-size: 24rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 点赞信息 */
.like-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.like-count {
  font-size: 24rpx;
  color: #999999;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.empty-action {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #d64a45 0%, #b63b36 100%);
  border-radius: 40rpx;
}

.empty-action text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.empty-action:active {
  opacity: 0.8;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

/* 到底提示 */
.end-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 80rpx;
  gap: 20rpx;
}

.end-line {
  width: 80rpx;
  height: 2rpx;
  background: #e0e0e0;
}

.end-text {
  font-size: 24rpx;
  color: #bbbbbb;
}

/* ========== 隐私提示 ========== */
.privacy-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  gap: 24rpx;
}

.privacy-text {
  font-size: 28rpx;
  color: #999999;
}

/* ========== 安全区域 ========== */
.safe-area-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}

/* ========== 页面加载 ========== */
.page-loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  z-index: 9999;
}

/* ========== Vant Tabs 样式覆盖 ========== */
.content-section .van-tabs {
  --tabs-nav-background: #ffffff;
}

.content-section .van-tabs__wrap {
  border-bottom: 1rpx solid #f0f0f0;
}

