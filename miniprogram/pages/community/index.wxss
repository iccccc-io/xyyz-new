/* pages/community/index.wxss */

page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* ========== 固定顶部区域 ========== */
.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
}

/* --- 标签行 --- */
.tab-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 96rpx;
  padding: 0 32rpx;
  gap: 0;
}

.tab-sep {
  font-size: 28rpx;
  color: #ddd;
  margin: 0 20rpx;
  line-height: 1;
}

.tab-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.tab-label {
  font-size: 32rpx;
  color: #aaa;
  font-weight: 500;
  transition: all 0.2s ease;
}

.tab-active .tab-label {
  font-size: 36rpx;
  color: #1a1a1a;
  font-weight: bold;
}

.tab-ink {
  position: absolute;
  bottom: 0;
  width: 36rpx;
  height: 5rpx;
  border-radius: 3rpx;
  background: #b63b36;
}

/* 问一问 Tab：padding-bottom 设为 0，让 ai-label-wrap 的底边直接贴着 tab 视觉底边，
   与「发现」「关注」的横杠底边位置保持完全一致 */
.ai-tab-item {
  padding: 10rpx 0 0;
}

.ai-tab-content {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

/* AI 彩虹圆形图标 */
.ai-round-inner {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    #ff3b3b, #ff8c00, #ffe000,
    #3ecf3e, #1a8fff, #a259ff, #ff3b3b
  );
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.18);
  flex-shrink: 0;
  overflow: hidden;
}

/* 大星星 - 居中偏左下 */
.ai-star-big {
  position: absolute;
  font-size: 26rpx;
  color: #fff;
  line-height: 1;
  top: 50%;
  left: 50%;
  transform: translate(-68%, -58%);
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 小星星 - 居中偏右上，与大星星形成叠压 */
.ai-star-small {
  position: absolute;
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.95);
  line-height: 1;
  top: 50%;
  left: 50%;
  transform: translate(-10%, -88%);
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.25);
}

/* 图标优雅闪烁动画 */
@keyframes iconPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  40%       { opacity: 0.65; transform: scale(0.9); }
  70%       { opacity: 0.9; transform: scale(0.96); }
}

.ai-round-inner.pulsing {
  animation: iconPulse 2s ease-in-out infinite;
}

.ai-round-label {
  font-size: 32rpx;
  font-weight: 500;
  color: #aaa;
  transition: all 0.2s ease;
}

.ai-label-active {
  font-size: 36rpx !important;
  font-weight: bold !important;
  color: #1a1a1a !important;
}

/* tab-ink 居中对齐基础样式 */
.tab-ink {
  left: 50%;
  transform: translateX(-50%);
}

/* 问一问文字容器：与 .tab-item 一致，用 padding-bottom 控制文字与横杠间距 */
.ai-label-wrap {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 10rpx;
}

/* 横杠贴在容器底边，与「发现」「关注」选中态到横杠的视觉距离一致 */
.ai-label-wrap .tab-ink {
  position: absolute;
  bottom: 0;
  width: 72rpx;
}

/* --- 搜索行 --- */
.search-row {
  box-sizing: border-box; /* 让 padding 算在 88rpx 内，避免占位偏小覆盖帖子 */
  height: 88rpx;
  padding: 0 32rpx 16rpx;
  opacity: 1;
  overflow: hidden;
  transition: height 0.3s cubic-bezier(0.4, 0, 0.2, 1),
              opacity 0.25s ease,
              padding-bottom 0.3s ease;
}

.search-row.search-collapsed {
  height: 0;
  opacity: 0;
  padding-bottom: 0;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f0f0f0;
  border-radius: 36rpx;
}

.search-bar-input {
  flex: 1;
  min-width: 0;
  height: 100%;
  font-size: 26rpx;
  color: #3d3530;
  background: transparent;
}

.search-placeholder {
  font-size: 26rpx;
  color: #b0b0b0;
}

.search-bar-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 4rpx 6rpx;
}

/* 占位元素 */
.header-placeholder {
  width: 100%;
}

.community-container {
  padding: 0;
  overflow: hidden;
}

/* 发现 / 关注：横向滑动切换 */
.feed-swiper {
  width: 100%;
  box-sizing: border-box;
}

.feed-swiper-item {
  height: 100%;
  overflow: hidden;
}

.feed-scroll {
  height: 100%;
  width: 100%;
  box-sizing: border-box;
}

.feed-scroll-inner {
  padding: 20rpx;
  padding-bottom: 48rpx;
  box-sizing: border-box;
  min-height: 100%;
}

/* 关注空状态 */
.follow-empty {
  padding: 120rpx 0;
}

/* 瀑布流 */
.waterfall-container {
  display: flex;
  gap: 20rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.post-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.post-card:active {
  transform: scale(0.98);
}

.card-cover {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: #f0f0f0;
}

.cover-image {
  width: 100%;
  display: block;
}

.image-count {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(0, 0, 0, 0.5);
  padding: 8rpx 14rpx;
  border-radius: 20rpx;
}

.count-text {
  font-size: 22rpx;
  color: #ffffff;
}

.card-content {
  padding: 20rpx;
}

.title-row {
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.project-tag {
  display: inline;
  font-size: 22rpx;
  color: #b63b36;
  background: rgba(182, 59, 54, 0.1);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-right: 8rpx;
  vertical-align: middle;
}

.post-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.author-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  overflow: hidden;
}

.author-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.author-name {
  font-size: 24rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 140rpx;
}

.author-name.certified { color: #b63b36; font-weight: 500; }

.like-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.like-count { font-size: 24rpx; color: #999999; }
.like-count.liked { color: #b63b36; }

.empty-state,
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
}

.end-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 120rpx;
  gap: 20rpx;
}

.end-line { width: 80rpx; height: 2rpx; background: #e0e0e0; }
.end-text { font-size: 24rpx; color: #bbbbbb; }

/* ========== 发布按钮 ========== */
.fab-button {
  position: fixed;
  right: 40rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 36rpx;
  background: linear-gradient(135deg, #b63b36 0%, #d4574f 100%);
  border-radius: 60rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.25), 0 12rpx 40rpx rgba(182,59,54,0.4);
  z-index: 50;
  transition: all 0.3s ease;
}

.fab-button.fab-hidden {
  opacity: 0;
  transform: scale(0.7) translateY(20rpx);
  pointer-events: none;
}

.fab-button:active { transform: scale(0.95); }

.fab-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

/* ========== AI 问一问 抽屉 ========== */
.ai-drawer {
  position: fixed;
  left: 0;
  right: 0;
  background: #f7f7f7;
  z-index: 99;
  transform: translateY(100%);
  transition: transform 0.38s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.ai-drawer-open {
  transform: translateY(0);
}

/* 消息滚动区：flex:1 占满抽屉剩余空间，内联 height 做 scroll-view 必需的定高 */
.chat-scroll {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.chat-scroll-inner {
  padding: 24rpx 24rpx 0;
}

/* 欢迎卡片 */
.chat-welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
}

.chat-welcome-icon {
  margin-bottom: 24rpx;
}

/* 欢迎区：与顶部「问一问」同款的彩虹圆 + 叠星，仅放大尺寸 */
.ai-round-inner--welcome {
  width: 96rpx;
  height: 96rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.14);
}

.ai-round-inner--welcome .ai-star-big {
  font-size: 58rpx;
}

.ai-round-inner--welcome .ai-star-small {
  font-size: 34rpx;
}

.chat-welcome-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.chat-welcome-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.85;
  margin-bottom: 32rpx;
  white-space: pre-line;
  text-align: center;
  max-width: 600rpx;
}

.chat-quick-bar {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 16rpx;
  width: 100%;
  max-width: 560rpx;
}

.chat-quick-chip {
  padding: 20rpx 28rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid #e8e8e8;
  transition: all 0.15s;
  text-align: center;
  box-sizing: border-box;
}

.chat-quick-chip:active {
  background: #f0f0f0;
}

/* 消息气泡 */
.chat-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.chat-row-wrap {
  margin-bottom: 8rpx;
}

.chat-row-self {
  justify-content: flex-end;
}

.chat-row-ai {
  justify-content: flex-start;
  gap: 14rpx;
}

.chat-ai-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #a259ff, #1a8fff);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chat-ai-avatar-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 1rpx;
}

.chat-bubble {
  max-width: 72%;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  word-break: break-all;
}

.chat-bubble-user {
  background: #b63b36;
  border-bottom-right-radius: 6rpx;
}

.chat-bubble-ai {
  background: #fff;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.chat-bubble-error {
  background: #fff5f0;
  border: 1rpx solid #ffd0c0;
}

.chat-bubble-text {
  font-size: 30rpx;
  line-height: 1.7;
  color: #333;
}

.chat-bubble-user .chat-bubble-text {
  color: #fff;
}

.chat-citation-mark {
  font-size: 26rpx;
  color: #1a8fff;
  font-weight: 500;
}

/* 思考中 */
.chat-typing-bubble {
  padding: 20rpx 28rpx;
}

.typing-dots {
  display: flex;
  align-items: center;
  gap: 10rpx;
  height: 32rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ccc;
  animation: typingBounce 1.2s ease-in-out infinite;
}

.dot-1 { animation-delay: 0s; }
.dot-2 { animation-delay: 0.2s; }
.dot-3 { animation-delay: 0.4s; }

@keyframes typingBounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-8rpx); opacity: 1; }
}

/* 追问建议 */
.chat-suggested {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  padding: 12rpx 0 16rpx 74rpx;
}

.chat-suggested-chip {
  padding: 10rpx 24rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #555;
  border: 1rpx solid #e0e0e0;
  transition: all 0.15s;
}

.chat-suggested-chip:active {
  background: #f5f5f5;
}

/* ========== 底部输入区：flex 流式布局，不再用 absolute ========== */
.chat-input-area {
  flex-shrink: 0;
  background: #f7f7f7;
  border-top: 1rpx solid #efefef;
  padding-top: 16rpx;
}

.chat-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 24rpx 16rpx;
}

.chat-input-capsule {
  flex: 1;
  height: 80rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #e8e8e8;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.chat-input-field {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #333;
  background: transparent;
}

.chat-input-placeholder {
  color: #bbb;
  font-size: 30rpx;
}

.chat-send-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.chat-send-active {
  background: #b63b36;
  box-shadow: 0 4rpx 16rpx rgba(182, 59, 54, 0.35);
}

.chat-send-btn:active {
  transform: scale(0.92);
}

/* ========== 引文标记 & 引文卡片 ========== */
.chat-citation-mark {
  display: inline;
  color: #3478f6;
  font-size: 26rpx;
  font-weight: 600;
  padding: 2rpx 4rpx;
  border-radius: 6rpx;
  background: rgba(52, 120, 246, 0.08);
}

.chat-citation-mark:active {
  background: rgba(52, 120, 246, 0.2);
}

.chat-citation-list {
  margin-top: 12rpx;
  padding-left: 74rpx;
}

.chat-citation-scroll {
  white-space: nowrap;
}

.chat-citation-scroll-inner {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.chat-citation-card {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: rgba(52, 120, 246, 0.06);
  border: 1rpx solid rgba(52, 120, 246, 0.12);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.chat-citation-card:active {
  background: rgba(52, 120, 246, 0.14);
}

.chat-citation-icon {
  font-size: 24rpx;
}

.chat-citation-title {
  font-size: 24rpx;
  color: #3478f6;
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: calc(120rpx + env(safe-area-inset-bottom));
}
