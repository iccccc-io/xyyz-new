/* pages/order/logistics.wxss */

.logistics-page {
  min-height: 100vh;
  background: #f6f0e8;
  padding-bottom: 40rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.pickup-wrap {
  padding: 80rpx 32rpx 0;
}

.pickup-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.pickup-icon {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: #FFF7EC;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pickup-title {
  display: block;
  margin-top: 22rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.pickup-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #8B7A69;
  text-align: center;
}

.pickup-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F4EBDD;
}

.pickup-meta-label {
  font-size: 24rpx;
  color: #9C8D7E;
}

.pickup-meta-value {
  font-size: 26rpx;
  color: #4A3E34;
  font-weight: 600;
}

/* ===== 错误状态 ===== */
.error-wrap {
  padding: 80rpx 40rpx;
}

.error-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.error-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-top: 12rpx;
}

.error-desc {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  line-height: 1.6;
  padding: 0 20rpx;
}

.error-tracking {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 16rpx 24rpx;
  background: #f9f5ef;
  border-radius: 12rpx;
}

.error-tracking-label { font-size: 24rpx; color: #999; }
.error-tracking-no { font-size: 26rpx; color: #8B6F47; font-family: monospace; }

.error-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 24rpx;
  padding: 16rpx 40rpx;
  background: #fff0f0;
  border-radius: 40rpx;
  color: #8B2E2A;
  font-size: 28rpx;
  font-weight: 500;
}

/* ===== 地图区域 ===== */
.map-section {
  position: relative;
  height: 360rpx;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.logistics-map {
  width: 100%;
  height: 100%;
}

.map-overlay {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(10px);
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}

.map-area {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* ===== 头部快递信息 ===== */
.header-card {
  margin: 20rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.carrier-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.carrier-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.cache-hint {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: #aaa;
}

.tracking-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 0;
  border-top: 1rpx solid #f5f0e8;
}

.tracking-label {
  font-size: 26rpx;
  color: #999;
}

.tracking-number {
  font-size: 28rpx;
  color: #333;
  font-family: monospace;
  letter-spacing: 1rpx;
  flex: 1;
}

.notice-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: #fff8f0;
  border-radius: 10rpx;
  margin-top: 12rpx;
}

.notice-text {
  font-size: 24rpx;
  color: #ff9500;
}

/* ===== 物流时间轴 ===== */
.timeline-card {
  margin: 20rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.timeline-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f0e8;
}

.timeline {
  display: flex;
  flex-direction: column;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
  min-height: 100rpx;
}

/* 左侧竖线 */
.tl-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 24rpx;
  flex-shrink: 0;
}

.tl-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ddd;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.dot-active {
  width: 20rpx;
  height: 20rpx;
  background: #8B2E2A;
  box-shadow: 0 0 0 6rpx rgba(139,46,42,0.2);
  margin-top: 6rpx;
}

.tl-line {
  width: 3rpx;
  flex: 1;
  background: #e8e0d4;
  min-height: 40rpx;
}

/* 右侧内容 */
.tl-content {
  flex: 1;
  padding-bottom: 28rpx;
}

.tl-context {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.item-active .tl-context {
  color: #333;
  font-weight: 600;
}

.tl-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.tl-time {
  font-size: 22rpx;
  color: #bbb;
}

.item-active .tl-time {
  color: #8B6F47;
}

.tl-area {
  font-size: 22rpx;
  color: #ccc;
  background: #f9f5ef;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.item-active .tl-area {
  color: #8B6F47;
}
