<view class="order-list-page">
  <nav-bar
    title="我的订单"
    showTitle="{{true}}"
    showBack="{{true}}"
    background="solid"
    dark="{{true}}"
    placeholder="{{true}}"
  />

  <view class="order-top-shell" style="top: {{stickyTopPx}}px;">
    <view class="toolbar-row">
      <view class="toolbar-search">
        <van-icon name="search" size="18" color="#B8AEA2" />
        <input
          class="toolbar-input"
          placeholder="搜索商品或工坊"
          placeholder-class="toolbar-placeholder"
          value="{{searchValue}}"
          confirm-type="search"
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
        />
        <view class="search-clear" wx:if="{{searchValue}}" bindtap="onSearchClear">
          <van-icon name="cross" size="14" color="#B8AEA2" />
        </view>
        <view class="search-action" bindtap="onSearchConfirm">
          <van-icon name="arrow" size="16" color="#A12D27" />
        </view>
      </view>
      <view
        class="toolbar-filter {{showTimeFilterDrawer ? 'is-open' : ''}} {{hasActiveTimeFilter ? 'is-active' : ''}} {{isFilterBreathing ? 'is-breathing' : ''}}"
        bindtap="toggleTimeFilterDrawer"
      >
        <van-icon name="clock-o" size="18" color="#A12D27" />
        <view class="filter-active-dot" wx:if="{{hasActiveTimeFilter}}"></view>
      </view>
    </view>

    <view class="tabs-sticky">
      <scroll-view class="tabs-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="tabs-row">
          <view
            wx:for="{{orderTabs}}"
            wx:key="name"
            class="tab-item {{activeTab === item.name ? 'tab-active' : ''}}"
            data-name="{{item.name}}"
            bindtap="onTabChange"
          >
            <text class="tab-text">
              {{item.name === 'all' ? '全部' : item.name === '10' ? '待付款' : item.name === '20' ? '待发货' : item.name === '30' ? '待收货' : item.name === '40' ? '已完成' : '售后'}}
            </text>
            <view class="tab-ink" wx:if="{{activeTab === item.name}}"></view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="time-filter-drawer {{showTimeFilterDrawer ? 'is-open' : ''}}">
      <view class="time-filter-inner">
        <view class="drawer-head">
          <text class="drawer-title">按下单时间筛选</text>
          <text class="drawer-summary" wx:if="{{activeTimeFilterSummary}}">{{activeTimeFilterSummary}}</text>
        </view>

        <view class="drawer-chip-row">
          <view class="drawer-chip {{draftTimeFilter.granularity === 'year' ? 'is-active' : ''}}" data-value="year" bindtap="selectTimeGranularity">按年</view>
          <view class="drawer-chip {{draftTimeFilter.granularity === 'month' ? 'is-active' : ''}}" data-value="month" bindtap="selectTimeGranularity">按月</view>
          <view class="drawer-chip {{draftTimeFilter.granularity === 'day' ? 'is-active' : ''}}" data-value="day" bindtap="selectTimeGranularity">按日</view>
        </view>

        <view class="drawer-chip-row drawer-chip-row-secondary">
          <view class="drawer-chip drawer-chip-secondary {{draftTimeFilter.type === 'single' ? 'is-active' : ''}}" data-value="single" bindtap="selectTimeType">单选</view>
          <view class="drawer-chip drawer-chip-secondary {{draftTimeFilter.type === 'range' ? 'is-active' : ''}}" data-value="range" bindtap="selectTimeType">区间</view>
        </view>

        <view class="picker-group" wx:if="{{draftTimeFilter.granularity === 'year' && draftTimeFilter.type === 'single'}}">
          <picker mode="date" fields="year" value="{{draftTimeFilter.yearSingle}}" data-field="yearSingle" bindchange="onTimePickerChange">
            <view class="picker-card">
              <text class="picker-label">年份</text>
              <view class="picker-value-row">
                <text class="picker-value">{{draftTimeFilter.yearSingleLabel}}</text>
                <van-icon name="arrow-down" size="14" color="#9A8C7C" />
              </view>
            </view>
          </picker>
        </view>

        <view class="picker-grid" wx:if="{{draftTimeFilter.granularity === 'year' && draftTimeFilter.type === 'range'}}">
          <picker mode="date" fields="year" value="{{draftTimeFilter.yearStart}}" data-field="yearStart" bindchange="onTimePickerChange">
            <view class="picker-card">
              <text class="picker-label">开始年份</text>
              <view class="picker-value-row">
                <text class="picker-value">{{draftTimeFilter.yearStartLabel}}</text>
                <van-icon name="arrow-down" size="14" color="#9A8C7C" />
              </view>
            </view>
          </picker>
          <picker mode="date" fields="year" value="{{draftTimeFilter.yearEnd}}" data-field="yearEnd" bindchange="onTimePickerChange">
            <view class="picker-card">
              <text class="picker-label">结束年份</text>
              <view class="picker-value-row">
                <text class="picker-value">{{draftTimeFilter.yearEndLabel}}</text>
                <van-icon name="arrow-down" size="14" color="#9A8C7C" />
              </view>
            </view>
          </picker>
        </view>

        <view class="picker-group" wx:if="{{draftTimeFilter.granularity === 'month' && draftTimeFilter.type === 'single'}}">
          <picker mode="date" fields="month" value="{{draftTimeFilter.monthSingle}}" data-field="monthSingle" bindchange="onTimePickerChange">
            <view class="picker-card">
              <text class="picker-label">月份</text>
              <view class="picker-value-row">
                <text class="picker-value">{{draftTimeFilter.monthSingleLabel}}</text>
                <van-icon name="arrow-down" size="14" color="#9A8C7C" />
              </view>
            </view>
          </picker>
        </view>

        <view class="picker-grid" wx:if="{{draftTimeFilter.granularity === 'month' && draftTimeFilter.type === 'range'}}">
          <picker mode="date" fields="month" value="{{draftTimeFilter.monthStart}}" data-field="monthStart" bindchange="onTimePickerChange">
            <view class="picker-card">
              <text class="picker-label">开始月份</text>
              <view class="picker-value-row">
                <text class="picker-value">{{draftTimeFilter.monthStartLabel}}</text>
                <van-icon name="arrow-down" size="14" color="#9A8C7C" />
              </view>
            </view>
          </picker>
          <picker mode="date" fields="month" value="{{draftTimeFilter.monthEnd}}" data-field="monthEnd" bindchange="onTimePickerChange">
            <view class="picker-card">
              <text class="picker-label">结束月份</text>
              <view class="picker-value-row">
                <text class="picker-value">{{draftTimeFilter.monthEndLabel}}</text>
                <van-icon name="arrow-down" size="14" color="#9A8C7C" />
              </view>
            </view>
          </picker>
        </view>

        <view class="picker-group" wx:if="{{draftTimeFilter.granularity === 'day' && draftTimeFilter.type === 'single'}}">
          <picker mode="date" fields="day" value="{{draftTimeFilter.daySingle}}" data-field="daySingle" bindchange="onTimePickerChange">
            <view class="picker-card">
              <text class="picker-label">日期</text>
              <view class="picker-value-row">
                <text class="picker-value">{{draftTimeFilter.daySingleLabel}}</text>
                <van-icon name="arrow-down" size="14" color="#9A8C7C" />
              </view>
            </view>
          </picker>
        </view>

        <view class="picker-grid" wx:if="{{draftTimeFilter.granularity === 'day' && draftTimeFilter.type === 'range'}}">
          <picker mode="date" fields="day" value="{{draftTimeFilter.dayStart}}" data-field="dayStart" bindchange="onTimePickerChange">
            <view class="picker-card">
              <text class="picker-label">开始日期</text>
              <view class="picker-value-row">
                <text class="picker-value">{{draftTimeFilter.dayStartLabel}}</text>
                <van-icon name="arrow-down" size="14" color="#9A8C7C" />
              </view>
            </view>
          </picker>
          <picker mode="date" fields="day" value="{{draftTimeFilter.dayEnd}}" data-field="dayEnd" bindchange="onTimePickerChange">
            <view class="picker-card">
              <text class="picker-label">结束日期</text>
              <view class="picker-value-row">
                <text class="picker-value">{{draftTimeFilter.dayEndLabel}}</text>
                <van-icon name="arrow-down" size="14" color="#9A8C7C" />
              </view>
            </view>
          </picker>
        </view>

        <view class="drawer-actions">
          <view class="drawer-btn drawer-btn-reset" bindtap="onResetTimeFilter">重置</view>
          <view class="drawer-btn drawer-btn-apply" bindtap="onApplyTimeFilter">应用筛选</view>
        </view>
      </view>
    </view>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <van-loading size="24px" color="#E1251B">正在加载订单...</van-loading>
  </view>

  <van-empty
    wx:elif="{{!loading && orders.length === 0}}"
    image="order"
    description="{{searchKeyword ? '没有找到匹配的订单' : (hasActiveTimeFilter ? '该时间范围内暂无订单' : '暂时还没有订单')}}"
  >
    <view class="empty-action" bindtap="goToMall">
      <text class="empty-action-text">去逛商城</text>
      <van-icon name="arrow" size="16" color="#B66A44" />
    </view>
  </van-empty>

  <view class="orders-wrap {{isTabSwitching ? 'is-switching' : ''}}" wx:else>
      <view class="order-card" wx:for="{{orders}}" wx:key="_id" style="animation-delay: {{item.cardDelay}}ms;">
        <view class="card-head">
          <view class="shop-block">
            <view class="shop-icon-wrap">
              <van-icon name="shop-o" size="14" color="#999999" />
            </view>
            <view class="shop-text-wrap">
              <view class="shop-name">{{item.shopName}}</view>
              <view class="shop-arrow">></view>
            </view>
          </view>
          <view class="status-text {{item.statusStyle}}">
            {{item.status === 10 ? '待付款' : item.status === 20 ? '待发货' : item.status === 30 ? '已发货' : item.status === 40 ? '已完成' : item.status === 50 ? '已取消' : '售后中'}}
          </view>
        </view>

      <view class="product-panel" bindtap="goToDetail" data-id="{{item._id}}">
        <image class="product-img" src="{{item.product_snapshot.sku_image || item.product_snapshot.cover_img}}" mode="aspectFill" />

        <view class="product-main">
          <text class="product-title">{{item.product_snapshot.title}}</text>
          <text class="product-desc" wx:if="{{item.product_snapshot.sku_name}}">款式：{{item.product_snapshot.sku_name}}</text>

          <view class="product-tags">
            <text class="mini-tag heritage" wx:if="{{item.projectName}}">{{item.projectName}}</text>
            <text class="mini-tag neutral">{{item.categoryText}}</text>
          </view>
        </view>

        <view class="product-side">
          <view class="product-side-price-group">
            <text class="side-symbol">¥</text>
            <text class="product-price">{{item.productPriceDisplay}}</text>
          </view>
          <text class="product-qty">共 {{item.quantity}} 件</text>
        </view>
      </view>

      <view class="countdown-strip" wx:if="{{item.status === 10 && item.countdownDisplay}}">
        <van-icon name="clock-o" size="13" color="#E1251B" />
        <text class="countdown-text">{{item.countdown > 0 ? ('请在 ' + item.countdownDisplay + ' 内完成支付') : '支付超时，订单即将自动取消'}}</text>
      </view>

      <view class="logistics-strip {{item.isPickupOrder ? 'is-pickup' : ''}}" wx:if="{{item.status === 30 && (item.tracking_number || item.isPickupOrder)}}">
        <van-icon name="logistics" size="14" color="#999999" />
        <text class="logistics-text">{{item.logisticsSummary}}</text>
      </view>

      <view class="summary-bar">
        <text class="summary-text">共 {{item.quantity}} 件商品</text>
        <text class="summary-text">实付款</text>
        <view class="summary-price-group">
          <text class="summary-symbol">¥</text>
          <text class="summary-price">{{item.totalDisplay}}</text>
        </view>
      </view>

      <view class="card-actions">
        <block wx:if="{{item.status === 10}}">
          <view class="action-btn subtle" bindtap="cancelOrder" data-id="{{item._id}}" data-idx="{{index}}">取消订单</view>
          <view class="action-btn primary" bindtap="payOrder" data-id="{{item._id}}" data-total="{{item.totalDisplay}}" data-idx="{{index}}">去支付</view>
        </block>

        <block wx:elif="{{item.status === 20}}">
          <view class="action-note">{{item.isPickupOrder ? '待工坊交付' : '工坊正在备货，请耐心等待发货'}}</view>
          <view class="action-btn subtle" bindtap="goToDetail" data-id="{{item._id}}">查看详情</view>
        </block>

        <block wx:elif="{{item.status === 30}}">
          <view class="action-btn subtle {{item.isPickupOrder ? 'is-disabled' : ''}}" bindtap="viewLogistics" data-id="{{item._id}}" data-pickup="{{item.isPickupOrder}}">查看物流</view>
          <view class="action-btn primary" bindtap="confirmReceipt" data-id="{{item._id}}" data-idx="{{index}}">确认收货</view>
        </block>

        <block wx:elif="{{item.status === 40 && item.has_aftersale}}">
          <view class="action-btn subtle" bindtap="viewAftersale" data-id="{{item._id}}">查看售后进度</view>
          <view class="action-btn subtle {{item.isPickupOrder ? 'is-disabled' : ''}}" wx:if="{{item.showLogisticsAction}}" bindtap="viewLogistics" data-id="{{item._id}}" data-pickup="{{item.isPickupOrder}}">查看物流</view>
          <view class="action-btn primary" bindtap="goToDetail" data-id="{{item._id}}">查看详情</view>
        </block>

        <block wx:elif="{{item.status === 40}}">
          <view class="action-btn subtle {{item.isPickupOrder ? 'is-disabled' : ''}}" wx:if="{{item.showLogisticsAction}}" bindtap="viewLogistics" data-id="{{item._id}}" data-pickup="{{item.isPickupOrder}}">查看物流</view>
          <view wx:if="{{item.reviewStatus === 1}}" class="action-btn primary" bindtap="goToReviewDetail" data-review-id="{{item.reviewId}}">
            我的评价
          </view>
          <view wx:else class="action-btn primary" bindtap="goToReviewSubmit" data-id="{{item._id}}">
            去评价
          </view>
        </block>

        <block wx:elif="{{item.status === 60}}">
          <view class="action-btn subtle" bindtap="viewAftersale" data-id="{{item._id}}">查看售后进度</view>
          <view class="action-btn primary" bindtap="goToDetail" data-id="{{item._id}}">查看详情</view>
        </block>

        <block wx:else>
          <view class="action-btn primary" bindtap="goToDetail" data-id="{{item._id}}">查看详情</view>
        </block>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
      <text>加载更多订单</text>
    </view>
    <view class="no-more" wx:elif="{{orders.length > 0 && !hasMore}}">
      <text>没有更多订单了</text>
    </view>
  </view>
</view>

<pay-keyboard
  id="payKeyboard"
  show="{{showPayKeyboard}}"
  title="补充支付"
  amount-display="{{payAmountDisplay}}"
  loading="{{paying}}"
  bind:confirm="onPayConfirm"
  bind:close="closePayKeyboard"
/>
