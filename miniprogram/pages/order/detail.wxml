<view class="detail-page">
  <nav-bar
    title="订单详情"
    showTitle="{{true}}"
    showBack="{{true}}"
    background="solid"
    dark="{{true}}"
    placeholder="{{true}}"
  />

  <view class="loading-wrap" wx:if="{{loading}}">
    <van-loading size="24px" color="#A12D27">加载中...</van-loading>
  </view>

  <block wx:if="{{!loading && order}}">
    <view class="status-stage">
      <view class="status-ticket {{ticketEntered ? 'ticket-entered' : 'ticket-entering'}} banner-{{order.status}} {{order.aftersale_result === 'refunded' ? 'banner-refunded' : ''}}">
        <view class="ticket-surface">
          <view class="ticket-upper">
            <view class="ticket-copy">
              <text class="ticket-title">
                {{order.status === 10 ? '待付款' : order.status === 20 ? '待发货' : order.status === 30 ? '已发货' : order.status === 40 ? '交易完成' : order.status === 50 ? '已取消' : '售后处理'}}
              </text>
              <text class="ticket-desc">
                {{order.status === 10 ? '请尽快完成支付，超时将自动取消。' : order.status === 20 ? '订单已支付，等待卖家发货。' : order.status === 30 ? '快递已发出，请留意查收。' : order.status === 40 ? '售后窗口期内可申请售后。' : order.status === 50 ? '订单已取消。' : '售后处理中，可随时查看记录。'}}
              </text>
              <view class="countdown-row" wx:if="{{order.status === 10 && countdown > 0}}">
                <van-icon name="clock-o" size="16" color="rgba(255,255,255,0.92)" />
                <text class="countdown-text">剩余支付时间 {{countdownDisplay}}</text>
              </view>
              <view class="countdown-row expired" wx:elif="{{order.status === 10 && countdown <= 0}}">
                <text class="countdown-text">支付超时，订单即将自动取消</text>
              </view>
            </view>
            <view class="ticket-side">
              <view class="ticket-amount-block">
                <text class="ticket-amount-label">实付</text>
                <view class="ticket-amount-line">
                  <text class="ticket-amount-currency">¥</text>
                  <text class="ticket-amount-value">{{order.totalDisplay}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="ticket-seam">
            <view class="ticket-notch ticket-notch-left"></view>
            <view class="ticket-dash"></view>
            <view class="ticket-notch ticket-notch-right"></view>
          </view>

          <view class="ticket-lower">
            <text class="ticket-order-caption">订单号</text>
            <text class="ticket-order-id">{{order._id}}</text>
          </view>
        </view>

        <view class="ticket-teeth">
          <view class="ticket-tooth" wx:for="{{ticketTeeth}}" wx:key="*this"></view>
        </view>
      </view>
    </view>

    <view class="content-wrap">
      <view class="spotlight-card">
        <view class="spotlight-head">
          <text class="spotlight-title">{{order.product_snapshot.workshop_name || '湘韵遗珍文创商城'}}</text>
          <text class="spotlight-link" bindtap="goToProduct">查看商品</text>
        </view>
        <view class="spotlight-body" bindtap="goToProduct">
          <image class="spotlight-image" src="{{order.product_snapshot.sku_image || order.product_snapshot.cover_img}}" mode="aspectFill" />
          <view class="spotlight-main">
            <text class="spotlight-name">{{order.product_snapshot.title}}</text>
            <text class="spotlight-sku" wx:if="{{order.product_snapshot.sku_name}}">款式：{{order.product_snapshot.sku_name}}</text>
            <view class="spotlight-tags">
              <text class="spotlight-tag spotlight-tag-brand" wx:if="{{order.product_snapshot.related_project_name}}">{{order.product_snapshot.related_project_name}}</text>
              <text class="spotlight-tag">{{order.product_snapshot.category || '文创好物'}}</text>
            </view>
          </view>
          <view class="spotlight-side">
            <text class="spotlight-price">¥{{order.productPriceDisplay}}</text>
            <text class="spotlight-count">x {{order.quantity}}</text>
          </view>
        </view>
      </view>

      <view class="steps-card" wx:if="{{order.status !== 50}}">
        <view class="card-title-row">
          <view class="card-title-main">
            <van-icon name="cluster-o" size="18" color="#A12D27" />
            <text class="card-title">履约进度</text>
          </view>
        </view>
        <view class="steps-row">
          <view class="step-item {{order.status >= 10 ? 'step-done' : ''}}">
            <view class="step-dot {{order.status === 10 ? 'dot-active' : order.status > 10 ? 'dot-done' : ''}}">
              <van-icon wx:if="{{order.status > 10}}" name="success" size="14" color="#fff" />
              <text wx:else class="dot-num">1</text>
            </view>
            <text class="step-label">待付款</text>
            <text class="step-time" wx:if="{{order.createTimeDisplay}}">{{order.createTimeDisplay}}</text>
          </view>
          <view class="step-line {{order.status > 10 ? 'line-done' : ''}}"></view>
          <view class="step-item {{order.status >= 20 ? 'step-done' : ''}}">
            <view class="step-dot {{order.status === 20 ? 'dot-active' : order.status > 20 ? 'dot-done' : ''}}">
              <van-icon wx:if="{{order.status > 20}}" name="success" size="14" color="#fff" />
              <text wx:else class="dot-num">2</text>
            </view>
            <text class="step-label">待发货</text>
            <text class="step-time" wx:if="{{order.payTimeDisplay}}">{{order.payTimeDisplay}}</text>
          </view>
          <view class="step-line {{order.status > 20 ? 'line-done' : ''}}"></view>
          <view class="step-item {{order.status >= 30 ? 'step-done' : ''}}">
            <view class="step-dot {{order.status === 30 ? 'dot-active' : order.status > 30 ? 'dot-done' : ''}}">
              <van-icon wx:if="{{order.status > 30}}" name="success" size="14" color="#fff" />
              <text wx:else class="dot-num">3</text>
            </view>
            <text class="step-label">已发货</text>
            <text class="step-time" wx:if="{{order.shipTimeDisplay}}">{{order.shipTimeDisplay}}</text>
          </view>
          <view class="step-line {{order.status > 30 ? 'line-done' : ''}}"></view>
          <view class="step-item {{order.status >= 40 ? 'step-done' : ''}}">
            <view class="step-dot {{order.status >= 40 ? 'dot-done' : ''}}">
              <van-icon wx:if="{{order.status >= 40}}" name="success" size="14" color="#fff" />
              <text wx:else class="dot-num">4</text>
            </view>
            <text class="step-label">已完成</text>
            <text class="step-time" wx:if="{{order.completeTimeDisplay}}">{{order.completeTimeDisplay}}</text>
          </view>
        </view>
      </view>

      <view class="info-card logistics-card" wx:if="{{order.status >= 30 && order.tracking_number}}">
        <view class="card-title-row">
          <view class="card-title-main">
            <van-icon name="logistics" size="18" color="#1989fa" />
            <text class="card-title">物流信息</text>
          </view>
          <view class="card-link" bindtap="queryLogistics">
            <text>查看物流</text>
            <van-icon name="arrow" size="14" color="#8B6F47" />
          </view>
        </view>
        <view class="logistics-info-row">
          <view class="logistics-badge">{{order.carrier_code}}</view>
          <text class="logistics-no" bindtap="copyTracking">{{order.tracking_number}}</text>
          <van-icon name="copy-o" size="16" color="#aaa" bindtap="copyTracking" />
        </view>
        <text class="logistics-sub">发货时间：{{order.shipTimeDisplay}}</text>
      </view>

      <view class="info-card" wx:if="{{order.delivery_address}}">
        <view class="card-title-row">
          <view class="card-title-main">
            <van-icon name="location-o" size="18" color="#A12D27" />
            <text class="card-title">收货地址</text>
          </view>
        </view>
        <view class="address-card">
          <view class="address-user-row">
            <text class="address-name">{{order.delivery_address.userName}}</text>
            <text class="address-tel">{{order.delivery_address.telNumber}}</text>
          </view>
          <text class="address-detail">
            {{order.delivery_address.provinceName}}{{order.delivery_address.cityName}}{{order.delivery_address.countyName}} {{order.delivery_address.detailInfo}}
          </text>
        </view>
      </view>

      <view class="info-card">
        <view class="card-title-row">
          <view class="card-title-main">
            <van-icon name="description" size="18" color="#A12D27" />
            <text class="card-title">订单信息</text>
          </view>
        </view>
        <view class="info-grid">
          <view class="info-grid-item grid-span-full">
            <text class="grid-label">订单号</text>
            <view class="grid-value-row" bindtap="copyOrderId">
              <text class="grid-value order-id-text">{{order._id}}</text>
              <van-icon name="copy-o" size="14" color="#aaa" />
            </view>
          </view>
          <view class="info-grid-item">
            <text class="grid-label">下单时间</text>
            <text class="grid-value">{{order.createTimeDisplay}}</text>
          </view>
          <view class="info-grid-item" wx:if="{{order.payTimeDisplay}}">
            <text class="grid-label">支付时间</text>
            <text class="grid-value">{{order.payTimeDisplay}}</text>
          </view>
          <view class="info-grid-item" wx:if="{{order.completeTimeDisplay}}">
            <text class="grid-label">完成时间</text>
            <text class="grid-value">{{order.completeTimeDisplay}}</text>
          </view>
          <view class="info-grid-item">
            <text class="grid-label">实付金额</text>
            <text class="grid-value price-val">¥{{order.totalDisplay}}</text>
          </view>
        </view>
      </view>

      <view class="info-card aftersale-log-card" wx:if="{{aftersaleLog}}">
        <view class="card-title-row">
          <view class="card-title-main">
            <van-icon name="service-o" size="18" color="#ff9500" />
            <text class="card-title">售后记录</text>
          </view>
          <van-tag color="{{aftersaleLog.status === 3 ? '#10b981' : aftersaleLog.status < 0 ? '#999' : '#ff9500'}}" plain size="medium">
            {{aftersaleLog.statusText}}
          </van-tag>
        </view>
        <view class="info-grid">
          <view class="info-grid-item">
            <text class="grid-label">类型</text>
            <text class="grid-value">{{aftersaleLog.type}}</text>
          </view>
          <view class="info-grid-item">
            <text class="grid-label">退款金额</text>
            <text class="grid-value price-val">¥{{aftersaleLog.refundDisplay}}</text>
          </view>
          <view class="info-grid-item grid-span-full">
            <text class="grid-label">原因</text>
            <text class="grid-value">{{aftersaleLog.reason}}</text>
          </view>
        </view>
        <view class="as-log-timeline" wx:if="{{aftersaleLog.operationLogs.length > 0}}">
          <view class="as-log-tl" wx:for="{{aftersaleLog.operationLogs}}" wx:key="index">
            <view class="as-tl-dot {{item.operator === 'seller' ? 'dot-red' : item.operator === 'system' ? 'dot-orange' : ''}}"></view>
            <view class="as-tl-content">
              <view class="as-tl-head">
                <text class="as-tl-role">{{item.operatorLabel}}</text>
                <text class="as-tl-time">{{item.timeDisplay}}</text>
              </view>
              <text class="as-tl-text">{{item.content}}</text>
            </view>
          </view>
        </view>
        <view class="card-link link-block" bindtap="viewAftersale" wx:if="{{activeAftersaleId}}">
          <text>查看完整售后详情</text>
          <van-icon name="arrow" size="14" color="#8B6F47" />
        </view>
      </view>

      <view class="aftersale-hint-card" wx:if="{{canApplyAftersale}}">
        <van-icon name="shield-o" size="18" color="#ff9500" />
        <text class="as-hint-text">售后保障中，截止 {{aftersaleDeadlineDisplay}}</text>
      </view>
    </view>

    <view class="detail-footer">
      <block wx:if="{{order.status === 10}}">
        <view class="footer-btn footer-btn-secondary" bindtap="cancelOrder">取消订单</view>
        <view class="footer-btn footer-btn-primary" bindtap="payOrder">立即支付</view>
      </block>

      <block wx:elif="{{order.status === 30}}">
        <view class="footer-btn footer-btn-secondary" bindtap="queryLogistics">查看物流</view>
        <view class="footer-btn footer-btn-primary" bindtap="confirmReceipt">确认收货</view>
      </block>

      <block wx:elif="{{order.status === 40 && order.has_aftersale}}">
        <view class="footer-btn footer-btn-secondary" bindtap="queryLogistics" wx:if="{{order.tracking_number}}">查看物流</view>
        <view class="footer-btn footer-btn-primary" bindtap="viewAftersale" wx:if="{{activeAftersaleId}}">查看售后进度</view>
        <view class="footer-btn footer-btn-secondary" bindtap="goBack" wx:if="{{!order.tracking_number && !activeAftersaleId}}">返回列表</view>
      </block>

      <block wx:elif="{{order.status === 40}}">
        <view class="footer-btn footer-btn-secondary" bindtap="queryLogistics" wx:if="{{order.tracking_number}}">查看物流</view>
        <view class="footer-btn footer-btn-warning" bindtap="applyAftersale" wx:if="{{canApplyAftersale}}">
          {{aftersaleLog ? '重新申请售后' : '申请售后'}}
        </view>
        <view class="footer-btn footer-btn-primary" bindtap="goToReviewDetail" wx:if="{{order.reviewStatus === 1}}">
          我的评价
        </view>
        <view class="footer-btn footer-btn-primary" bindtap="goToReviewSubmit" wx:else>
          去评价
        </view>
      </block>

      <block wx:elif="{{order.status === 60}}">
        <view class="footer-btn footer-btn-secondary" bindtap="goBack">返回列表</view>
        <view class="footer-btn footer-btn-primary" bindtap="viewAftersale" wx:if="{{activeAftersaleId}}">查看售后进度</view>
      </block>

      <block wx:else>
        <view class="footer-btn footer-btn-secondary" bindtap="goBack">返回列表</view>
      </block>
    </view>
  </block>
</view>

<pay-keyboard
  id="payKeyboard"
  show="{{showPayKeyboard}}"
  title="订单续付"
  amount-display="{{order.totalDisplay}}"
  loading="{{paying}}"
  bind:confirm="onPayConfirm"
  bind:close="closePayKeyboard"
/>
