<view class="detail-page">
  <nav-bar
    title="订单详情"
    showTitle="{{true}}"
    showBack="{{true}}"
    background="solid"
    dark="{{true}}"
    placeholder="{{true}}"
  />

  <view class="loading-wrap" wx:if="{{loading}}">
    <van-loading size="24px" color="#A12D27">加载中...</van-loading>
  </view>

  <block wx:if="{{!loading && order}}">
    <view class="status-stage">
      <view class="status-ticket {{ticketEntered ? 'ticket-entered' : 'ticket-entering'}} banner-{{order.status}} {{order.aftersale_result === 'refunded' ? 'banner-refunded' : ''}}">
        <view class="ticket-surface">
          <view class="ticket-upper">
            <view class="ticket-copy">
              <text class="ticket-title">
                {{order.statusText}}
              </text>
              <text class="ticket-desc">
                {{order.statusDesc}}
              </text>
              <view class="countdown-row" wx:if="{{order.status === 10 && countdown > 0}}">
                <van-icon name="clock-o" size="16" color="rgba(255,255,255,0.92)" />
                <text class="countdown-text">剩余支付时间 {{countdownDisplay}}</text>
              </view>
              <view class="countdown-row expired" wx:elif="{{order.status === 10 && countdown <= 0}}">
                <text class="countdown-text">支付超时，订单即将自动取消</text>
              </view>
            </view>
            <view class="ticket-side">
              <view class="ticket-amount-block">
                <text class="ticket-amount-label">实付</text>
                <view class="ticket-amount-line">
                  <text class="ticket-amount-currency">¥</text>
                  <text class="ticket-amount-value">{{order.totalDisplay}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="ticket-seam">
            <view class="ticket-notch ticket-notch-left"></view>
            <view class="ticket-dash"></view>
            <view class="ticket-notch ticket-notch-right"></view>
          </view>

          <view class="ticket-lower">
            <text class="ticket-order-caption">订单号</text>
            <text class="ticket-order-id">{{order._id}}</text>
          </view>
        </view>

        <view class="ticket-teeth">
          <view class="ticket-tooth" wx:for="{{ticketTeeth}}" wx:key="*this"></view>
        </view>
      </view>
    </view>

    <view class="content-wrap">
      <view class="panel panel-product">
        <view class="panel-head">
          <view class="panel-title-wrap">
            <text class="panel-index">01</text>
            <view class="panel-copy">
              <text class="panel-title">关联商品</text>
              <text class="panel-desc">{{order.product_snapshot.workshop_name || '湘韵遗珍文创商城'}}</text>
            </view>
          </view>
          <view class="panel-link" bindtap="goToProduct">
            <text>查看商品</text>
            <van-icon name="arrow" size="14" color="#B1A79C" />
          </view>
        </view>
        <view class="product-shell" bindtap="goToProduct">
          <image class="product-image" src="{{order.product_snapshot.sku_image || order.product_snapshot.cover_img}}" mode="aspectFill" />
          <view class="product-main">
            <text class="product-title">{{order.product_snapshot.title}}</text>
            <text class="product-sku" wx:if="{{order.product_snapshot.sku_name}}">款式：{{order.product_snapshot.sku_name}}</text>
            <view class="product-tags">
              <text class="product-tag product-tag-brand" wx:if="{{order.product_snapshot.related_project_name}}">{{order.product_snapshot.related_project_name}}</text>
              <text class="product-tag">{{order.product_snapshot.category || '文创好物'}}</text>
            </view>
          </view>
          <view class="product-side">
            <text class="product-price">¥{{order.productPriceDisplay}}</text>
            <text class="product-count">x {{order.quantity}}</text>
          </view>
        </view>
      </view>

      <view class="panel" wx:if="{{order.status !== 50}}">
        <view class="panel-head">
          <view class="panel-title-wrap">
            <text class="panel-index">02</text>
            <view class="panel-copy">
              <text class="panel-title">履约进度</text>
              <text class="panel-desc">订单从付款到完成的关键节点会记录在这里</text>
            </view>
          </view>
        </view>
        <view class="steps-shell">
          <view class="steps-row">
          <view class="step-item {{order.status >= 10 ? 'step-done' : ''}}">
            <view class="step-dot {{order.status === 10 ? 'dot-active' : order.status > 10 ? 'dot-done' : ''}}">
              <van-icon wx:if="{{order.status > 10}}" name="success" size="14" color="#fff" />
              <text wx:else class="dot-num">1</text>
            </view>
            <text class="step-label">待付款</text>
            <text class="step-time" wx:if="{{order.createTimeDisplay}}">{{order.createTimeDisplay}}</text>
          </view>
          <view class="step-line {{order.status > 10 ? 'line-done' : ''}}"></view>
          <view class="step-item {{order.status >= 20 ? 'step-done' : ''}}">
            <view class="step-dot {{order.status === 20 ? 'dot-active' : order.status > 20 ? 'dot-done' : ''}}">
              <van-icon wx:if="{{order.status > 20}}" name="success" size="14" color="#fff" />
              <text wx:else class="dot-num">2</text>
            </view>
            <text class="step-label">待发货</text>
            <text class="step-time" wx:if="{{order.payTimeDisplay}}">{{order.payTimeDisplay}}</text>
          </view>
          <view class="step-line {{order.status > 20 ? 'line-done' : ''}}"></view>
          <view class="step-item {{order.status >= 30 ? 'step-done' : ''}}">
            <view class="step-dot {{order.status === 30 ? 'dot-active' : order.status > 30 ? 'dot-done' : ''}}">
              <van-icon wx:if="{{order.status > 30}}" name="success" size="14" color="#fff" />
              <text wx:else class="dot-num">3</text>
            </view>
            <text class="step-label">已发货</text>
            <text class="step-time" wx:if="{{order.shipTimeDisplay}}">{{order.shipTimeDisplay}}</text>
          </view>
          <view class="step-line {{order.status > 30 ? 'line-done' : ''}}"></view>
          <view class="step-item {{order.status >= 40 ? 'step-done' : ''}}">
            <view class="step-dot {{order.status >= 40 ? 'dot-done' : ''}}">
              <van-icon wx:if="{{order.status >= 40}}" name="success" size="14" color="#fff" />
              <text wx:else class="dot-num">4</text>
            </view>
            <text class="step-label">已完成</text>
            <text class="step-time" wx:if="{{order.completeTimeDisplay}}">{{order.completeTimeDisplay}}</text>
          </view>
        </view>
        </view>
      </view>

      <view class="panel" wx:if="{{order.showLogisticsPanel}}">
        <view class="panel-head">
          <view class="panel-title-wrap">
            <text class="panel-index">03</text>
            <view class="panel-copy">
              <text class="panel-title">{{order.isPickupOrder ? '交付信息' : '物流信息'}}</text>
              <text class="panel-desc">{{order.isPickupOrder ? '该订单为同城自提，无需查询快递轨迹' : '当前包裹的发货与物流状态'}}</text>
            </view>
          </view>
          <view class="panel-link {{order.isPickupOrder ? 'is-disabled' : ''}}" bindtap="queryLogistics">
            <text>查看物流</text>
            <van-icon name="arrow" size="14" color="#B1A79C" />
          </view>
        </view>
        <view class="field-block logistics-shell">
          <view class="field-head">
            <text class="field-label">{{order.isPickupOrder ? '交付方式' : '物流单号'}}</text>
            <view class="inline-action" bindtap="copyTracking" wx:if="{{!order.isPickupOrder}}">
              <text>复制</text>
              <van-icon name="copy-o" size="14" color="#B1A79C" />
            </view>
          </view>
          <view class="logistics-main-row">
            <view class="logistics-badge {{order.isPickupOrder ? 'is-pickup' : ''}}">{{order.logisticsBadge}}</view>
            <text class="logistics-no" bindtap="copyTracking">{{order.logisticsText}}</text>
          </view>
          <text class="field-helper field-helper-filled">{{order.isPickupOrder ? '交付时间：' : '发货时间：'}}{{order.shipTimeDisplay}}</text>
        </view>
      </view>

      <view class="panel" wx:if="{{order.delivery_address}}">
        <view class="panel-head">
          <view class="panel-title-wrap">
            <text class="panel-index">04</text>
            <view class="panel-copy">
              <text class="panel-title">{{order.isPickupOrder ? '自提联系信息' : '收货地址'}}</text>
              <text class="panel-desc">{{order.isPickupOrder ? '商家会按这份联系人信息与买家约定同城自提交付' : '买家确认收货所使用的地址信息'}}</text>
            </view>
          </view>
        </view>
        <view class="field-block address-shell">
          <view class="address-user-row">
            <text class="address-name">{{order.delivery_address.userName}}</text>
            <text class="address-tel">{{order.delivery_address.telNumber}}</text>
          </view>
          <text class="address-detail">
            {{order.delivery_address.provinceName}}{{order.delivery_address.cityName}}{{order.delivery_address.countyName}} {{order.delivery_address.detailInfo}}
          </text>
        </view>
      </view>

      <view class="panel">
        <view class="panel-head">
          <view class="panel-title-wrap">
            <text class="panel-index">05</text>
            <view class="panel-copy">
              <text class="panel-title">订单信息</text>
              <text class="panel-desc">用于核对订单编号、支付与完成时间</text>
            </view>
          </view>
        </view>
        <view class="field-block info-grid-item">
          <view class="field-head">
            <text class="field-label">订单号</text>
          </view>
          <view class="grid-value-row" bindtap="copyOrderId">
            <text class="grid-value order-id-text">{{order._id}}</text>
            <van-icon name="copy-o" size="14" color="#B1A79C" />
          </view>
        </view>
        <view class="field-block info-stack-block">
          <view class="field-head">
            <text class="field-label">时间记录</text>
          </view>
          <view class="info-stack">
            <view class="info-stack-row">
              <text class="info-stack-label">下单时间</text>
              <text class="info-stack-value">{{order.createTimeDisplay}}</text>
            </view>
            <view class="info-stack-row" wx:if="{{order.payTimeDisplay}}">
              <text class="info-stack-label">支付时间</text>
              <text class="info-stack-value">{{order.payTimeDisplay}}</text>
            </view>
            <view class="info-stack-row" wx:if="{{order.completeTimeDisplay}}">
              <text class="info-stack-label">完成时间</text>
              <text class="info-stack-value">{{order.completeTimeDisplay}}</text>
            </view>
          </view>
        </view>
        <view class="field-block info-grid-item">
          <view class="field-head">
            <text class="field-label">实付金额</text>
          </view>
          <text class="grid-value price-val">¥{{order.totalDisplay}}</text>
        </view>
      </view>

      <view class="panel panel-warning" wx:if="{{aftersaleLog}}">
        <view class="panel-head">
          <view class="panel-title-wrap">
            <text class="panel-index">06</text>
            <view class="panel-copy">
              <text class="panel-title">售后记录</text>
              <text class="panel-desc">当前订单关联的最近一笔售后处理信息</text>
            </view>
          </view>
          <text class="panel-meta">{{aftersaleLog.statusText}}</text>
        </view>
        <view class="field-grid">
          <view class="field-block info-grid-item">
            <view class="field-head">
              <text class="field-label">类型</text>
            </view>
            <text class="grid-value">{{aftersaleLog.type}}</text>
          </view>
          <view class="field-block info-grid-item">
            <view class="field-head">
              <text class="field-label">退款金额</text>
            </view>
            <text class="grid-value price-val">¥{{aftersaleLog.refundDisplay}}</text>
          </view>
          <view class="field-block info-grid-item grid-span-full">
            <view class="field-head">
              <text class="field-label">原因</text>
            </view>
            <text class="grid-value">{{aftersaleLog.reason}}</text>
          </view>
        </view>
        <view class="timeline-shell" wx:if="{{aftersaleLog.operationLogs.length > 0}}">
          <view class="as-log-tl" wx:for="{{aftersaleLog.operationLogs}}" wx:key="index">
            <view class="as-tl-dot {{item.operator === 'seller' ? 'dot-red' : item.operator === 'system' ? 'dot-orange' : ''}}"></view>
            <view class="as-tl-content">
              <view class="as-tl-head">
                <text class="as-tl-role">{{item.operatorLabel}}</text>
                <text class="as-tl-time">{{item.timeDisplay}}</text>
              </view>
              <text class="as-tl-text">{{item.content}}</text>
            </view>
          </view>
        </view>
        <view class="select-block action-block" bindtap="viewAftersale" wx:if="{{activeAftersaleId}}">
          <view class="select-copy">
            <text class="field-label">查看完整售后详情</text>
          </view>
          <view class="select-value-wrap">
            <view class="select-value is-filled">进入详情</view>
            <van-icon class="select-arrow" name="arrow" size="16" color="#B1A79C" />
          </view>
        </view>
      </view>

      <view class="hint-card" wx:if="{{canApplyAftersale}}">
        <van-icon name="shield-o" size="18" color="#ff9500" />
        <text class="as-hint-text">售后保障中，截止 {{aftersaleDeadlineDisplay}}</text>
      </view>
    </view>

    <view class="detail-footer">
      <block wx:if="{{order.status === 10}}">
        <view class="footer-btn footer-btn-secondary" bindtap="cancelOrder">取消订单</view>
        <view class="footer-btn footer-btn-primary" bindtap="payOrder">立即支付</view>
      </block>

      <block wx:elif="{{order.status === 30}}">
        <view class="footer-btn footer-btn-secondary {{order.isPickupOrder ? 'is-disabled' : ''}}" bindtap="queryLogistics">查看物流</view>
        <view class="footer-btn footer-btn-primary" bindtap="confirmReceipt">确认收货</view>
      </block>

      <block wx:elif="{{order.status === 40 && order.has_aftersale}}">
        <view class="footer-btn footer-btn-secondary {{order.isPickupOrder ? 'is-disabled' : ''}}" bindtap="queryLogistics" wx:if="{{order.showLogisticsAction}}">查看物流</view>
        <view class="footer-btn footer-btn-primary" bindtap="viewAftersale" wx:if="{{activeAftersaleId}}">查看售后进度</view>
        <view class="footer-btn footer-btn-secondary" bindtap="goBack" wx:if="{{!order.showLogisticsAction && !activeAftersaleId}}">返回列表</view>
      </block>

      <block wx:elif="{{order.status === 40}}">
        <view class="footer-btn footer-btn-secondary {{order.isPickupOrder ? 'is-disabled' : ''}}" bindtap="queryLogistics" wx:if="{{order.showLogisticsAction}}">查看物流</view>
        <view class="footer-btn footer-btn-warning" bindtap="applyAftersale" wx:if="{{canApplyAftersale}}">
          {{aftersaleLog ? '重新申请售后' : '申请售后'}}
        </view>
        <view class="footer-btn footer-btn-primary" bindtap="goToReviewDetail" wx:if="{{order.reviewStatus === 1}}">
          我的评价
        </view>
        <view class="footer-btn footer-btn-primary" bindtap="goToReviewSubmit" wx:else>
          去评价
        </view>
      </block>

      <block wx:elif="{{order.status === 60}}">
        <view class="footer-btn footer-btn-secondary" bindtap="goBack">返回列表</view>
        <view class="footer-btn footer-btn-primary" bindtap="viewAftersale" wx:if="{{activeAftersaleId}}">查看售后进度</view>
      </block>

      <block wx:else>
        <view class="footer-btn footer-btn-secondary" bindtap="goBack">返回列表</view>
      </block>
    </view>
  </block>
</view>

<pay-keyboard
  id="payKeyboard"
  show="{{showPayKeyboard}}"
  title="订单续付"
  amount-display="{{order.totalDisplay}}"
  loading="{{paying}}"
  bind:confirm="onPayConfirm"
  bind:close="closePayKeyboard"
/>
