.detail-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #faf7f0 0%, #f3ede3 46%, #ebe1d2 100%);
  padding-bottom: 160rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.status-stage {
  position: relative;
  background: #f3ede3;
  padding: 0 22rpx 38rpx;
}

.status-ticket {
  position: relative;
  overflow: visible;
  z-index: 1;
  transition:
    transform 520ms cubic-bezier(0.2, 0.82, 0.24, 1),
    opacity 420ms ease,
    filter 520ms cubic-bezier(0.2, 0.82, 0.24, 1);
  transform-origin: top center;
  will-change: transform, opacity;
}

.ticket-entering {
  opacity: 0;
  transform: translateY(-56rpx) scale(0.985);
  filter: saturate(0.94);
}

.ticket-entered {
  opacity: 1;
  transform: translateY(0) scale(1);
  filter: saturate(1);
}

.ticket-surface,
.ticket-teeth {
  position: relative;
  z-index: 1;
}

.ticket-surface {
  overflow: hidden;
  box-shadow:
    0 18rpx 34rpx rgba(74, 58, 42, 0.16),
    0 28rpx 52rpx rgba(74, 58, 42, 0.08);
}

.status-ticket.banner-10 .ticket-surface {
  background: #ff5a57;
}

.status-ticket.banner-20 .ticket-surface {
  background: #ffac33;
}

.status-ticket.banner-30 .ticket-surface {
  background: #3a9fff;
}

.status-ticket.banner-40 .ticket-surface,
.status-ticket.banner-refunded .ticket-surface {
  background: #2fcd97;
}

.status-ticket.banner-50 .ticket-surface {
  background: #c5c5c5;
}

.status-ticket.banner-60 .ticket-surface {
  background: #9d7a57;
}

.ticket-upper {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx 30rpx 24rpx;
}

.ticket-copy {
  flex: 1;
  min-width: 0;
  padding-top: 10rpx;
}

.ticket-side {
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  flex-shrink: 0;
  min-width: 188rpx;
  padding-top: 10rpx;
}

.ticket-title {
  display: block;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: #ffffff;
}

.ticket-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.85);
}

.ticket-amount-block {
  position: relative;
  padding-top: 24rpx;
  text-align: right;
}

.ticket-amount-label {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 22rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.72);
  letter-spacing: 2rpx;
}

.ticket-amount-line {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  margin-top: 10rpx;
}

.ticket-amount-currency {
  font-size: 26rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
  margin-right: 4rpx;
}

.ticket-amount-value {
  display: block;
  font-size: 48rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
  font-family: Georgia, "Times New Roman", serif;
}

.countdown-row {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 14rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
}

.countdown-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 600;
}

.countdown-row.expired .countdown-text {
  color: rgba(255, 255, 255, 0.78);
}

.ticket-seam {
  position: relative;
  height: 34rpx;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.ticket-seam::before,
.ticket-seam::after {
  content: '';
  position: absolute;
  top: 0;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #f3ede3;
  z-index: 2;
}

.ticket-seam::before {
  left: -17rpx;
}

.ticket-seam::after {
  right: -17rpx;
}

.ticket-dash {
  position: relative;
  z-index: 1;
  flex: 1;
  height: 4rpx;
  margin: 0 18rpx;
  background: repeating-linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.88) 0 18rpx,
    rgba(255, 255, 255, 0) 18rpx 34rpx
  );
  opacity: 0.95;
}

.ticket-notch {
  display: none;
}

.ticket-lower {
  padding: 6rpx 30rpx 14rpx;
  text-align: center;
}

.ticket-order-caption {
  display: block;
  font-size: 20rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.72);
  letter-spacing: 8rpx;
  text-indent: 8rpx;
}

.ticket-order-id {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 2rpx;
  word-break: break-all;
}

.ticket-teeth {
  display: flex;
  align-items: flex-start;
  height: 22rpx;
  margin-top: -1rpx;
  padding: 0 2rpx;
  overflow: hidden;
  line-height: 0;
  font-size: 0;
}

.ticket-tooth {
  flex: 1 1 0;
  height: 22rpx;
  margin-left: -1rpx;
  -webkit-clip-path: polygon(0 0, 100% 0, 50% 100%);
  clip-path: polygon(0 0, 100% 0, 50% 100%);
}

.ticket-tooth:first-child {
  margin-left: 0;
}

.status-ticket.banner-10 .ticket-tooth {
  background: #ff5a57;
}

.status-ticket.banner-20 .ticket-tooth {
  background: #ffac33;
}

.status-ticket.banner-30 .ticket-tooth {
  background: #3a9fff;
}

.status-ticket.banner-40 .ticket-tooth,
.status-ticket.banner-refunded .ticket-tooth {
  background: #2fcd97;
}

.status-ticket.banner-50 .ticket-tooth {
  background: #c5c5c5;
}

.status-ticket.banner-60 .ticket-tooth {
  background: #9d7a57;
}

.content-wrap {
  padding: 22rpx 24rpx 0;
}

.panel {
  margin-bottom: 24rpx;
  padding: 26rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow:
    0 14rpx 34rpx rgba(66, 48, 34, 0.05),
    0 1rpx 0 rgba(255, 255, 255, 0.85) inset;
}

.panel-product {
  background: linear-gradient(180deg, rgba(255, 250, 247, 0.98) 0%, rgba(255, 255, 255, 0.94) 100%);
}

.panel-warning {
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.98) 0%, rgba(255, 255, 255, 0.94) 100%);
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.panel-title-wrap {
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.panel-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: #f7eee8;
  color: #b63b36;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
  flex-shrink: 0;
}

.panel-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.panel-title {
  font-size: 30rpx;
  line-height: 1.2;
  color: #2c231e;
  font-weight: 700;
}

.panel-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #9b8e83;
}

.panel-meta {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f7f2ed;
  color: #8a7a6e;
  font-size: 20rpx;
  line-height: 1;
}

.panel-link {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f7f2ed;
  color: #8a7a6e;
  font-size: 20rpx;
  line-height: 1;
}

.panel-link.is-disabled {
  color: #B6ABA0;
  background: #F3EEE8;
}

.product-shell {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fbfaf8;
  border: 1rpx solid rgba(125, 100, 81, 0.08);
}

.product-image {
  width: 166rpx;
  height: 166rpx;
  border-radius: 22rpx;
  background: #ede4db;
  flex-shrink: 0;
}

.product-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.product-title {
  font-size: 28rpx;
  line-height: 1.45;
  color: #2d241f;
  font-weight: 700;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-sku {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #94877b;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.product-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f5f2ee;
  font-size: 20rpx;
  line-height: 1;
  color: #7c7066;
}

.product-tag-brand {
  background: linear-gradient(135deg, rgba(182, 59, 54, 0.12) 0%, rgba(212, 87, 79, 0.18) 100%);
  color: #b63b36;
}

.product-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
}

.product-price {
  font-size: 34rpx;
  line-height: 1;
  color: #9f2b24;
  font-weight: 700;
}

.product-count {
  font-size: 22rpx;
  color: #9f9489;
}

.field-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx 14rpx;
  margin-top: 22rpx;
}

.field-block,
.select-block {
  margin-top: 22rpx;
  padding: 22rpx 22rpx 18rpx;
  border-radius: 22rpx;
  background: #fbfaf8;
  border: 1rpx solid rgba(125, 100, 81, 0.06);
}

.field-grid .field-block,
.field-grid .select-block {
  margin-top: 0;
}

.field-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.field-label {
  font-size: 24rpx;
  line-height: 1.2;
  color: #5b5048;
  font-weight: 600;
}

.field-helper {
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #aaa095;
}

.field-helper-filled {
  color: #8d7f73;
}

.steps-shell {
  margin-top: 22rpx;
  padding: 24rpx 20rpx 18rpx;
  border-radius: 24rpx;
  background: #fbfaf8;
  border: 1rpx solid rgba(125, 100, 81, 0.08);
}

.steps-row {
  display: flex;
  align-items: flex-start;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 0 0 60rpx;
  gap: 8rpx;
}

.step-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #e0d6c8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dot-active {
  background: #8b2e2a;
  box-shadow: 0 0 0 6rpx rgba(139, 46, 42, 0.15);
}

.dot-done {
  background: #10b981;
}

.dot-num {
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
}

.step-label {
  font-size: 22rpx;
  color: #333333;
  text-align: center;
  white-space: nowrap;
}

.step-time {
  font-size: 18rpx;
  color: #aaa;
  text-align: center;
  line-height: 1.3;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #e0d6c8;
  margin-top: 16rpx;
  border-radius: 2rpx;
}

.line-done {
  background: #10b981;
}

.logistics-shell {
  margin-top: 22rpx;
}

.logistics-main-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
}

.logistics-badge {
  background: #e8f4ff;
  color: #1989fa;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.logistics-no {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #333333;
  font-family: monospace;
}

.inline-action {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 20rpx;
  line-height: 1;
  color: #8a7a6e;
}

.address-shell {
  margin-top: 22rpx;
}

.address-user-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.address-tel {
  font-size: 26rpx;
  color: #666666;
}

.address-detail {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #7f7369;
}

.info-grid-item {
  min-width: 0;
}

.grid-span-full {
  grid-column: 1 / -1;
}

.grid-value {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #342d28;
  font-weight: 600;
}

.grid-value-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.info-stack-block {
  margin-top: 16rpx;
}

.info-stack {
  margin-top: 14rpx;
}

.info-stack-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 14rpx 0;
}

.info-stack-row + .info-stack-row {
  border-top: 1rpx solid rgba(125, 100, 81, 0.08);
}

.info-stack-label {
  font-size: 24rpx;
  line-height: 1.4;
  color: #8d8074;
  flex-shrink: 0;
}

.logistics-badge.is-pickup {
  background: #F7EEE5;
  color: #9C7F63;
}

.info-stack-value {
  min-width: 0;
  font-size: 26rpx;
  line-height: 1.45;
  color: #342d28;
  font-weight: 600;
  text-align: right;
}

.price-val {
  color: #9f2b24;
}

.order-id-text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.timeline-shell {
  margin-top: 22rpx;
  padding: 12rpx 18rpx;
  border-radius: 24rpx;
  background: #fbfaf8;
  border: 1rpx solid rgba(125, 100, 81, 0.08);
}

.as-log-tl {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 0;
}

.as-tl-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #1989fa;
  flex-shrink: 0;
  margin-top: 10rpx;
}

.as-tl-dot.dot-red {
  background: #8b2e2a;
}

.as-tl-dot.dot-orange {
  background: #ff9500;
}

.as-tl-content {
  flex: 1;
}

.as-tl-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.as-tl-role {
  font-size: 22rpx;
  font-weight: 600;
  color: #8b6f47;
}

.as-tl-time {
  font-size: 20rpx;
  color: #bbb;
}

.as-tl-text {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #666666;
}

.select-block {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.select-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.select-value-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  min-width: 0;
  align-self: center;
  min-height: 40rpx;
}

.select-value {
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  font-size: 26rpx;
  color: #beb4ab;
  line-height: 40rpx;
  text-align: right;
}

.select-value.is-filled {
  color: #2c231e;
}

.select-arrow {
  height: 40rpx;
  display: flex;
  align-items: center;
}

.action-block {
  margin-top: 18rpx;
}

.hint-card {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: -2rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #fff4f3;
}

.as-hint-text {
  font-size: 22rpx;
  line-height: 1.6;
  color: #b63b36;
}

.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 -6rpx 24rpx rgba(92, 79, 66, 0.08);
}

.footer-btn {
  min-width: 168rpx;
  height: 68rpx;
  padding: 0 30rpx;
  border-radius: 34rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid transparent;
  background: rgba(255, 255, 255, 0.92);
  transition:
    transform 0.18s ease,
    box-shadow 0.18s ease,
    border-color 0.18s ease,
    color 0.18s ease;
}

.footer-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 14rpx rgba(92, 79, 66, 0.06);
}

.footer-btn-secondary {
  color: #5f5249;
  border: 1rpx solid rgba(129, 107, 89, 0.24);
}

.footer-btn-primary {
  color: #b63b36;
  border-color: rgba(182, 59, 54, 0.56);
}

.footer-btn.is-disabled {
  color: #B6ABA0;
  border-color: rgba(182, 171, 160, 0.46);
  background: rgba(250, 247, 243, 0.98);
}

.footer-btn.is-disabled:active {
  transform: none;
  box-shadow: none;
}

.footer-btn-warning {
  color: #c27a20;
  border-color: rgba(194, 122, 32, 0.52);
}
