/* pages/order/list.wxss */

.order-list-page {
  min-height: 100vh;
  background: #f6f0e8;
  padding-bottom: 40rpx;
}

.order-tabs {
  position: sticky;
  top: 0;
  z-index: 100;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

/* ===== 订单卡片 ===== */
.orders-wrap {
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f0e8;
  margin-bottom: 16rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.shop-name {
  font-size: 26rpx;
  color: #8B6F47;
  font-weight: 600;
}

/* 状态文字样式 */
.order-status-text {
  font-size: 26rpx;
  font-weight: 600;
}

.status-pending-pay { color: #ee0a24; }
.status-pending-ship { color: #ff9500; }
.status-shipped { color: #1989fa; }
.status-done { color: #10b981; }
.status-cancelled { color: #999; }
.status-aftersale { color: #8B6F47; }
.status-refunded { color: #10b981; }

/* 商品信息行 */
.product-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.product-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.product-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.product-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #8B2E2A;
}

.product-qty {
  font-size: 26rpx;
  color: #999;
}

/* 总计行 */
.total-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  padding: 12rpx 0;
  border-top: 1rpx solid #f5f0e8;
}

.total-label {
  font-size: 24rpx;
  color: #999;
}

.total-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #8B2E2A;
}

/* 待付款倒计时提示 */
.countdown-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 0;
  border-top: 1rpx solid #fff5f5;
  background: #fff8f8;
  margin: 0 -24rpx;
  padding-left: 24rpx;
}

.countdown-tip-text {
  font-size: 24rpx;
  color: #ee0a24;
  font-weight: 500;
}

/* 物流行 */
.logistics-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 0;
  border-top: 1rpx solid #f5f0e8;
}

.logistics-text {
  font-size: 24rpx;
  color: #666;
}

/* 操作按钮区 */
.card-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f0e8;
  margin-top: 8rpx;
}

/* 底部加载更多 */
.load-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

.load-more {
  color: #8B6F47;
}
