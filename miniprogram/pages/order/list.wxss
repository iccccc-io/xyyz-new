.order-list-page {
  min-height: 100vh;
  background: linear-gradient(175deg, #faf7f0 0%, #f2ece0 52%, #e9e0d0 100%);
  padding-bottom: 40rpx;
}

.order-top-shell {
  position: sticky;
  top: 0;
  z-index: 120;
  background: rgba(250, 246, 238, 0.96);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border-bottom: 1rpx solid rgba(182, 59, 54, 0.08);
  box-shadow: 0 10rpx 26rpx rgba(92, 79, 66, 0.06);
}

.toolbar-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx 12rpx;
  background: transparent;
}

.toolbar-search {
  flex: 1;
  height: 72rpx;
  padding: 0 12rpx 0 22rpx;
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow:
    0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.toolbar-input {
  flex: 1;
  min-width: 0;
  height: 100%;
  font-size: 26rpx;
  color: #4B4038;
}

.toolbar-placeholder {
  font-size: 26rpx;
  color: #b7b1aa;
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.toolbar-filter {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 36rpx;
  background: #ffffff;
  border: 1rpx solid rgba(161, 45, 39, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  display: flex;
  align-items: center;
  justify-content: center;
  transition:
    transform 0.18s ease,
    box-shadow 0.2s ease;
  position: relative;
}

.toolbar-filter:active {
  transform: scale(0.96);
}

.toolbar-filter.is-open,
.toolbar-filter.is-active {
  background: #fff7f1;
  border-color: rgba(161, 45, 39, 0.18);
}

.toolbar-filter.is-breathing {
  animation: filterBreath 0.9s ease;
}

@keyframes filterBreath {
  0% {
    transform: scale(1);
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  }

  35% {
    transform: scale(0.92);
  }

  68% {
    transform: scale(1.06);
    box-shadow: 0 10rpx 24rpx rgba(161, 45, 39, 0.14);
  }

  100% {
    transform: scale(1);
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  }
}

.filter-active-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #a12d27;
  box-shadow: 0 0 0 4rpx rgba(161, 45, 39, 0.12);
}

.search-action {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #f7efe8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tabs-sticky {
  background: transparent;
  border-top: 1rpx solid rgba(182, 59, 54, 0.06);
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-row {
  display: inline-flex;
  align-items: center;
  padding: 0 18rpx 4rpx;
}

.tab-item {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  padding: 18rpx 14rpx 12rpx;
  transition: transform 0.18s ease;
}

.tab-item:active {
  transform: scale(0.98);
}

.tab-text {
  font-size: 28rpx;
  line-height: 1.3;
  color: #8a7f72;
  font-weight: 500;
  white-space: nowrap;
  transition:
    color 0.2s ease,
    font-weight 0.2s ease,
    transform 0.2s ease;
}

.tab-active .tab-text {
  color: #b63b36;
  font-weight: 700;
  transform: translateY(-1rpx);
}

.tab-ink {
  width: 34rpx;
  height: 6rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #b63b36 0%, #c7685c 100%);
  box-shadow: 0 2rpx 10rpx rgba(182, 59, 54, 0.28);
  animation: tabInkPop 0.2s ease both;
}

.time-filter-drawer {
  overflow: hidden;
  max-height: 0;
  opacity: 0;
  transform: translateY(-12rpx);
  pointer-events: none;
  transition:
    max-height 0.32s ease,
    opacity 0.2s ease,
    transform 0.28s ease;
}

.time-filter-drawer.is-open {
  max-height: 960rpx;
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.time-filter-inner {
  margin: 4rpx 24rpx 18rpx;
  padding: 22rpx 20rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(182, 59, 54, 0.08);
  box-shadow: 0 8rpx 24rpx rgba(92, 79, 66, 0.06);
}

.drawer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.drawer-title {
  font-size: 26rpx;
  color: #3d3530;
  font-weight: 700;
}

.drawer-summary {
  flex-shrink: 0;
  max-width: 60%;
  font-size: 22rpx;
  line-height: 1.4;
  color: #9a8c7c;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.drawer-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.drawer-chip-row-secondary {
  margin-top: 14rpx;
}

.drawer-chip {
  min-width: 112rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  background: #f7f1e8;
  color: #7b6e62;
  font-size: 24rpx;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition:
    transform 0.18s ease,
    background 0.18s ease,
    color 0.18s ease;
}

.drawer-chip:active {
  transform: scale(0.97);
}

.drawer-chip.is-active {
  background: #a12d27;
  color: #ffffff;
}

.drawer-chip-secondary {
  min-width: 144rpx;
}

.picker-group,
.picker-grid {
  margin-top: 18rpx;
}

.picker-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.picker-card {
  min-height: 108rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  background: #fffaf4;
  border: 1rpx solid rgba(182, 59, 54, 0.08);
  box-sizing: border-box;
}

.picker-label {
  display: block;
  font-size: 22rpx;
  color: #9a8c7c;
  line-height: 1.3;
}

.picker-value-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.picker-value {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #3d3530;
  font-weight: 600;
  line-height: 1.35;
}

.drawer-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 20rpx;
}

.drawer-btn {
  flex: 1;
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.drawer-btn-reset {
  background: #f5eee7;
  color: #7a6b60;
}

.drawer-btn-apply {
  background: #a12d27;
  color: #ffffff;
}

@keyframes tabInkPop {
  from {
    opacity: 0;
    transform: scaleX(0.5);
  }

  to {
    opacity: 1;
    transform: scaleX(1);
  }
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 56vh;
}

.empty-action {
  margin-top: 28rpx;
  min-width: 260rpx;
  height: 92rpx;
  padding: 0 38rpx;
  border-radius: 46rpx;
  border: 2rpx solid rgba(198, 140, 105, 0.72);
  background: rgba(255, 252, 247, 0.74);
  color: #a65d3d;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 26rpx rgba(141, 102, 73, 0.08);
  transition:
    transform 0.18s ease,
    box-shadow 0.18s ease,
    background 0.18s ease;
}

.empty-action:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 18rpx rgba(141, 102, 73, 0.06);
  background: rgba(255, 249, 242, 0.94);
}

.empty-action-text {
  line-height: 1;
}

.orders-wrap {
  padding: 20rpx 20rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.orders-wrap.is-switching {
  opacity: 0.92;
}

.order-card {
  border-radius: 22rpx;
  padding: 22rpx 22rpx 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  animation: cardRise 0.36s ease both;
}

@keyframes cardRise {
  from {
    opacity: 0;
    transform: translateY(12rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.shop-block {
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.shop-icon-wrap {
  width: 24rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.shop-text-wrap {
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.shop-name {
  min-width: 0;
  height: 32rpx;
  font-size: 28rpx;
  line-height: 32rpx;
  color: #333333;
  font-weight: 600;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shop-arrow {
  height: 32rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #b3b3b3;
  flex-shrink: 0;
}

.status-text {
  align-self: flex-start;
  flex-shrink: 0;
  height: 32rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 600;
}

.status-pending-pay,
.status-pending-ship,
.status-shipped,
.status-aftersale {
  color: #e1251b;
}

.status-done,
.status-refunded,
.status-cancelled {
  color: #8c8c8c;
}

.product-panel {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.product-img {
  width: 152rpx;
  height: 152rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f2f2f2;
}

.product-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.product-title {
  font-size: 30rpx;
  line-height: 1.42;
  color: #333333;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.mini-tag {
  display: inline-flex;
  align-items: center;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  line-height: 1;
}

.mini-tag.heritage {
  background: #fff3f2;
  color: #e1251b;
}

.mini-tag.neutral {
  background: #f5f5f5;
  color: #777777;
}

.product-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #999999;
}

.product-side {
  width: 124rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.product-side-price-group {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 2rpx;
  width: 100%;
  color: #1f1f1f;
}

.side-symbol {
  font-size: 22rpx;
  font-weight: 600;
}

.product-price {
  font-size: 36rpx;
  line-height: 1;
  font-weight: 700;
}

.product-qty {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #8c8c8c;
}

.countdown-strip,
.logistics-strip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 14rpx;
}

.countdown-strip {
  animation: countdownPulse 2.2s ease-in-out infinite;
}

@keyframes countdownPulse {
  0%,
  100% {
    opacity: 1;
  }

  50% {
    opacity: 0.76;
  }
}

.countdown-text,
.logistics-text {
  font-size: 22rpx;
  line-height: 1.45;
}

.countdown-text {
  color: #e1251b;
}

.logistics-text {
  color: #8c8c8c;
}

.logistics-strip.is-pickup .logistics-text {
  color: #9C7F63;
}

.summary-bar {
  margin-top: 16rpx;
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 8rpx;
}

.summary-text {
  font-size: 24rpx;
  color: #666666;
}

.summary-price-group {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
  color: #1f1f1f;
}

.summary-symbol {
  font-size: 22rpx;
  font-weight: 700;
}

.summary-price {
  font-size: 38rpx;
  line-height: 1;
  font-weight: 700;
}

.card-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.action-note {
  margin-right: auto;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.45;
  color: #999999;
}

.action-btn {
  min-width: 164rpx;
  height: 64rpx;
  padding: 0 30rpx;
  border-radius: 32rpx;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.92);
  transition:
    transform 0.18s ease,
    box-shadow 0.18s ease,
    border-color 0.18s ease,
    color 0.18s ease;
}

.action-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 14rpx rgba(92, 79, 66, 0.06);
}

.action-btn.subtle {
  color: #5f5249;
  border: 1rpx solid rgba(129, 107, 89, 0.24);
}

.action-btn.primary {
  color: #b63b36;
  border: 1rpx solid rgba(182, 59, 54, 0.56);
}

.action-btn.is-disabled {
  color: #B6ABA0;
  border-color: rgba(182, 171, 160, 0.46);
  background: rgba(250, 247, 243, 0.98);
}

.action-btn.is-disabled:active {
  transform: none;
  box-shadow: none;
}

.load-more,
.no-more {
  text-align: center;
  padding: 28rpx 0 10rpx;
  font-size: 24rpx;
  color: #999999;
}

.load-more {
  color: #666666;
}
