<!-- 自定义导航栏 -->
<nav-bar
  title="{{projectData.name || '项目详情'}}"
  showTitle="{{showNavTitle}}"
  background="{{showNavTitle ? 'solid' : 'transparent'}}"
  dark="{{showNavTitle}}"
  placeholder="{{false}}"
/>

<view class="detail-container">
  <!-- 加载状态 -->
  <view class="loading-wrapper" wx:if="{{loading}}">
    <van-loading type="spinner" color="#b63b36" size="40">加载中...</van-loading>
  </view>

  <!-- 空状态 -->
  <van-empty wx:if="{{!loading && !projectData}}" description="项目不存在" />

  <block wx:if="{{projectData}}">
    <!-- 封面图 -->
    <view class="hero-cover" bindtap="previewCover">
      <image class="cover-img" src="{{projectData.cover}}" mode="aspectFill" />
      <view class="cover-gradient"></view>
      <view class="cover-title-area">
        <text class="cover-name">{{projectData.name}}</text>
      </view>
    </view>

    <!-- 基本信息卡片 -->
    <view class="info-card">
      <view class="tags-row">
        <van-tag type="danger" size="large" plain>{{projectData.level}}</van-tag>
        <van-tag color="#8b6f47" size="large" plain>{{projectData.category}}</van-tag>
        <van-tag wx:if="{{projectData.batch}}" color="#52c41a" size="large" plain>{{projectData.batch}}</van-tag>
      </view>
      <view class="meta-row" wx:if="{{projectData.city}}">
        <van-icon name="location-o" size="14" color="#999" />
        <text class="meta-value">{{projectData.city}}</text>
      </view>
    </view>

    <!-- 视频区 -->
    <view class="section-card" wx:if="{{projectData.video && projectData.video.url}}">
      <view class="section-header">
        <view class="section-bar"></view>
        <text>相关视频</text>
      </view>
      <view class="video-wrapper">
        <video
          class="video-player"
          src="{{projectData.video.url}}"
          title="{{projectData.video.name || ''}}"
          controls
          show-center-play-btn
          show-fullscreen-btn
          object-fit="contain"
        />
      </view>
      <view class="video-name" wx:if="{{projectData.video.name}}">{{projectData.video.name}}</view>
    </view>

    <!-- 项目简介 (富文本) -->
    <view class="section-card" wx:if="{{projectData._processedContent}}">
      <view class="section-header">
        <view class="section-bar"></view>
        <text>项目简介</text>
      </view>
      <view class="rich-content">
        <rich-text nodes="{{projectData._processedContent}}"></rich-text>
      </view>
    </view>

    <!-- 代表性传承人 -->
    <view class="section-card" wx:if="{{inheritorList.length > 0}}">
      <view class="section-header">
        <view class="section-bar"></view>
        <text>代表性传承人</text>
        <text class="section-count">{{inheritorList.length}}位</text>
      </view>
      <view class="inheritor-grid">
        <view class="inheritor-item"
          wx:for="{{inheritorList}}" wx:key="inheritor_id"
          bindtap="goToInheritor" data-id="{{item.inheritor_id}}">
          <image class="inheritor-avatar" src="{{item.cover}}" mode="aspectFill" />
          <view class="inheritor-name">{{item.name}}</view>
          <view class="inheritor-level">{{item.level}}</view>
        </view>
      </view>
    </view>

    <!-- 相关资讯 -->
    <view class="section-card" wx:if="{{newsList.length > 0}}">
      <view class="section-header">
        <view class="section-bar"></view>
        <text>相关资讯</text>
      </view>
      <view class="news-list">
        <view class="news-item"
          wx:for="{{newsList}}" wx:key="news_id"
          bindtap="goToNews" data-id="{{item.news_id}}">
          <view class="news-content">
            <view class="news-title">{{item.title}}</view>
            <van-tag plain color="{{item.category === '非遗快讯' ? '#1989fa' : '#8b6f47'}}" size="medium">{{item.category}}</van-tag>
          </view>
          <van-icon name="arrow" size="14" color="#ccc" />
        </view>
      </view>
    </view>

    <!-- 底部安全区 -->
    <view class="safe-bottom"></view>
  </block>
</view>
