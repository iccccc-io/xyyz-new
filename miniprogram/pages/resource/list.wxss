page {
  background-color: #f7f5f1;
  height: 100vh;
}

.resource-container {
  width: 100%;
  min-height: 100vh;
  background-color: #f7f5f1;
}

/* ========== 顶部固定区域 ========== */
.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #f7f5f1;
}

.status-bar {
  background-color: #f7f5f1;
}

.nav-row {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  background-color: #f7f5f1;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.04);
}

.back-btn:active {
  background: rgba(0, 0, 0, 0.08);
}

.page-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.nav-placeholder {
  width: 60rpx;
}

/* ========== Tabs ========== */
.tabs-bar {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  margin: 0 30rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
  position: relative;
}

.tab-item.active {
  background: linear-gradient(135deg, #b63b36 0%, #8b2e2a 100%);
  color: #fff;
  font-weight: bold;
}

/* ========== 搜索栏 ========== */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx 0;
}

.filter-icon {
  margin-left: 16rpx;
  padding: 16rpx;
  background-color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(139, 111, 71, 0.1);
  flex-shrink: 0;
}

/* ========== 资讯分类子标签 ========== */
.news-category-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 30rpx 8rpx;
}

.news-cat-item {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  transition: all 0.3s;
}

.news-cat-item.active {
  background: linear-gradient(135deg, #b63b36 0%, #8b2e2a 100%);
  color: #fff;
  font-weight: bold;
}

/* ========== 列表内容区 ========== */
.list-content {
  padding: 20rpx 30rpx;
  padding-bottom: 40rpx;
}

/* ========== 项目卡片 ========== */
.project-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.project-card:active {
  transform: scale(0.98);
}

.project-cover {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  background: #eee;
}

.project-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.project-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.project-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.project-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
  margin-left: 6rpx;
}

/* ========== 传承人卡片 ========== */
.inheritor-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.inheritor-card:active {
  transform: scale(0.98);
}

.inheritor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #eee;
  border: 4rpx solid #f0e6d6;
}

.inheritor-info {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

.inheritor-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.inheritor-level {
  font-size: 26rpx;
  color: #8b6f47;
  margin-bottom: 6rpx;
}

.inheritor-project {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 资讯卡片 ========== */
.news-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.news-card:active {
  transform: scale(0.98);
}

.news-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.news-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.news-related {
  font-size: 22rpx;
  color: #999;
}

/* ========== 空/加载/到底 ========== */
.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.loading-state {
  padding: 60rpx 0;
  text-align: center;
}

.no-more {
  padding: 40rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
}

/* ========== 筛选弹窗 ========== */
.filter-popup {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #fafaf8;
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background-color: #fff;
  border-bottom: 2rpx solid #f0f0f0;
}

.filter-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.filter-body {
  flex: 1;
  padding: 20rpx 0;
}

.filter-section {
  margin-bottom: 10rpx;
  background-color: #fff;
  padding: 28rpx 32rpx;
}

.filter-section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 14rpx 28rpx;
  background-color: #f7f5f1;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.filter-option.active {
  background-color: #fff5f0;
  color: #b63b36;
  border-color: #b63b36;
  font-weight: bold;
}

.filter-footer {
  display: flex;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 2rpx solid #f0f0f0;
  gap: 20rpx;
}

.filter-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.reset-btn {
  background-color: #f7f5f1;
  color: #666;
  border: 2rpx solid #e5e5e5;
}

.confirm-btn {
  background: linear-gradient(135deg, #b63b36 0%, #8b2e2a 100%);
  color: #fff;
}
