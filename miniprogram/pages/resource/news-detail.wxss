page {
  background-color: #f7f5f1;
  min-height: 100vh;
}

.detail-container {
  min-height: 100vh;
  background-color: #f7f5f1;
}

/* ========== 封面图 ========== */
.cover-wrap {
  position: relative;
  width: 100%;
}

.cover-img {
  width: 100%;
  height: 480rpx;
  display: block;
  background: #e8e0d4;
}

.cover-category-badge {
  position: absolute;
  bottom: 24rpx;
  right: 28rpx;
  background: rgba(139, 111, 71, 0.88);
  color: #fff;
  font-size: 22rpx;
  font-weight: 500;
  padding: 6rpx 20rpx;
  border-radius: 32rpx;
  letter-spacing: 2rpx;
  backdrop-filter: blur(4px);
}

/* ========== 文章头部 ========== */
.article-header {
  background: #fff;
  padding: 32rpx 36rpx 0;
}

/* 无封面时的分类标签 */
.category-inline {
  display: inline-flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.category-text {
  font-size: 22rpx;
  color: #8b6f47;
  background: #f5ece0;
  border: 1rpx solid #ddc8a8;
  border-radius: 32rpx;
  padding: 5rpx 20rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 标题 */
.article-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1e1810;
  line-height: 1.55;
  letter-spacing: 1rpx;
  margin-bottom: 24rpx;
}

/* 元信息行 */
.meta-bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #a89878;
}

.meta-dot {
  font-size: 24rpx;
  color: #d4c8b8;
}

/* 头部与正文之间的虚线分隔 */
.header-divider {
  border-top: 2rpx dashed #e0d8cc;
  margin: 8rpx 0 0;
}

/* ========== 文章正文 ========== */
.article-body {
  background: #fff;
  padding: 36rpx 36rpx 48rpx;
  font-size: 30rpx;
  color: #2c2318;
  line-height: 1.9;
  word-break: break-all;
  /* 正文与本文涉及之间的虚线 */
  border-bottom: 2rpx dashed #e0d8cc;
}

/* ========== 本文涉及 ========== */
.related-section {
  background: #fff;
  padding: 36rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(to right, transparent, #d4c5a9);
}

.section-line:last-child {
  background: linear-gradient(to left, transparent, #d4c5a9);
}

.section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #8b6f47;
  letter-spacing: 4rpx;
  white-space: nowrap;
}

.related-group {
  margin-bottom: 28rpx;
}

.related-group:last-child {
  margin-bottom: 0;
}

.group-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #6a5840;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.related-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
  background: #faf8f4;
  border-radius: 10rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid #ece6db;
  transition: background 0.15s;
}

.related-item:last-child {
  margin-bottom: 0;
}

.related-item:active {
  background: #f5f0e8;
}

.related-name {
  font-size: 28rpx;
  color: #3a2e24;
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12rpx;
}

.related-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 0 8rpx;
}

.related-empty-text {
  font-size: 24rpx;
  color: #c4b8a8;
}

/* ========== 加载/空/安全区 ========== */
.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 300rpx 0;
}

.safe-bottom {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* ========== AI 悬浮按钮 ========== */
.ai-fab {
  position: fixed;
  right: 36rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  height: 76rpx;
  padding: 0 32rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #c94843 0%, #b63b36 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(182, 59, 54, 0.4);
  z-index: 50;
  transition: transform 0.2s ease;
  animation: fabFadeIn 0.4s ease-out;
}

.ai-fab:active {
  transform: scale(0.93);
}

.ai-fab-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
}

@keyframes fabFadeIn {
  from { opacity: 0; transform: scale(0.6) translateY(20rpx); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}
