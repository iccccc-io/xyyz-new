page {
  background-color: #fff;
  min-height: 100vh;
}

.detail-container {
  min-height: 100vh;
}

/* ========== 文章头部 ========== */
.article-header {
  padding: 20rpx 40rpx 32rpx;
  background: #fff;
}

.article-category {
  margin-bottom: 20rpx;
}

.article-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a1a;
  line-height: 1.5;
  letter-spacing: 1rpx;
}

/* ========== 文章正文 ========== */
.article-body {
  padding: 0 40rpx 40rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 2;
  word-break: break-all;
}

/* ========== 本文涉及 ========== */
.related-section {
  margin: 20rpx 30rpx;
  background: #f9f8f5;
  border-radius: 20rpx;
  padding: 36rpx;
}

.related-title {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #8b6f47;
}

.related-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(to right, transparent, #d4c5a9, transparent);
}

.related-group {
  margin-bottom: 28rpx;
}

.related-group:last-child {
  margin-bottom: 0;
}

.related-group-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
  margin-bottom: 16rpx;
}

.related-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.related-item:last-child {
  margin-bottom: 0;
}

.related-item:active {
  background: #fafaf8;
  transform: scale(0.98);
}

.related-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 加载/空/安全区 ========== */
.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 300rpx 0;
}

.safe-bottom {
  height: calc(60rpx + env(safe-area-inset-bottom));
}
