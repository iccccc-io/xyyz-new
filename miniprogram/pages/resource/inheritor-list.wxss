page {
  background-color: #f0ece4;
  height: 100vh;
}

.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: #f0ece4;
}

/* ========== 顶部固定区域 ========== */
.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #f0ece4;
}

.status-bar {
  background-color: #f0ece4;
}

/* ========== 导航栏 ========== */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255,255,255,0.7);
  border: 1rpx solid #ddd5c8;
}

.nav-back:active {
  background: rgba(255,255,255,0.9);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #3a2e24;
  letter-spacing: 6rpx;
}

.nav-right {
  width: 64rpx;
}

/* ========== 搜索行 ========== */
.search-row {
  display: flex;
  align-items: center;
  padding: 4rpx 30rpx 20rpx;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.85);
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 72rpx;
  border: 1rpx solid #ddd5c8;
}

.search-icon-inner {
  margin-right: 14rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #3a2e24;
  height: 72rpx;
  line-height: 72rpx;
}

.search-placeholder {
  color: #b8a898;
  font-size: 26rpx;
}

/* 胶囊形搜索按钮 */
.search-btn {
  flex-shrink: 0;
  background: #8b6f47;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0 40rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 40rpx;
  text-align: center;
  letter-spacing: 4rpx;
}

.search-btn:active {
  opacity: 0.85;
}

/* 圆形筛选按钮 */
.filter-btn {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.85);
  border-radius: 50%;
  border: 1rpx solid #ddd5c8;
}

.filter-btn:active {
  background: #f5f0e8;
}

/* ========== 列表内容区 ========== */
.list-content {
  padding: 20rpx 28rpx;
  padding-bottom: 40rpx;
}

/* ========== 传承人卡片 ========== */
.inheritor-card {
  display: flex;
  align-items: center;
  background: #fffdf9;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx 24rpx;
  border: 1rpx solid #e8e0d2;
  box-shadow: 0 3rpx 16rpx rgba(90,60,30,0.07);
  transition: opacity 0.15s;
}

.inheritor-card:active {
  opacity: 0.85;
}

/* 头像 */
.avatar-wrap {
  flex-shrink: 0;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: linear-gradient(135deg, #d4a97a 0%, #c4a46c 50%, #8b6f47 100%);
}

.inheritor-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f0ebe4;
  border: 3rpx solid #fffdf9;
  display: block;
}

/* 文字信息 */
.inheritor-info {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.level-tag {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #8b6f47;
  background: #f5ece0;
  border: 1rpx solid #ddc8a8;
  border-radius: 32rpx;
  padding: 4rpx 16rpx;
  font-weight: 500;
}

.inheritor-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #2c2318;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.project-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.project-name-text {
  font-size: 26rpx;
  color: #6a5a40;
  margin-left: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.city-row {
  display: flex;
  align-items: center;
}

.city-text {
  font-size: 24rpx;
  color: #a89878;
  margin-left: 8rpx;
}

/* ========== 空/加载/到底 ========== */
.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.loading-state {
  padding: 60rpx 0;
  text-align: center;
}

.no-more {
  padding: 40rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #c4b8a8;
}

/* ========== 筛选弹窗 ========== */
.filter-popup {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f7f5f1;
}

.filter-status-bar {
  background-color: #fff;
  flex-shrink: 0;
}

.filter-header {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #ece6db;
}

.filter-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3a2e24;
  letter-spacing: 2rpx;
}

.filter-body {
  flex: 1;
  padding: 20rpx 0;
}

.filter-section {
  margin-bottom: 10rpx;
  background-color: #fff;
  padding: 28rpx 32rpx;
}

.filter-section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #3a2e24;
  margin-bottom: 20rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 14rpx 28rpx;
  background-color: #f7f5f1;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #666;
  border: 1rpx solid #e0d8cc;
  transition: all 0.2s;
}

.filter-option.active {
  background-color: #8b6f47;
  color: #fff;
  border-color: #8b6f47;
  font-weight: 500;
}

.filter-footer {
  display: flex;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #ece6db;
  gap: 20rpx;
}

.filter-action {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.reset-action {
  background-color: #f7f5f1;
  color: #666;
  border: 1rpx solid #e0d8cc;
}

.confirm-action {
  background: #8b6f47;
  color: #fff;
}
