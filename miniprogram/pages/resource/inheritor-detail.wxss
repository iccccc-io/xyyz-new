page {
  background-color: #f7f5f1;
  min-height: 100vh;
}

.detail-container {
  min-height: 100vh;
}

/* ========== 个人档案头部 ========== */
.profile-hero {
  position: relative;
  padding: 120rpx 0 60rpx;
  overflow: hidden;
}

.profile-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #c94843 0%, #b63b36 40%, #8b2e2a 100%);
}

.profile-bg::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at top right, rgba(255,255,255,0.12) 0%, transparent 60%);
}

.profile-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.25);
  background: #f0e6d6;
}

.profile-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 24rpx;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.profile-level {
  margin-top: 16rpx;
}

/* ========== 项目链接卡片 ========== */
.project-link-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx !important;
  margin-top: -30rpx !important;
  position: relative;
  z-index: 5;
}

.project-link-card:active {
  background: #fafaf8;
}

.link-card-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.link-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  background: #fff5f0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.link-card-info {
  margin-left: 24rpx;
  flex: 1;
  min-width: 0;
}

.link-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.link-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 通用区块卡片 ========== */
.section-card {
  margin: 24rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
  margin-bottom: 28rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.section-bar {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(to bottom, #b63b36, #8b2e2a);
  border-radius: 4rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

/* ========== 富文本内容 ========== */
.rich-content {
  font-size: 30rpx;
  color: #444;
  line-height: 1.9;
  word-break: break-all;
}

/* ========== 资讯列表 ========== */
.news-list {
  display: flex;
  flex-direction: column;
}

.news-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f8f8f8;
  transition: background 0.2s;
}

.news-item:last-child {
  border-bottom: none;
}

.news-item:active {
  background: #fafaf8;
}

.news-content {
  flex: 1;
  min-width: 0;
}

.news-content .news-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ========== 加载/空/安全区 ========== */
.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 300rpx 0;
}

.safe-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}

/* ========== AI 悬浮按钮 ========== */
.ai-fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #c94843 0%, #b63b36 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(182, 59, 54, 0.45);
  z-index: 50;
  transition: transform 0.2s ease;
  animation: fabFadeIn 0.4s ease-out;
}

.ai-fab:active {
  transform: scale(0.9);
}

.ai-fab-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
}

@keyframes fabFadeIn {
  from {
    opacity: 0;
    transform: scale(0.5);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
