page {
  background-color: #f0ece4;
  min-height: 100vh;
}

.detail-container {
  min-height: 100vh;
}

/* ========== 封面大图英雄区 ========== */
.hero-cover {
  position: relative;
  width: 100%;
  height: 540rpx;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* 底部渐变蒙层 */
.hero-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(20, 12, 6, 0.55) 60%,
    rgba(20, 12, 6, 0.82) 100%
  );
}

/* 姓名 + 级别区域 */
.hero-bottom {
  position: absolute;
  bottom: 90rpx;
  left: 44rpx;
  right: 44rpx;
  z-index: 2;
}

.profile-name {
  display: block;
  font-size: 50rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 6rpx;
  text-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.35);
  line-height: 1.3;
}

.level-badge {
  display: inline-flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(196, 164, 108, 0.25);
  border: 1rpx solid rgba(196, 164, 108, 0.55);
}

.level-badge-text {
  font-size: 24rpx;
  color: #f0ddb8;
  letter-spacing: 2rpx;
}

/* ========== 基础信息卡片 ========== */
.info-card {
  margin: -50rpx 28rpx 0;
  background: #fffdf9;
  border-radius: 16rpx;
  padding: 20rpx 32rpx;
  border: 1rpx solid #e8e0d2;
  box-shadow: 0 6rpx 24rpx rgba(90, 60, 30, 0.1);
  position: relative;
  z-index: 5;
}

.info-row {
  display: flex;
  align-items: baseline;
  padding: 14rpx 0;
  border-bottom: 1rpx dashed #ece6db;
}

.info-row:last-child {
  border-bottom: none;
  padding-bottom: 6rpx;
}

.info-row:first-child {
  padding-top: 6rpx;
}

.info-label {
  font-size: 26rpx;
  color: #a89878;
  width: 100rpx;
  flex-shrink: 0;
  letter-spacing: 2rpx;
}

.info-value {
  font-size: 28rpx;
  color: #3a2e24;
  font-weight: 500;
  flex: 1;
}

/* ========== 所属项目跳转卡片 ========== */
.project-link-card {
  margin: 20rpx 28rpx 0;
  background: #fffdf9;
  border-radius: 16rpx;
  border: 1rpx solid #e8e0d2;
  box-shadow: 0 3rpx 16rpx rgba(90, 60, 30, 0.07);
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: background 0.15s;
}

.project-link-card:active {
  background: #faf7f2;
}

.project-link-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 14rpx;
  background: #f5ede0;
  border: 1rpx solid #e8d8c4;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.project-link-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.project-link-label {
  font-size: 22rpx;
  color: #a89878;
}

.project-link-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #3a2e24;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 通用区块卡片 ========== */
.section-card {
  margin: 20rpx 28rpx 0;
  background: #fffdf9;
  border-radius: 16rpx;
  padding: 32rpx;
  border: 1rpx solid #e8e0d2;
  box-shadow: 0 3rpx 16rpx rgba(90, 60, 30, 0.07);
}

.section-header {
  display: flex;
  align-items: center;
  padding-bottom: 22rpx;
  border-bottom: 1rpx dashed #e8e0d2;
  margin-bottom: 28rpx;
}

.section-bar {
  width: 7rpx;
  height: 30rpx;
  background: linear-gradient(to bottom, #c4a46c, #8b6f47);
  border-radius: 4rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c2318;
  letter-spacing: 2rpx;
}

/* ========== 富文本 ========== */
.rich-content {
  font-size: 30rpx;
  color: #3a2e24;
  line-height: 1.9;
  word-break: break-all;
}

/* ========== 资讯列表 ========== */
.news-list {
  display: flex;
  flex-direction: column;
}

.news-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx dashed #ece6db;
  transition: background 0.15s;
}

.news-item:last-child {
  border-bottom: none;
}

.news-item:active {
  background: #faf7f2;
}

.news-body {
  flex: 1;
  min-width: 0;
}

.news-title {
  display: -webkit-box;
  font-size: 28rpx;
  color: #3a2e24;
  line-height: 1.5;
  margin-bottom: 10rpx;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ========== 加载 / 安全区 ========== */
.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 300rpx 0;
}

.safe-bottom {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* ========== AI 悬浮胶囊 ========== */
.ai-fab {
  position: fixed;
  right: 36rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  height: 76rpx;
  padding: 0 32rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #c94843 0%, #b63b36 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(182, 59, 54, 0.4);
  z-index: 50;
  transition: transform 0.2s ease;
  animation: fabFadeIn 0.4s ease-out;
}

.ai-fab:active {
  transform: scale(0.93);
}

.ai-fab-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
}

@keyframes fabFadeIn {
  from { opacity: 0; transform: scale(0.6) translateY(20rpx); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}
