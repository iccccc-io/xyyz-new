<!-- 自定义导航栏 -->
<nav-bar
  title="资讯详情"
  showTitle="{{true}}"
  background="solid"
  dark="{{true}}"
  placeholder="{{true}}"
/>

<view class="detail-container">
  <!-- 加载状态 -->
  <view class="loading-wrapper" wx:if="{{loading}}">
    <van-loading type="spinner" color="#b63b36" size="40">加载中...</van-loading>
  </view>

  <!-- 空状态 -->
  <van-empty wx:if="{{!loading && !newsData}}" description="资讯不存在" />

  <block wx:if="{{newsData}}">
    <!-- 文章头部 -->
    <view class="article-header">
      <view class="article-category">
        <van-tag
          plain
          color="{{newsData.category === '非遗快讯' ? '#1989fa' : '#8b6f47'}}"
          size="large"
        >{{newsData.category}}</van-tag>
      </view>
      <view class="article-title">{{newsData.title}}</view>
    </view>

    <!-- 文章正文 -->
    <view class="article-body" wx:if="{{newsData._processedContent}}">
      <rich-text nodes="{{newsData._processedContent}}"></rich-text>
    </view>

    <!-- 本文涉及 -->
    <view class="related-section"
      wx:if="{{(newsData.related_projects && newsData.related_projects.length > 0) || (newsData.related_inheritors && newsData.related_inheritors.length > 0)}}">
      <view class="related-title">
        <view class="related-line"></view>
        <text>本文涉及</text>
        <view class="related-line"></view>
      </view>

      <!-- 关联项目 -->
      <view class="related-group" wx:if="{{newsData.related_projects && newsData.related_projects.length > 0}}">
        <view class="related-group-label">
          <van-icon name="bookmark-o" size="14" color="#b63b36" />
          <text>相关项目</text>
        </view>
        <view class="related-item"
          wx:for="{{newsData.related_projects}}" wx:key="project_id"
          bindtap="goToProject" data-id="{{item.project_id}}">
          <text class="related-name">{{item.name}}</text>
          <van-icon name="arrow" size="14" color="#ccc" />
        </view>
      </view>

      <!-- 关联传承人 -->
      <view class="related-group" wx:if="{{newsData.related_inheritors && newsData.related_inheritors.length > 0}}">
        <view class="related-group-label">
          <van-icon name="user-o" size="14" color="#b63b36" />
          <text>相关传承人</text>
        </view>
        <view class="related-item"
          wx:for="{{newsData.related_inheritors}}" wx:key="inheritor_id"
          bindtap="goToInheritor" data-id="{{item.inheritor_id}}">
          <text class="related-name">{{item.name}}</text>
          <van-icon name="arrow" size="14" color="#ccc" />
        </view>
      </view>
    </view>

    <!-- 底部安全区 -->
    <view class="safe-bottom"></view>

    <!-- AI 对话悬浮按钮 -->
    <view class="ai-fab" bindtap="goToAiChat">
      <text class="ai-fab-text">AI</text>
    </view>
  </block>
</view>
