page {
  background-color: #f7f5f1;
  min-height: 100vh;
}

.detail-container {
  min-height: 100vh;
}

/* ========== 封面图 ========== */
.hero-cover {
  position: relative;
  width: 100%;
  height: 520rpx;
  overflow: hidden;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.5));
}

.cover-title-area {
  position: absolute;
  bottom: 80rpx;
  left: 40rpx;
  right: 40rpx;
  z-index: 2;
}

.cover-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.4;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* ========== 基本信息卡片 ========== */
.info-card {
  margin: -50rpx 30rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 5;
}

.tags-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.meta-value {
  font-size: 28rpx;
  color: #666;
  margin-left: 8rpx;
}

/* ========== 通用区块卡片 ========== */
.section-card {
  margin: 24rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
  margin-bottom: 28rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.section-bar {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(to bottom, #b63b36, #8b2e2a);
  border-radius: 4rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.section-count {
  margin-left: auto;
  font-size: 26rpx;
  color: #999;
  font-weight: normal;
}

/* ========== 视频区 ========== */
.video-wrapper {
  border-radius: 12rpx;
  overflow: hidden;
}

.video-player {
  width: 100%;
  height: 380rpx;
}

.video-name {
  font-size: 26rpx;
  color: #666;
  margin-top: 16rpx;
  text-align: center;
}

/* ========== 富文本内容 ========== */
.rich-content {
  font-size: 30rpx;
  color: #444;
  line-height: 1.9;
  word-break: break-all;
}

/* ========== 传承人网格 ========== */
.inheritor-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.inheritor-item {
  width: calc(33.33% - 16rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  transition: transform 0.2s;
}

.inheritor-item:active {
  transform: scale(0.95);
}

.inheritor-avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: #f0e6d6;
  border: 4rpx solid #f0e6d6;
  margin-bottom: 16rpx;
}

.inheritor-grid .inheritor-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  text-align: center;
  margin-bottom: 6rpx;
}

.inheritor-grid .inheritor-level {
  font-size: 22rpx;
  color: #8b6f47;
  text-align: center;
}

/* ========== 资讯列表 ========== */
.news-list {
  display: flex;
  flex-direction: column;
}

.news-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f8f8f8;
  transition: background 0.2s;
}

.news-item:last-child {
  border-bottom: none;
}

.news-item:active {
  background: #fafaf8;
}

.news-content {
  flex: 1;
  min-width: 0;
}

.news-content .news-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ========== 加载/空/安全区 ========== */
.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 300rpx 0;
}

.safe-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
