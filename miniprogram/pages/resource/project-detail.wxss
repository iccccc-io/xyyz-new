page {
  background-color: #f0ece4;
  min-height: 100vh;
}

.detail-container {
  min-height: 100vh;
}

/* ========== 封面图 ========== */
.hero-cover {
  position: relative;
  width: 100%;
  height: 520rpx;
  overflow: hidden;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.55));
}

.cover-title-area {
  position: absolute;
  bottom: 80rpx;
  left: 40rpx;
  right: 40rpx;
  z-index: 2;
}

.cover-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.4;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* ========== 基本信息卡片 ========== */
.info-card {
  margin: -50rpx 28rpx 0;
  background: #fffdf9;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid #e8e0d2;
  box-shadow: 0 6rpx 24rpx rgba(90, 60, 30, 0.1);
  position: relative;
  z-index: 5;
}

.info-row {
  display: flex;
  align-items: baseline;
  padding: 14rpx 0;
  border-bottom: 1rpx dashed #ece6db;
}

.info-row:last-child {
  border-bottom: none;
  padding-bottom: 6rpx;
}

.info-row:first-child {
  padding-top: 6rpx;
}

.info-label {
  font-size: 26rpx;
  color: #a89878;
  width: 100rpx;
  flex-shrink: 0;
  letter-spacing: 2rpx;
}

.info-value {
  font-size: 28rpx;
  color: #3a2e24;
  font-weight: 500;
  flex: 1;
}

/* ========== 通用区块卡片 ========== */
.section-card {
  margin: 20rpx 28rpx;
  background: #fffdf9;
  border-radius: 16rpx;
  padding: 32rpx;
  border: 1rpx solid #e8e0d2;
  box-shadow: 0 3rpx 16rpx rgba(90, 60, 30, 0.07);
}

.section-header {
  display: flex;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx dashed #e8e0d2;
  margin-bottom: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #3a2e24;
  letter-spacing: 2rpx;
}

.section-bar {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(to bottom, #c4a46c, #8b6f47);
  border-radius: 4rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.section-count {
  margin-left: auto;
  font-size: 26rpx;
  color: #a89878;
  font-weight: normal;
}

/* ========== 视频区 ========== */
.video-wrapper {
  border-radius: 12rpx;
  overflow: hidden;
}

.video-player {
  width: 100%;
  height: 380rpx;
}

.video-name {
  font-size: 24rpx;
  color: #a89878;
  margin-top: 16rpx;
  text-align: center;
}

/* ========== 富文本内容 ========== */
.rich-content {
  font-size: 30rpx;
  color: #3a2e24;
  line-height: 1.9;
  word-break: break-all;
}

/* ========== 传承人网格 ========== */
.inheritor-grid {
  display: flex;
  flex-wrap: wrap;
}

.inheritor-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  box-sizing: border-box;
  transition: opacity 0.15s;
}

.inheritor-item:active {
  opacity: 0.7;
}

.inheritor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f0ebe4;
  border: 3rpx solid #e8e0d4;
  margin-bottom: 12rpx;
}

.inheritor-grid .inheritor-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #3a2e24;
  text-align: center;
  margin-bottom: 4rpx;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.inheritor-grid .inheritor-level {
  font-size: 20rpx;
  color: #8b6f47;
  text-align: center;
}

/* 传承人为空 */
.inheritor-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 0 8rpx;
}

.inheritor-empty-text {
  font-size: 24rpx;
  color: #c4b8a8;
}

/* ========== 资讯列表 ========== */
.news-list {
  display: flex;
  flex-direction: column;
}

.news-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx dashed #ece6db;
  transition: background 0.15s;
}

.news-item:last-child {
  border-bottom: none;
}

.news-item:active {
  background: #faf7f2;
}

.news-content {
  flex: 1;
  min-width: 0;
}

.news-content .news-title {
  font-size: 28rpx;
  color: #3a2e24;
  line-height: 1.5;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ========== 加载/空/安全区 ========== */
.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 300rpx 0;
}

.safe-bottom {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* ========== AI 悬浮按钮 ========== */
.ai-fab {
  position: fixed;
  right: 36rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  height: 76rpx;
  padding: 0 32rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #c94843 0%, #b63b36 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(182, 59, 54, 0.4);
  z-index: 50;
  transition: transform 0.2s ease;
  animation: fabFadeIn 0.4s ease-out;
}

.ai-fab:active {
  transform: scale(0.93);
}

.ai-fab-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
}

@keyframes fabFadeIn {
  from { opacity: 0; transform: scale(0.6) translateY(20rpx); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}
