<view class="page-container">
  <!-- 顶部固定区域 -->
  <view class="fixed-header">
    <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

    <!-- 导航栏 -->
    <view class="nav-bar">
      <view class="nav-back" bindtap="goBack">
        <van-icon name="arrow-left" size="18" color="#5a4a3a" />
      </view>
      <text class="nav-title">非遗项目</text>
      <view class="nav-right"></view>
    </view>

    <!-- 搜索行 -->
    <view class="search-row">
      <view class="search-input-wrap">
        <van-icon name="search" size="14" color="#c4a46c" custom-class="search-icon-inner" />
        <input
          class="search-input"
          placeholder="请输入关键字进行搜索"
          placeholder-class="search-placeholder"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          bindconfirm="onSearch"
          confirm-type="search"
        />
      </view>
      <view class="search-btn" bindtap="onSearch">搜索</view>
      <view class="filter-btn" bindtap="openFilter">
        <van-icon name="filter-o" size="20" color="#8b6f47" />
      </view>
    </view>
  </view>

  <!-- 列表内容区 -->
  <view class="list-content" style="padding-top: {{headerHeight}}px;">
    <block wx:if="{{dataList.length > 0}}">
      <view class="project-card"
        wx:for="{{dataList}}" wx:key="project_id"
        bindtap="goToDetail" data-id="{{item.project_id}}">
        <view class="project-name">{{item.name}}</view>
        <view class="tag-row">
          <text class="tag tag-level" wx:if="{{item.level}}">{{item.level}}</text>
          <text class="tag tag-category" wx:if="{{item.category}}">{{item.category}}</text>
          <text class="tag tag-batch" wx:if="{{item.batch}}">{{item.batch}}</text>
        </view>
        <view class="project-meta" wx:if="{{item.city}}">
          <van-icon name="location-o" size="12" color="#c4a46c" />
          <text class="meta-text">{{item.city}}</text>
        </view>
      </view>
    </block>

    <view class="empty-state" wx:if="{{dataList.length === 0 && !loading}}">
      <van-empty description="暂无数据" />
    </view>

    <view class="loading-state" wx:if="{{loading}}">
      <van-loading type="spinner" color="#8b6f47">加载中...</van-loading>
    </view>

    <view class="no-more" wx:if="{{noMore && dataList.length > 0}}">
      <text>— 已经到底了 —</text>
    </view>
  </view>

  <!-- 筛选弹窗 -->
  <van-popup
    show="{{ showFilter }}"
    position="right"
    custom-style="width: 75%; height: 100%;"
    bind:close="closeFilter"
  >
    <view class="filter-popup">
      <view class="filter-status-bar" style="height: {{statusBarHeight}}px;"></view>
      <view class="filter-header">
        <text class="filter-title">筛选</text>
      </view>

      <scroll-view class="filter-body" scroll-y>
        <view class="filter-section">
          <view class="filter-section-title">地区</view>
          <view class="filter-options">
            <view class="filter-option {{filterData.city === '' ? 'active' : ''}}"
              bindtap="selectFilter" data-type="city" data-value="">全部</view>
            <view class="filter-option {{filterData.city === item ? 'active' : ''}}"
              wx:for="{{cityOptions}}" wx:key="index"
              bindtap="selectFilter" data-type="city" data-value="{{item}}">{{item}}</view>
          </view>
        </view>

        <view class="filter-section">
          <view class="filter-section-title">类别</view>
          <view class="filter-options">
            <view class="filter-option {{filterData.category === '' ? 'active' : ''}}"
              bindtap="selectFilter" data-type="category" data-value="">全部</view>
            <view class="filter-option {{filterData.category === item ? 'active' : ''}}"
              wx:for="{{categoryOptions}}" wx:key="index"
              bindtap="selectFilter" data-type="category" data-value="{{item}}">{{item}}</view>
          </view>
        </view>

        <view class="filter-section">
          <view class="filter-section-title">级别</view>
          <view class="filter-options">
            <view class="filter-option {{filterData.level === '' ? 'active' : ''}}"
              bindtap="selectFilter" data-type="level" data-value="">全部</view>
            <view class="filter-option {{filterData.level === item ? 'active' : ''}}"
              wx:for="{{levelOptions}}" wx:key="index"
              bindtap="selectFilter" data-type="level" data-value="{{item}}">{{item}}</view>
          </view>
        </view>

        <view class="filter-section">
          <view class="filter-section-title">批次</view>
          <view class="filter-options">
            <view class="filter-option {{filterData.batch === '' ? 'active' : ''}}"
              bindtap="selectFilter" data-type="batch" data-value="">全部</view>
            <view class="filter-option {{filterData.batch === item ? 'active' : ''}}"
              wx:for="{{batchOptions}}" wx:key="index"
              bindtap="selectFilter" data-type="batch" data-value="{{item}}">{{item}}</view>
          </view>
        </view>
      </scroll-view>

      <view class="filter-footer">
        <view class="filter-action reset-action" bindtap="resetFilter">重置</view>
        <view class="filter-action confirm-action" bindtap="confirmFilter">确定</view>
      </view>
    </view>
  </van-popup>
</view>
