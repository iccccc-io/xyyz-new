<view class="checkout-page" wx:if="{{!loading}}">
  <nav-bar
    title="确认订单"
    showTitle="{{true}}"
    showBack="{{true}}"
    background="solid"
    dark="{{true}}"
    placeholder="{{true}}"
  />

  <view class="address-card" bindtap="chooseAddress">
    <text class="address-card-title">{{product && product.logistics && product.logistics.isPickup ? '自提联系信息' : '收货地址'}}</text>
    <view class="address-empty" wx:if="{{!address}}">
      <van-icon name="location-o" size="24" color="#8B2E2A" />
      <text class="address-empty-text">{{product && product.logistics && product.logistics.isPickup ? '点击选择自提联系信息' : '点击选择收货地址'}}</text>
      <van-icon name="arrow" size="16" color="#ccc" />
    </view>
    <view class="address-filled" wx:else>
      <view class="address-icon-wrap">
        <van-icon name="location-o" size="22" color="#8B2E2A" />
      </view>
      <view class="address-info">
        <view class="address-user-row">
        <text class="address-name">{{address.userName}}</text>
        <text class="address-tel">{{address.telNumber}}</text>
      </view>
      <text class="address-detail">{{address.provinceName}}{{address.cityName}}{{address.countyName}} {{address.detailInfo}}</text>
    </view>
    <van-icon name="arrow" size="16" color="#ccc" />
    </view>
    <text class="pickup-note" wx:if="{{product && product.logistics && product.logistics.isPickup}}">
      商家将按照这份联系人信息与您约定同城自提交付时间。
    </text>
  </view>

  <view class="product-card" wx:if="{{product}}">
    <view class="shop-row">
      <van-icon name="shop-o" size="16" color="#8B6F47" />
      <text class="shop-name">{{product.workshop_name || '湘韵遗珍文创商城'}}</text>
    </view>
    <view class="product-row">
      <image class="product-img" src="{{product.skuImage || product.cover_img}}" mode="aspectFill" />
      <view class="product-info">
        <text class="product-title">{{product.title}}</text>
        <view class="product-tags" wx:if="{{product.related_project_name}}">
          <van-tag plain color="#8B6F47" size="small">{{product.related_project_name}}</van-tag>
        </view>
        <text class="product-sku">款式：{{product.skuName}}</text>
        <view class="product-price-row">
          <view class="product-price-block">
            <text class="product-price">楼{{product.priceDisplay}}</text>
            <text class="product-original-price" wx:if="{{product.originalPriceDisplay}}">楼{{product.originalPriceDisplay}}</text>
          </view>
          <text class="product-qty">× {{quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="summary-card">
    <view class="summary-row">
      <text class="summary-label">商品金额</text>
      <text class="summary-value">楼{{totalDisplay}}</text>
    </view>
    <view class="summary-row">
      <text class="summary-label">{{product && product.logistics && product.logistics.isPickup ? '交付方式' : '运费'}}</text>
      <text class="summary-value">{{deliverySummaryText}}</text>
    </view>
    <view class="pay-on-delivery-tip" wx:if="{{showPayOnDeliveryNote}}">
      *该商品为邮费到付，收件时请直接支付给快递员。
    </view>
    <view class="summary-divider"></view>
    <view class="summary-row total-row">
      <text class="summary-label summary-label-total">实付金额</text>
      <view class="total-price-wrap">
        <text class="total-symbol">楼</text>
        <text class="total-value">{{totalDisplay}}</text>
      </view>
    </view>
  </view>

  <view class="checkout-footer">
    <view class="footer-left">
      <text class="footer-total-label">合计：</text>
      <text class="footer-total-price">楼{{totalDisplay}}</text>
    </view>
    <van-button
      type="primary"
      round
      color="#8B2E2A"
      loading="{{submitting}}"
      disabled="{{submitting}}"
      bind:click="submitOrder"
    >
      提交订单
    </van-button>
  </view>
</view>

<view class="loading-wrap" wx:if="{{loading}}">
  <van-loading size="24px" color="#8B2E2A">加载中...</van-loading>
</view>

<pay-keyboard
  id="payKeyboard"
  show="{{showPayKeyboard}}"
  title="确认支付"
  amount-display="{{totalDisplay}}"
  loading="{{paying}}"
  bind:confirm="onPayConfirm"
  bind:close="onPayKeyboardClose"
/>
