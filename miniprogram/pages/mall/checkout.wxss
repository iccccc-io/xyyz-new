/* pages/mall/checkout.wxss */

.checkout-page {
  min-height: 100vh;
  background: #f6f0e8;
  padding-bottom: 140rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

/* ===== 收货地址卡片 ===== */
.address-card {
  margin: 24rpx 28rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.address-empty {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.address-empty-text {
  flex: 1;
  font-size: 28rpx;
  color: #8B6F47;
}

.address-filled {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.address-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  background: #fff0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.address-info {
  flex: 1;
}

.address-user-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.address-tel {
  font-size: 26rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
}

/* ===== 商品卡片 ===== */
.product-card {
  margin: 0 28rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.shop-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f0e8;
}

.shop-name {
  font-size: 26rpx;
  color: #8B6F47;
  font-weight: 600;
}

.product-row {
  display: flex;
  gap: 20rpx;
}

.product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.product-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.product-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.product-sku {
  font-size: 24rpx;
  color: #8B6F47;
}

.product-price-block {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  flex-wrap: wrap;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #8B2E2A;
}

.product-original-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
}

.product-qty {
  font-size: 26rpx;
  color: #999;
}

/* ===== 金额汇总 ===== */
.summary-card {
  margin: 0 28rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.summary-label {
  font-size: 28rpx;
  color: #666;
}

.summary-value {
  font-size: 28rpx;
  color: #333;
}

.freight-free {
  color: #10b981;
}

.summary-divider {
  height: 1rpx;
  background: #f5f0e8;
  margin: 8rpx 0;
}

.pay-on-delivery-tip {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #B63B36;
}

.total-row {
  padding-top: 16rpx;
}

.summary-label-total {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.total-price-wrap {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
}

.total-symbol {
  font-size: 26rpx;
  color: #8B2E2A;
  margin-bottom: 4rpx;
}

.total-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #8B2E2A;
}

/* ===== 底部提交栏 ===== */
.checkout-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}

.footer-left {
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
}

.footer-total-label {
  font-size: 26rpx;
  color: #666;
}

.footer-total-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #8B2E2A;
}
