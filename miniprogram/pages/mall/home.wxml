<view class="mall-page">
  <view class="page-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-inner">
      <view class="capsule-offset" style="height: {{headerTopOffset}}px;"></view>

      <view class="search-shell">
        <van-icon name="search" size="18" color="#B8AEA2" />
        <input
          class="search-input"
          placeholder="搜索非遗文创..."
          placeholder-class="search-placeholder"
          value="{{searchValue}}"
          confirm-type="search"
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
        />
        <view class="search-clear" wx:if="{{searchValue}}" bindtap="onSearchClear">
          <van-icon name="cross" size="14" color="#B8AEA2" />
        </view>
        <view class="search-action" bindtap="onSearchConfirm">
          <van-icon name="arrow" size="16" color="#A12D27" />
        </view>
      </view>

      <scroll-view scroll-x class="tabs-scroll" enhanced show-scrollbar="{{false}}">
        <view class="tabs-track">
          <view
            class="tab-item {{activeCategory === item.id ? 'is-active' : ''}}"
            wx:for="{{categoryTabs}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="onCategoryChange"
          >
            <text class="tab-label">{{item.label}}</text>
            <view class="tab-ink" wx:if="{{activeCategory === item.id}}"></view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="page-content">
    <view class="featured-block" wx:if="{{featuredProduct && activeCategory === '全部' && !searchValue}}">
      <view class="featured-card" bindtap="goToDetail" data-id="{{featuredProduct._id}}">
        <image class="featured-image" src="{{featuredProduct.cover_img}}" mode="aspectFill" />
        <view class="featured-badge">{{featuredProduct.badgeText}}</view>
        <view class="featured-chip-row">
          <view class="featured-chip">{{featuredProduct.workshopDisplayName}}</view>
          <view class="featured-chip" wx:if="{{featuredProduct.projectDisplayName}}">{{featuredProduct.projectDisplayName}}</view>
        </view>
        <view class="featured-gradient"></view>
        <view class="featured-content">
          <text class="featured-title">{{featuredProduct.title}}</text>
          <view class="featured-footer">
            <text class="featured-price">¥{{featuredProduct.priceDisplay}}</text>
            <text class="featured-note">匠心推荐</text>
          </view>
        </view>
      </view>
    </view>

    <view class="feed-head">
      <view class="feed-head-main">
        <text class="feed-title">{{searchValue ? '搜索结果' : (activeCategory === '全部' ? '匠作清单' : activeCategory)}}</text>

        <view class="filter-trigger {{showFilterPanel ? 'is-open' : ''}}" bindtap="toggleFilterPanel">
          <van-icon name="filter-o" size="14" color="#7F4A35" />
          <text class="filter-trigger-text">筛选</text>
          <view class="filter-count" wx:if="{{activeFilterCount > 0}}">{{activeFilterCount}}</view>
          <view class="filter-arrow {{showFilterPanel ? 'is-open' : ''}}">
            <van-icon name="arrow-down" size="12" color="#7F4A35" />
          </view>
        </view>
      </view>

      <text class="feed-subtitle">{{searchValue ? '与关键词相关的非遗文创' : '让商品回归作品本身，也让工坊被看见'}}</text>
    </view>

    <view class="filter-panel {{showFilterPanel ? 'is-open' : 'is-closed'}}">
      <view class="filter-group">
        <text class="filter-group-title">排序方式</text>
        <view class="filter-options">
          <view
            class="filter-option {{draftFilterState.sortBy === item.id ? 'is-active' : ''}}"
            wx:for="{{sortOptions}}"
            wx:key="id"
            data-group="sortBy"
            data-id="{{item.id}}"
            bindtap="onSelectFilterOption"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-group">
        <text class="filter-group-title">价格区间</text>
        <view class="filter-options">
          <view
            class="filter-option {{draftFilterState.priceRange === item.id ? 'is-active' : ''}}"
            wx:for="{{priceOptions}}"
            wx:key="id"
            data-group="priceRange"
            data-id="{{item.id}}"
            bindtap="onSelectFilterOption"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-group">
        <text class="filter-group-title">非遗类别</text>
        <view class="filter-options">
          <view
            class="filter-option {{draftFilterState.heritageCategory === item.id ? 'is-active' : ''}}"
            wx:for="{{heritageCategoryOptions}}"
            wx:key="id"
            data-group="heritageCategory"
            data-id="{{item.id}}"
            bindtap="onSelectFilterOption"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-actions">
        <view class="filter-btn filter-btn-reset" bindtap="onResetFilter">重置</view>
        <view class="filter-btn filter-btn-apply" bindtap="onApplyFilter">应用筛选</view>
      </view>
    </view>

    <view class="loading-state" wx:if="{{loading}}">
      <van-loading size="24px" color="#A12D27">加载中...</van-loading>
    </view>

    <view class="empty-state" wx:elif="{{leftColumn.length === 0 && rightColumn.length === 0}}">
      <van-empty description="暂时没有符合条件的文创好物" />
    </view>

    <view class="waterfall-container" wx:else>
      <view class="waterfall-column">
        <view
          class="product-card"
          wx:for="{{leftColumn}}"
          wx:key="_id"
          bindtap="goToDetail"
          data-id="{{item._id}}"
        >
          <view class="card-media">
            <image class="card-image" src="{{item.cover_img}}" mode="widthFix" lazy-load />
            <view class="card-badge">{{item.badgeText}}</view>
          </view>
          <view class="card-body">
            <text class="card-title">{{item.title}}</text>
            <view class="merchant-row">
              <view class="workshop-box">
                <image wx:if="{{item.workshopLogo}}" class="workshop-avatar" src="{{item.workshopLogo}}" mode="aspectFill" />
                <view wx:else class="workshop-avatar workshop-avatar-fallback">
                  <text class="workshop-initial">{{item.workshopInitial}}</text>
                </view>
                <view class="merchant-copy">
                  <text class="workshop-name">{{item.workshopDisplayName}}</text>
                  <text class="merchant-caption">匠人店铺</text>
                </view>
              </view>
            </view>
            <view class="card-footer">
              <view class="card-price price-emphasis">
                <text class="price-symbol">¥</text>
                <text class="price-value">{{item.priceDisplay}}</text>
              </view>
              <view class="card-tag heritage-tag footer-heritage-tag" wx:if="{{item.projectDisplayName}}">
                <view class="tag-seal"></view>
                <text class="tag-text">{{item.projectDisplayName}}</text>
              </view>
              <view class="card-tag card-tag-muted footer-heritage-tag" wx:else>
                <text class="tag-text">源自 {{item.originDisplay}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="waterfall-column">
        <view
          class="product-card"
          wx:for="{{rightColumn}}"
          wx:key="_id"
          bindtap="goToDetail"
          data-id="{{item._id}}"
        >
          <view class="card-media">
            <image class="card-image" src="{{item.cover_img}}" mode="widthFix" lazy-load />
            <view class="card-badge">{{item.badgeText}}</view>
          </view>
          <view class="card-body">
            <text class="card-title">{{item.title}}</text>
            <view class="merchant-row">
              <view class="workshop-box">
                <image wx:if="{{item.workshopLogo}}" class="workshop-avatar" src="{{item.workshopLogo}}" mode="aspectFill" />
                <view wx:else class="workshop-avatar workshop-avatar-fallback">
                  <text class="workshop-initial">{{item.workshopInitial}}</text>
                </view>
                <view class="merchant-copy">
                  <text class="workshop-name">{{item.workshopDisplayName}}</text>
                  <text class="merchant-caption">匠人店铺</text>
                </view>
              </view>
            </view>
            <view class="card-footer">
              <view class="card-price price-emphasis">
                <text class="price-symbol">¥</text>
                <text class="price-value">{{item.priceDisplay}}</text>
              </view>
              <view class="card-tag heritage-tag footer-heritage-tag" wx:if="{{item.projectDisplayName}}">
                <view class="tag-seal"></view>
                <text class="tag-text">{{item.projectDisplayName}}</text>
              </view>
              <view class="card-tag card-tag-muted footer-heritage-tag" wx:else>
                <text class="tag-text">源自 {{item.originDisplay}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{loadingMore}}">
      <van-loading size="20px" color="#A12D27" />
    </view>

    <view class="no-more" wx:if="{{noMore && (leftColumn.length > 0 || rightColumn.length > 0)}}">
      已经到底了
    </view>
  </view>
</view>
