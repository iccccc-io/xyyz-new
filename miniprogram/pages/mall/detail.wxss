/* pages/mall/detail.wxss */
page {
  background: #ffffff;
  min-height: 100vh;
}

.detail-page {
  background: #ffffff;
}

.hero-section {
  position: relative;
  width: 100%;
  height: 880rpx;
  background: #EFE8E0;
  overflow: hidden;
}

.hero-swiper,
.hero-image {
  width: 100%;
  height: 100%;
}

.hero-top-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.58) 38%, rgba(0, 0, 0, 0) 100%);
  z-index: 2;
  pointer-events: none;
}

.hero-back {
  position: absolute;
  left: 24rpx;
  z-index: 4;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(16, 12, 10, 0.34);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-sizing: border-box;
}

.hero-indicator {
  position: absolute;
  right: 24rpx;
  bottom: 28rpx;
  z-index: 4;
  min-width: 96rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(14, 12, 11, 0.48);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-sizing: border-box;
}

.hero-indicator-text {
  font-size: 22rpx;
  color: #FFFFFF;
  line-height: 1;
  font-weight: 500;
}

.content-section {
  background: #FFFFFF;
}

.core-info {
  padding: 30rpx 30rpx 34rpx;
}

.price-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.price-main {
  min-width: 0;
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  column-gap: 10rpx;
  row-gap: 8rpx;
}

.price-currency {
  font-size: 32rpx;
  line-height: 1;
  color: #A12D27;
  font-weight: 700;
}

.price-number {
  font-size: 48rpx;
  line-height: 1;
  color: #A12D27;
  font-weight: 800;
  letter-spacing: -0.8rpx;
}

.price-original {
  font-size: 24rpx;
  line-height: 1;
  color: #999999;
  text-decoration: line-through;
}

.sales-copy {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.2;
  color: #999999;
  padding-bottom: 8rpx;
}

.mini-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.mini-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #F1F1F1;
  color: #555555;
  font-size: 20rpx;
  line-height: 1.5;
}

.product-title {
  display: block;
  margin-top: 20rpx;
  font-size: 36rpx;
  line-height: 1.44;
  color: #333333;
  font-weight: 600;
}

.product-intro {
  display: block;
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: #8C837B;
}

.meta-row {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.meta-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #F7F2ED;
}

.meta-pill-text {
  font-size: 22rpx;
  line-height: 1.2;
  color: #7B6252;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.meta-stock {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.2;
  color: #A49B93;
}

.quantity-row {
  margin-top: 28rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #FAF7F3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.quantity-label {
  font-size: 28rpx;
  line-height: 1.2;
  color: #332A25;
  font-weight: 600;
}

.quantity-control {
  display: flex;
  align-items: center;
  border-radius: 18rpx;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: inset 0 0 0 1rpx rgba(80, 62, 50, 0.08);
}

.qty-btn {
  width: 68rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F7F2ED;
}

.qty-btn.disabled {
  opacity: 0.65;
}

.qty-value {
  min-width: 88rpx;
  height: 60rpx;
  text-align: center;
  line-height: 60rpx;
  font-size: 28rpx;
  color: #332A25;
  font-weight: 700;
  background: #FFFFFF;
}

.section-divider {
  width: 100%;
  height: 16rpx;
  background: #F5F5F5;
}

.cultural-section {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  background: #FFFFFF;
}

.traceability-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 30rpx 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(161, 45, 39, 0.11) 0%, rgba(161, 45, 39, 0.03) 100%);
  border: 1rpx solid rgba(161, 45, 39, 0.1);
}

.trace-main {
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  flex: 1;
}

.trace-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: rgba(161, 45, 39, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.trace-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.trace-label {
  font-size: 22rpx;
  line-height: 1.2;
  color: #8E5A48;
}

.trace-name {
  font-size: 34rpx;
  line-height: 1.3;
  color: #8F251D;
  font-weight: 700;
}

.trace-desc {
  font-size: 22rpx;
  line-height: 1.65;
  color: #8A7770;
}

.trace-action {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-left: 6rpx;
}

.trace-action-text {
  font-size: 24rpx;
  line-height: 1.2;
  color: #A12D27;
  font-weight: 600;
}

.workshop-surface {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx 26rpx;
  border-radius: 28rpx;
  background: #FDFBF9;
}

.workshop-main {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
}

.workshop-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #EBDCD1;
  flex-shrink: 0;
}

.workshop-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
}

.workshop-avatar-text {
  font-size: 30rpx;
  line-height: 1;
  color: #8F251D;
  font-weight: 700;
}

.workshop-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.workshop-name {
  display: block;
  font-size: 30rpx;
  line-height: 1.35;
  color: #2F241E;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.workshop-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.workshop-badge {
  max-width: 100%;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(161, 45, 39, 0.12);
  color: #A12D27;
  font-size: 20rpx;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.store-entry-btn {
  flex-shrink: 0;
  min-width: 164rpx;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 2rpx solid #A12D27;
  background: #FFFFFF;
  color: #A12D27;
  font-size: 24rpx;
  line-height: 72rpx;
  text-align: center;
  font-weight: 600;
  box-sizing: border-box;
}

.detail-images {
  background: #FFFFFF;
}

.detail-top-space {
  height: 32rpx;
  background: #FFFFFF;
}

.detail-image {
  width: 100%;
  display: block;
}

.bottom-placeholder {
  height: calc(170rpx + env(safe-area-inset-bottom));
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-bar-content {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 18rpx 24rpx 20rpx;
}

.action-icons {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 26rpx;
}

.action-icon-item {
  min-width: 68rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.action-icon-label {
  font-size: 20rpx;
  line-height: 1;
  color: #5C544D;
}

.cta-group {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: stretch;
  border-radius: 999rpx;
  overflow: hidden;
}

.cta-btn {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 700;
}

.cart-btn {
  background: #FFF3EA;
  color: #C7612C;
  border-right: 1rpx solid rgba(199, 97, 44, 0.12);
}

.buy-btn {
  background: #A12D27;
  color: #FFFFFF;
}

.cart-btn text,
.buy-btn text {
  color: inherit;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}
