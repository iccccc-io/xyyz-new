/* pages/mall/detail.wxss */
page {
  background: #0C0B0A;
  min-height: 100vh;
}

.detail-page {
  background: #0C0B0A;
}

.hero-section {
  position: relative;
  width: 100%;
  height: 1120rpx;
  overflow: visible;
  background-color: #070605;
  background-image:
    radial-gradient(circle at 50% 29%, rgba(255, 242, 210, 0.8) 0%, rgba(255, 232, 194, 0.52) 12%, rgba(154, 125, 95, 0.14) 22%, rgba(27, 23, 20, 0.02) 34%, rgba(6, 6, 5, 0.98) 66%, rgba(3, 3, 3, 1) 100%),
    repeating-linear-gradient(105deg, rgba(255, 255, 255, 0.01) 0, rgba(255, 255, 255, 0.01) 2rpx, rgba(0, 0, 0, 0) 2rpx, rgba(0, 0, 0, 0) 28rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.04) 0%, rgba(0, 0, 0, 0) 16%),
    linear-gradient(180deg, #090807 0%, #0B0A09 100%);
}

.hero-stage {
  position: absolute;
  left: 52rpx;
  right: 52rpx;
  bottom: 176rpx;
  box-sizing: border-box;
  z-index: 1;
}

.hero-canvas {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 30rpx;
  overflow: hidden;
  background: transparent;
  box-shadow:
    0 28rpx 64rpx rgba(0, 0, 0, 0.5),
    0 10rpx 24rpx rgba(0, 0, 0, 0.2),
    0 0 88rpx rgba(255, 227, 185, 0.07);
}

.hero-gallery {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
}

.hero-slide {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  opacity: 0;
  pointer-events: none;
  transition: opacity 360ms ease;
}

.hero-slide.is-active {
  opacity: 1;
  pointer-events: auto;
}

.hero-image {
  width: 100%;
  height: 100%;
  display: block;
}

.hero-nav {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 96rpx;
  z-index: 2;
}

.hero-nav-prev {
  left: 0;
}

.hero-nav-next {
  right: 0;
}

.hero-back {
  position: absolute;
  left: 24rpx;
  z-index: 4;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(17, 15, 13, 0.38);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.22);
  box-sizing: border-box;
}

.hero-indicator {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 4;
  min-width: 96rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(7, 7, 7, 0.46);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-sizing: border-box;
}

.hero-indicator-text {
  font-size: 22rpx;
  color: #FFF8F1;
  line-height: 1;
  font-weight: 500;
}

.content-section {
  position: relative;
  z-index: 8;
  margin-top: -72rpx;
  background: transparent;
}

.product-info-panel {
  position: relative;
  z-index: 10;
  background: #FFFFFF;
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
  margin-top: 0;
  overflow: hidden;
  box-shadow:
    0 -18rpx 52rpx rgba(0, 0, 0, 0.08),
    0 -4rpx 18rpx rgba(0, 0, 0, 0.03);
}

.core-info {
  padding: 60rpx 30rpx 34rpx;
}

.price-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.price-main {
  min-width: 0;
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  column-gap: 10rpx;
  row-gap: 8rpx;
}

.price-currency {
  font-size: 32rpx;
  line-height: 1;
  color: #A12D27;
  font-weight: 700;
}

.price-number {
  font-size: 48rpx;
  line-height: 1;
  color: #A12D27;
  font-weight: 800;
  letter-spacing: -0.8rpx;
}

.price-suffix {
  font-size: 24rpx;
  line-height: 1;
  color: #A12D27;
  font-weight: 700;
}

.price-original {
  font-size: 24rpx;
  line-height: 1;
  color: #999999;
  text-decoration: line-through;
}

.sales-copy {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.2;
  color: #999999;
  padding-bottom: 8rpx;
}

.logistics-bar {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #F9F5F1;
}

.logistics-bar-text {
  display: block;
  font-size: 22rpx;
  line-height: 1.7;
  color: #7F7065;
}

.mini-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.mini-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #F1F1F1;
  color: #555555;
  font-size: 20rpx;
  line-height: 1.5;
}

.mini-tag.promise-tag {
  background: rgba(161, 45, 39, 0.1);
  color: #A12D27;
  font-weight: 600;
}

.product-title {
  display: block;
  margin-top: 20rpx;
  font-size: 36rpx;
  line-height: 1.44;
  color: #333333;
  font-weight: 600;
}

.product-intro {
  display: block;
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: #8C837B;
}

.meta-row {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.meta-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #F7F2ED;
}

.meta-pill-text {
  font-size: 22rpx;
  line-height: 1.2;
  color: #7B6252;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.meta-stock {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.2;
  color: #A49B93;
}

.sku-entry {
  margin-top: 24rpx;
  padding: 22rpx 22rpx;
  border-radius: 24rpx;
  background: #FAF7F3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.sku-entry-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sku-entry-label {
  font-size: 24rpx;
  line-height: 1.2;
  color: #7B6252;
}

.sku-entry-value {
  font-size: 28rpx;
  line-height: 1.4;
  color: #B4AAA0;
}

.sku-entry-value.is-filled {
  color: #332A25;
  font-weight: 600;
}

.sku-entry-stock {
  font-size: 20rpx;
  line-height: 1.5;
  color: #A49B93;
}

.quantity-row {
  margin-top: 28rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #FAF7F3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.quantity-label {
  font-size: 28rpx;
  line-height: 1.2;
  color: #332A25;
  font-weight: 600;
}

.quantity-control {
  display: flex;
  align-items: center;
  border-radius: 18rpx;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: inset 0 0 0 1rpx rgba(80, 62, 50, 0.08);
}

.qty-btn {
  width: 68rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F7F2ED;
}

.qty-btn.disabled {
  opacity: 0.65;
}

.qty-value {
  min-width: 88rpx;
  height: 60rpx;
  text-align: center;
  line-height: 60rpx;
  font-size: 28rpx;
  color: #332A25;
  font-weight: 700;
  background: #FFFFFF;
}

.section-divider {
  width: 100%;
  height: 16rpx;
  background: #F5F5F5;
}

.cultural-section {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  background: #FFFFFF;
}

.traceability-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 30rpx 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(161, 45, 39, 0.11) 0%, rgba(161, 45, 39, 0.03) 100%);
  border: 1rpx solid rgba(161, 45, 39, 0.1);
}

.trace-main {
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  flex: 1;
}

.trace-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: rgba(161, 45, 39, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.trace-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.trace-label {
  font-size: 22rpx;
  line-height: 1.2;
  color: #8E5A48;
}

.trace-name {
  font-size: 34rpx;
  line-height: 1.3;
  color: #8F251D;
  font-weight: 700;
}

.trace-desc {
  font-size: 22rpx;
  line-height: 1.65;
  color: #8A7770;
}

.trace-action {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-left: 6rpx;
}

.trace-action-text {
  font-size: 24rpx;
  line-height: 1.2;
  color: #A12D27;
  font-weight: 600;
}

.workshop-surface {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx 26rpx;
  border-radius: 28rpx;
  background: #FDFBF9;
}

.workshop-main {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
}

.workshop-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #EBDCD1;
  flex-shrink: 0;
}

.workshop-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
}

.workshop-avatar-text {
  font-size: 30rpx;
  line-height: 1;
  color: #8F251D;
  font-weight: 700;
}

.workshop-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.workshop-name {
  display: block;
  font-size: 30rpx;
  line-height: 1.35;
  color: #2F241E;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.workshop-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.workshop-badge {
  max-width: 100%;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(161, 45, 39, 0.12);
  color: #A12D27;
  font-size: 20rpx;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.store-entry-btn {
  flex-shrink: 0;
  min-width: 164rpx;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 2rpx solid #A12D27;
  background: #FFFFFF;
  color: #A12D27;
  font-size: 24rpx;
  line-height: 72rpx;
  text-align: center;
  font-weight: 600;
  box-sizing: border-box;
}

.detail-images {
  background: #FFFFFF;
}

.detail-top-space {
  height: 32rpx;
  background: #FFFFFF;
}

.detail-image {
  width: 100%;
  display: block;
}

.bottom-placeholder {
  height: calc(170rpx + env(safe-area-inset-bottom));
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-bar-content {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 18rpx 24rpx 20rpx;
}

.action-icons {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 26rpx;
}

.action-icon-item {
  min-width: 68rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.action-icon-label {
  font-size: 20rpx;
  line-height: 1;
  color: #5C544D;
}

.cta-group {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: stretch;
  border-radius: 999rpx;
  overflow: hidden;
}

.cta-group-single .cta-btn {
  border-radius: 999rpx;
}

.cta-btn {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 700;
}

.cart-btn {
  background: #FFF3EA;
  color: #C7612C;
  border-right: 1rpx solid rgba(199, 97, 44, 0.12);
}

.buy-btn {
  background: #A12D27;
  color: #FFFFFF;
}

.cta-btn.is-disabled {
  opacity: 0.55;
}

.cart-btn text,
.buy-btn text {
  color: inherit;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.sku-popup {
  background: #FFFFFF;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
}

.sku-popup-header {
  position: relative;
  padding: 8rpx 0 20rpx;
  text-align: center;
}

.sku-popup-title {
  font-size: 32rpx;
  line-height: 1.2;
  color: #2C231E;
  font-weight: 700;
}

.sku-popup-close {
  position: absolute;
  top: 0;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F7F2EC;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sku-popup-preview {
  display: flex;
  gap: 20rpx;
  align-items: center;
  padding: 16rpx 0 24rpx;
}

.sku-popup-image {
  width: 168rpx;
  height: 168rpx;
  border-radius: 24rpx;
  background: #EFE5DB;
  flex-shrink: 0;
}

.sku-popup-price-block {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.sku-popup-price-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  flex-wrap: wrap;
}

.sku-popup-price {
  font-size: 42rpx;
  line-height: 1;
  color: #A12D27;
  font-weight: 800;
}

.sku-popup-price-suffix {
  font-size: 22rpx;
  line-height: 1;
  color: #A12D27;
  font-weight: 700;
}

.sku-popup-original {
  font-size: 22rpx;
  line-height: 1;
  color: #999999;
  text-decoration: line-through;
}

.sku-popup-stock,
.sku-popup-selected {
  font-size: 24rpx;
  line-height: 1.5;
  color: #7F7065;
}

.sku-section + .sku-section {
  margin-top: 24rpx;
}

.sku-section-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  line-height: 1.2;
  color: #332A25;
  font-weight: 700;
}

.sku-option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.sku-option {
  min-width: calc(50% - 7rpx);
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #F7F2ED;
  border: 1rpx solid transparent;
  box-sizing: border-box;
}

.sku-option.is-active {
  background: rgba(161, 45, 39, 0.08);
  border-color: rgba(161, 45, 39, 0.24);
}

.sku-option.is-disabled {
  opacity: 0.5;
}

.sku-option-name {
  display: block;
  font-size: 26rpx;
  line-height: 1.4;
  color: #332A25;
  font-weight: 600;
}

.sku-option-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #8A7A6E;
}

.quantity-row-popup {
  margin-top: 0;
}

.sku-popup-footer {
  margin-top: 28rpx;
}

.sku-confirm-btn {
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #C44437 0%, #A92E2A 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
}

.sku-confirm-btn.is-disabled {
  opacity: 0.55;
}
