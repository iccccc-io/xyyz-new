page {
  background: #F9F7F3;
  min-height: 100vh;
  color: #333333;
}

.mall-page {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.page-header {
  position: sticky;
  top: 0;
  z-index: 20;
  background: rgba(249, 247, 243, 0.92);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.header-inner {
  padding: 18rpx 20rpx 16rpx;
}

.capsule-offset {
  width: 100%;
}

.search-shell {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 72rpx;
  padding: 0 12rpx 0 22rpx;
  border-radius: 40rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 100%;
  font-size: 26rpx;
  color: #4B4038;
}

.search-placeholder {
  color: #B7B1AA;
  font-size: 26rpx;
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-action {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #F7EFE8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tabs-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.tabs-track {
  display: inline-flex;
  align-items: center;
  gap: 30rpx;
  padding-right: 20rpx;
}

.tab-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0 12rpx;
  flex-shrink: 0;
}

.tab-label {
  font-size: 26rpx;
  color: #999999;
  font-weight: 500;
  white-space: nowrap;
}

.tab-item.is-active .tab-label {
  color: #A12D27;
  font-size: 28rpx;
  font-weight: 700;
}

.tab-ink {
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 34rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #A12D27;
  transform: translateX(-50%);
}

.page-content {
  padding: 20rpx 20rpx 0;
}

.featured-block {
  margin-bottom: 24rpx;
}

.featured-card {
  position: relative;
  height: 360rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
  background: #EDE6DE;
}

.featured-image {
  width: 100%;
  height: 100%;
}

.featured-badge,
.featured-chip,
.card-badge {
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
  background: rgba(255, 255, 255, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: #FFFFFF;
}

.featured-badge {
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.featured-chip-row {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  display: flex;
  gap: 10rpx;
  justify-content: flex-end;
  max-width: 72%;
}

.featured-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.featured-gradient {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 55%;
  background: linear-gradient(to top, rgba(25, 18, 13, 0.64), rgba(25, 18, 13, 0));
}

.featured-content {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 18rpx;
}

.featured-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.4;
  color: #FFFFFF;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.featured-footer {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.featured-price {
  font-size: 36rpx;
  color: #FFF1E7;
  font-weight: 700;
}

.featured-note {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.feed-head {
  margin: 8rpx 0 20rpx;
}

.feed-head-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.feed-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #333333;
}

.feed-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #9B938B;
}

.filter-trigger {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid #E8DACE;
  background: #FFF9F3;
}

.filter-trigger.is-open {
  border-color: #D6B093;
  background: #FFF3EA;
}

.filter-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.28s ease;
}

.filter-arrow.is-open {
  transform: rotate(180deg);
}

.filter-trigger-text {
  font-size: 22rpx;
  color: #7F4A35;
  font-weight: 600;
}

.filter-count {
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 14rpx;
  background: #A12D27;
  color: #FFFFFF;
  font-size: 18rpx;
  line-height: 28rpx;
  text-align: center;
  box-sizing: border-box;
}

.filter-panel {
  margin-bottom: 0;
  padding: 0 18rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  opacity: 0;
  max-height: 0;
  transform: translateY(-8rpx);
  pointer-events: none;
  transition: max-height 0.28s ease, opacity 0.2s ease, transform 0.28s ease, margin 0.28s ease, padding 0.28s ease;
}

.filter-panel.is-open {
  margin-bottom: 24rpx;
  padding: 20rpx 18rpx 18rpx;
  opacity: 1;
  max-height: 1200rpx;
  transform: translateY(0);
  pointer-events: auto;
}

.filter-group + .filter-group {
  margin-top: 16rpx;
}

.filter-group-title {
  display: block;
  font-size: 24rpx;
  line-height: 1.2;
  color: #6B4A3A;
  font-weight: 600;
}

.filter-options {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.filter-option {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid #EDE3D9;
  background: #FAF6F1;
  color: #7E766F;
  font-size: 22rpx;
  line-height: 1.2;
}

.filter-option.is-active {
  border-color: #A12D27;
  background: #A12D27;
  color: #FFFFFF;
}

.filter-actions {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.filter-btn {
  flex: 1;
  height: 66rpx;
  border-radius: 33rpx;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-btn-reset {
  color: #7A6B60;
  background: #F5EEE7;
}

.filter-btn-apply {
  color: #FFFFFF;
  background: #A12D27;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 120rpx 0 80rpx;
}

.empty-state {
  padding: 100rpx 0 40rpx;
}

.waterfall-container {
  display: flex;
  gap: 16rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.card-media {
  position: relative;
  background: #EFE8E0;
}

.card-image {
  width: 100%;
  display: block;
}

.card-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  max-width: calc(100% - 32rpx);
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-body {
  padding: 16rpx;
}

.card-title {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 500;
  color: #333333;
}

.card-tag-row {
  margin-top: 12rpx;
}

.card-tag {
  display: inline-block;
  max-width: 100%;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  background: #F5F5F5;
  color: #7A6F66;
  font-size: 20rpx;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.card-tag-muted {
  color: #8F857D;
}

.card-footer {
  margin-top: 16rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 10rpx;
}

.card-price {
  display: flex;
  align-items: baseline;
  min-width: 0;
}

.price-symbol {
  font-size: 22rpx;
  color: #A12D27;
  font-weight: 700;
}

.price-value {
  font-size: 32rpx;
  color: #A12D27;
  font-weight: 700;
  line-height: 1;
}

.workshop-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  max-width: 52%;
  min-width: 0;
}

.workshop-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: #EADFD2;
  flex-shrink: 0;
}

.workshop-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F2E5D8;
}

.workshop-initial {
  font-size: 20rpx;
  color: #876456;
  font-weight: 600;
}

.workshop-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 20rpx;
  color: #999999;
}

.loading-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0 20rpx;
}

.no-more {
  padding: 48rpx 0 20rpx;
  text-align: center;
  font-size: 22rpx;
  color: #B2A59B;
}
