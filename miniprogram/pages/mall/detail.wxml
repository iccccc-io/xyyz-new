<view class="detail-page" wx:if="{{!loading && product}}">
  <view class="hero-section">
    <view class="hero-stage" style="top: {{heroCanvasTop}}px;">
      <view class="hero-canvas">
        <view class="hero-gallery">
          <view
            class="hero-slide {{currentImageIndex === index ? 'is-active' : ''}}"
            wx:for="{{product.heroImages}}"
            wx:key="*this"
            data-index="{{index}}"
            data-kind="hero"
            bindtap="previewImage"
          >
            <image class="hero-image" src="{{item}}" mode="aspectFill" />
          </view>
        </view>

        <view class="hero-nav hero-nav-prev" wx:if="{{product.heroImages.length > 1}}" catchtap="showPrevHeroImage"></view>
        <view class="hero-nav hero-nav-next" wx:if="{{product.heroImages.length > 1}}" catchtap="showNextHeroImage"></view>

        <view class="hero-indicator" wx:if="{{product.heroImages.length > 1}}">
          <text class="hero-indicator-text">{{currentImageIndex + 1}}/{{product.heroImages.length}}</text>
        </view>
      </view>
    </view>

    <view
      class="hero-back"
      bindtap="goBack"
      style="top: {{backButtonTop}}px; width: {{backButtonWidth}}px; height: {{backButtonHeight}}px;"
    >
      <van-icon name="arrow-left" size="18" color="#FFFFFF" />
    </view>
  </view>

  <view class="content-section">
    <view class="product-info-panel">
      <view class="core-info">
        <view class="price-row">
          <view class="price-main">
            <text class="price-currency">¥</text>
            <text class="price-number">{{product.displayPrice}}</text>
            <text class="price-suffix" wx:if="{{product.displayPriceSuffix}}">{{product.displayPriceSuffix}}</text>
            <text class="price-original" wx:if="{{product.displayOriginalPrice}}">¥{{product.displayOriginalPrice}}</text>
          </view>
          <text class="sales-copy">已售 {{product.salesDisplay}}</text>
        </view>

        <view class="logistics-bar" wx:if="{{product.logistics}}">
          <text class="logistics-bar-text">{{product.logistics.summaryText}}</text>
        </view>

        <view class="mini-tags" wx:if="{{(product.logistics && product.logistics.shippingPromiseText) || product.displayTags.length > 0}}">
          <text class="mini-tag promise-tag" wx:if="{{product.logistics && product.logistics.shippingPromiseText}}">
            {{product.logistics.shippingPromiseText}}
          </text>
          <text class="mini-tag" wx:for="{{product.displayTags}}" wx:key="*this">{{item}}</text>
        </view>

        <text class="product-title">{{product.title}}</text>
        <text class="product-intro">{{product.introDisplay}}</text>

        <view class="meta-row">
          <view class="meta-pill">
            <van-icon name="location-o" size="14" color="#7B6252" />
            <text class="meta-pill-text">{{product.originDisplay}}</text>
          </view>
          <text class="meta-stock">{{product.displaySkuName ? ('库存 ' + product.displayStock + ' 件') : ('总库存 ' + product.total_stock + ' 件')}}</text>
        </view>

        <view class="sku-entry" bindtap="openSkuPopup">
          <view class="sku-entry-main">
            <text class="sku-entry-label">选择款式</text>
            <text class="sku-entry-value {{product.displaySkuName ? 'is-filled' : ''}}">
              {{product.displaySkuName || (product.hasMultipleSkus ? '请选择商品款式' : (product.defaultSku ? product.defaultSku.sku_name : '默认款式'))}}
            </text>
            <text class="sku-entry-stock" wx:if="{{product.displaySkuName}}">当前库存 {{product.displayStock}} 件</text>
          </view>
          <van-icon name="arrow" size="16" color="#8A7A6E" />
        </view>
      </view>
    </view>

    <view class="section-divider" wx:if="{{product.related_project_name || product.workshop_info}}"></view>

    <view class="cultural-section" wx:if="{{product.related_project_name || product.workshop_info}}">
      <view class="traceability-card" wx:if="{{product.related_project_name}}" bindtap="goToProject">
        <view class="trace-main">
          <view class="trace-icon-wrap">
            <van-icon name="bookmark-o" size="22" color="#A12D27" />
          </view>
          <view class="trace-copy">
            <text class="trace-label">非遗溯源</text>
            <text class="trace-name">{{product.related_project_name}}</text>
            <text class="trace-desc">这件作品关联的技艺脉络与文化背景，点此继续了解。</text>
          </view>
        </view>
        <view class="trace-action">
          <text class="trace-action-text">去了解</text>
          <van-icon name="arrow" size="14" color="#A12D27" />
        </view>
      </view>

      <view class="workshop-surface" wx:if="{{product.workshop_info}}" bindtap="goToWorkshop">
        <view class="workshop-main">
          <image wx:if="{{product.workshop_info.logoDisplay}}" class="workshop-avatar" src="{{product.workshop_info.logoDisplay}}" mode="aspectFill" />
          <view wx:else class="workshop-avatar workshop-avatar-fallback">
            <text class="workshop-avatar-text">{{product.workshop_info.initial}}</text>
          </view>

          <view class="workshop-copy">
            <text class="workshop-name">{{product.workshop_info.name}}</text>
            <view class="workshop-meta" wx:if="{{product.workshopCardTag}}">
              <text class="workshop-badge">{{product.workshopCardTag}}</text>
            </view>
          </view>
        </view>

        <view class="store-entry-btn">进店看看</view>
      </view>
    </view>

    <view class="section-divider"></view>

    <view class="review-section">
      <view class="review-section-head">
        <view>
          <text class="review-section-title">匠心评价</text>
          <text class="review-section-subtitle">来自真实成交订单的买家反馈</text>
        </view>
        <view class="review-section-link" bindtap="goToProductReviews">
          <text>查看全部</text>
          <van-icon name="arrow" size="14" color="#A12D27" />
        </view>
      </view>

      <view class="review-summary-card">
        <view class="review-summary-score">
          <text class="review-summary-number">{{reviewSummary.displayScore}}</text>
          <text class="review-summary-desc">综合评分</text>
        </view>
        <view class="review-summary-meta">
          <text class="review-summary-count">共 {{reviewSummary.review_count || 0}} 条评价</text>
          <text class="review-summary-tip" wx:if="{{reviewSummary.review_count > 0}}">评价来自已完成订单，支持按款式查看</text>
          <text class="review-summary-tip" wx:else>暂无买家评价，期待第一条真实反馈</text>
        </view>
      </view>

      <view class="review-loading" wx:if="{{reviewLoading}}">
        <van-loading size="20px" color="#A12D27">加载评价中...</van-loading>
      </view>

      <view class="review-preview-list" wx:elif="{{reviewPreviewList.length > 0}}">
        <view class="review-preview-card" wx:for="{{reviewPreviewList}}" wx:key="_id">
          <view class="review-preview-user">
            <image class="review-preview-avatar" src="{{item.user_info.avatar}}" mode="aspectFill" />
            <view class="review-preview-meta">
              <text class="review-preview-name">{{item.user_info.nickname}}</text>
              <text class="review-preview-time" wx:if="{{item.buy_time_text}}">购买于 {{item.buy_time_text}}</text>
            </view>
            <text class="review-preview-score">{{item.avg_score_text}} 分</text>
          </view>

          <text class="review-preview-content" wx:if="{{item.content}}">{{item.content}}</text>
          <text class="review-preview-sku" wx:if="{{item.sku_text}}">{{item.sku_text}}</text>

          <view class="review-preview-images" wx:if="{{item.images && item.images.length > 0}}">
            <image
              wx:for="{{item.images}}"
              wx:for-item="image"
              wx:key="*this"
              class="review-preview-image"
              src="{{image}}"
              mode="aspectFill"
              data-index="{{index}}"
              data-urls="{{item.images}}"
              bindtap="previewReviewImages"
            />
          </view>
        </view>
      </view>

      <view class="review-empty" wx:else>
        <text>暂无评价，欢迎成为第一位分享体验的买家。</text>
      </view>
    </view>

    <view class="detail-images" wx:if="{{product.detailImages.length > 0}}">
      <view class="detail-top-space"></view>
      <image
        wx:for="{{product.detailImages}}"
        wx:key="*this"
        class="detail-image"
        src="{{item}}"
        mode="widthFix"
        lazy-load
        data-index="{{index}}"
        data-kind="{{'detail'}}"
        bindtap="previewImage"
      />
    </view>

    <view class="bottom-placeholder"></view>
  </view>
</view>

<view class="action-bar" style="padding-bottom: {{safeAreaBottom}}px;" wx:if="{{!loading && product}}">
  <view class="action-bar-content">
    <view class="action-icons">
      <view class="action-icon-item" bindtap="toggleFavorite">
        <van-icon name="{{isFavorite ? 'star' : 'star-o'}}" size="22" color="{{isFavorite ? '#A12D27' : '#4B4038'}}" />
        <text class="action-icon-label">{{isFavorite ? '已收藏' : '收藏'}}</text>
      </view>

      <view class="action-icon-item" wx:if="{{product.workshop_info}}" bindtap="goToWorkshop">
        <van-icon name="shop-o" size="22" color="#4B4038" />
        <text class="action-icon-label">工坊</text>
      </view>
    </view>

    <view class="cta-group cta-group-single">
      <view class="cta-btn buy-btn {{isUnavailable ? 'is-disabled' : ''}}" bindtap="buyNow">
        <text>立即购买</text>
      </view>
    </view>
  </view>
</view>

<van-popup
  show="{{showSkuPopup}}"
  position="bottom"
  round
  bind:close="closeSkuPopup"
  custom-style="background: transparent;"
>
  <view class="sku-popup">
    <view class="sku-popup-header">
      <text class="sku-popup-title">选择款式</text>
      <view class="sku-popup-close" bindtap="closeSkuPopup">
        <van-icon name="cross" size="18" color="#8F847A" />
      </view>
    </view>

    <view class="sku-popup-preview">
      <image class="sku-popup-image" src="{{product.displayImage || product.cover_img}}" mode="aspectFill" />
      <view class="sku-popup-price-block">
        <view class="sku-popup-price-row">
          <text class="sku-popup-price">¥{{product.displayPrice}}</text>
          <text class="sku-popup-price-suffix" wx:if="{{product.displayPriceSuffix}}">{{product.displayPriceSuffix}}</text>
          <text class="sku-popup-original" wx:if="{{product.displayOriginalPrice}}">¥{{product.displayOriginalPrice}}</text>
        </view>
        <text class="sku-popup-stock">库存 {{product.displayStock}} 件</text>
        <text class="sku-popup-selected">{{product.displaySkuName || (product.defaultSku ? product.defaultSku.sku_name : '默认款式')}}</text>
      </view>
    </view>

    <view class="sku-section">
      <text class="sku-section-title">款式</text>
      <view class="sku-option-list">
        <view
          class="sku-option {{selectedSkuId === item.sku_id ? 'is-active' : ''}} {{item.stock <= 0 ? 'is-disabled' : ''}}"
          wx:for="{{product.skus}}"
          wx:key="sku_id"
          data-id="{{item.sku_id}}"
          bindtap="selectSku"
        >
          <text class="sku-option-name">{{item.sku_name}}</text>
          <text class="sku-option-meta">¥{{item.priceDisplay}} / 库存 {{item.stock}}</text>
        </view>
      </view>
    </view>

    <view class="sku-section">
      <text class="sku-section-title">数量</text>
      <view class="quantity-row quantity-row-popup">
        <text class="quantity-label">购买数量</text>
        <view class="quantity-control">
          <view class="qty-btn {{quantity <= 1 ? 'disabled' : ''}}" bindtap="decreaseQuantity">
            <van-icon name="minus" size="16" color="{{quantity <= 1 ? '#BBB2A8' : '#4F4036'}}" />
          </view>
          <text class="qty-value">{{quantity}}</text>
          <view class="qty-btn {{quantity >= product.displayStock ? 'disabled' : ''}}" bindtap="increaseQuantity">
            <van-icon name="plus" size="16" color="{{quantity >= product.displayStock ? '#BBB2A8' : '#4F4036'}}" />
          </view>
        </view>
      </view>
    </view>

    <view class="sku-popup-footer">
      <view class="sku-confirm-btn {{product.displayStock <= 0 ? 'is-disabled' : ''}}" bindtap="confirmSkuBuy">
        确认购买
      </view>
    </view>
  </view>
</van-popup>

<view class="loading-state" wx:if="{{loading}}">
  <van-loading size="24px" color="#A12D27">加载中...</van-loading>
</view>
