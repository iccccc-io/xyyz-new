<!-- pages/mall/detail.wxml -->
<view class="detail-page" wx:if="{{!loading && product}}">
  <view class="hero-section">
    <swiper
      class="hero-swiper"
      circular="{{product.heroImages.length > 1}}"
      indicator-dots="{{false}}"
      bindchange="onSwiperChange"
    >
      <swiper-item
        wx:for="{{product.heroImages}}"
        wx:key="*this"
        data-index="{{index}}"
        data-kind="hero"
        bindtap="previewImage"
      >
        <image class="hero-image" src="{{item}}" mode="aspectFill" />
      </swiper-item>
    </swiper>

    <view class="hero-top-mask" style="height: {{heroMaskHeight}}px;"></view>

    <view
      class="hero-back"
      bindtap="goBack"
      style="top: {{backButtonTop}}px; width: {{backButtonWidth}}px; height: {{backButtonHeight}}px;"
    >
      <van-icon name="arrow-left" size="18" color="#FFFFFF" />
    </view>

    <view class="hero-indicator" wx:if="{{product.heroImages.length > 1}}">
      <text class="hero-indicator-text">{{currentImageIndex + 1}}/{{product.heroImages.length}}</text>
    </view>
  </view>

  <view class="content-section">
    <view class="core-info">
      <view class="price-row">
        <view class="price-main">
          <text class="price-currency">¥</text>
          <text class="price-number">{{product.priceDisplay}}</text>
          <text class="price-original" wx:if="{{product.originalPriceDisplay}}">¥{{product.originalPriceDisplay}}</text>
        </view>
        <text class="sales-copy">已售 {{product.salesDisplay}}</text>
      </view>

      <view class="mini-tags" wx:if="{{product.displayTags.length > 0}}">
        <text class="mini-tag" wx:for="{{product.displayTags}}" wx:key="*this">{{item}}</text>
      </view>

      <text class="product-title">{{product.title}}</text>
      <text class="product-intro">{{product.introDisplay}}</text>

      <view class="meta-row">
        <view class="meta-pill">
          <van-icon name="location-o" size="14" color="#7B6252" />
          <text class="meta-pill-text">{{product.originDisplay}}</text>
        </view>
        <text class="meta-stock">库存 {{product.stock}} 件</text>
      </view>

      <view class="quantity-row">
        <text class="quantity-label">购买数量</text>
        <view class="quantity-control">
          <view class="qty-btn {{quantity <= 1 ? 'disabled' : ''}}" bindtap="decreaseQuantity">
            <van-icon name="minus" size="16" color="{{quantity <= 1 ? '#BBB2A8' : '#4F4036'}}" />
          </view>
          <text class="qty-value">{{quantity}}</text>
          <view class="qty-btn {{quantity >= product.stock ? 'disabled' : ''}}" bindtap="increaseQuantity">
            <van-icon name="plus" size="16" color="{{quantity >= product.stock ? '#BBB2A8' : '#4F4036'}}" />
          </view>
        </view>
      </view>
    </view>

    <view class="section-divider" wx:if="{{product.related_project_name || product.workshop_info}}"></view>

    <view class="cultural-section" wx:if="{{product.related_project_name || product.workshop_info}}">
      <view class="traceability-card" wx:if="{{product.related_project_name}}" bindtap="goToProject">
        <view class="trace-main">
          <view class="trace-icon-wrap">
            <van-icon name="bookmark-o" size="22" color="#A12D27" />
          </view>
          <view class="trace-copy">
            <text class="trace-label">非遗溯源</text>
            <text class="trace-name">{{product.related_project_name}}</text>
            <text class="trace-desc">这件作品关联的技艺脉络与文化背景，点此继续了解。</text>
          </view>
        </view>
        <view class="trace-action">
          <text class="trace-action-text">去了解</text>
          <van-icon name="arrow" size="14" color="#A12D27" />
        </view>
      </view>

      <view class="workshop-surface" wx:if="{{product.workshop_info}}" bindtap="goToWorkshop">
        <view class="workshop-main">
          <image
            wx:if="{{product.workshop_info.logoDisplay}}"
            class="workshop-avatar"
            src="{{product.workshop_info.logoDisplay}}"
            mode="aspectFill"
          />
          <view wx:else class="workshop-avatar workshop-avatar-fallback">
            <text class="workshop-avatar-text">{{product.workshop_info.initial}}</text>
          </view>

          <view class="workshop-copy">
            <text class="workshop-name">{{product.workshop_info.name}}</text>
            <view class="workshop-meta" wx:if="{{product.workshopCardTag}}">
              <text class="workshop-badge">{{product.workshopCardTag}}</text>
            </view>
          </view>
        </view>

        <view class="store-entry-btn">进店看看</view>
      </view>
    </view>

    <view class="detail-images" wx:if="{{product.detailImages.length > 0}}">
      <view class="detail-top-space"></view>
      <image
        wx:for="{{product.detailImages}}"
        wx:key="*this"
        class="detail-image"
        src="{{item}}"
        mode="widthFix"
        lazy-load
        data-index="{{index}}"
        data-kind="detail"
        bindtap="previewImage"
      />
    </view>

    <view class="bottom-placeholder"></view>
  </view>
</view>

<view class="action-bar" style="padding-bottom: {{safeAreaBottom}}px;" wx:if="{{!loading && product}}">
  <view class="action-bar-content">
    <view class="action-icons">
      <view class="action-icon-item" bindtap="toggleFavorite">
        <van-icon name="{{isFavorite ? 'star' : 'star-o'}}" size="22" color="{{isFavorite ? '#A12D27' : '#4B4038'}}" />
        <text class="action-icon-label">{{isFavorite ? '已收藏' : '收藏'}}</text>
      </view>

      <view class="action-icon-item" wx:if="{{product.workshop_info}}" bindtap="goToWorkshop">
        <van-icon name="shop-o" size="22" color="#4B4038" />
        <text class="action-icon-label">工坊</text>
      </view>
    </view>

    <view class="cta-group">
      <view class="cta-btn cart-btn" bindtap="addToCart">
        <text>加入购物车</text>
      </view>
      <view class="cta-btn buy-btn" bindtap="buyNow">
        <text>立即购买</text>
      </view>
    </view>
  </view>
</view>

<view class="loading-state" wx:if="{{loading}}">
  <van-loading size="24px" color="#A12D27">加载中...</van-loading>
</view>
