.page {
  min-height: 100vh;
  background: #f7f1e8;
}

.page-loading {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content {
  padding: 24rpx 24rpx 220rpx;
}

.panel {
  margin-bottom: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fffdf9 0%, #fffaf4 100%);
  box-shadow: 0 14rpx 34rpx rgba(78, 53, 36, 0.08);
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.panel-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.panel-index {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: rgba(182, 59, 54, 0.08);
  color: #b63b36;
  font-size: 24rpx;
  line-height: 56rpx;
  text-align: center;
  font-weight: 700;
  flex-shrink: 0;
}

.panel-copy {
  flex: 1;
  min-width: 0;
}

.panel-title {
  display: block;
  font-size: 30rpx;
  color: #2f241e;
  font-weight: 700;
}

.field-block {
  margin-top: 20rpx;
}

.field-head,
.media-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.field-label {
  font-size: 26rpx;
  color: #2f241e;
  font-weight: 600;
}

.required-mark {
  color: #b63b36;
  margin-right: 6rpx;
}

.field-counter,
.field-unit {
  font-size: 22rpx;
  color: #9a8b80;
}

.field-input-shell,
.field-textarea {
  width: 100%;
  margin-top: 16rpx;
  padding: 24rpx 22rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #faf4eb;
  color: #2f241e;
  font-size: 28rpx;
  line-height: 1.7;
}

.field-input-shell {
  display: flex;
  align-items: center;
  min-height: 92rpx;
}

.field-input {
  width: 100%;
  height: 44rpx;
  line-height: 44rpx;
  padding: 0;
  color: #2f241e;
  font-size: 28rpx;
  background: transparent;
}

.field-textarea {
  height: 220rpx;
  min-height: 220rpx;
}

.profile-textarea {
  height: 180rpx;
  min-height: 180rpx;
}

.field-placeholder {
  color: #b1a79c;
}

.media-group + .media-group {
  margin-top: 30rpx;
}

.single-upload {
  margin-top: 18rpx;
}

.image-preview {
  position: relative;
  overflow: hidden;
  background-color: #f5f5f5;
}

.logo-preview {
  width: 192rpx;
  height: 192rpx;
  border-radius: 28rpx;
}

.cover-preview {
  width: 100%;
  height: 280rpx;
  border-radius: 24rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  display: block;
}

.delete-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 30rpx;
  line-height: 46rpx;
  text-align: center;
}

.upload-btn {
  border: 2rpx dashed #d8cec4;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #faf4eb;
}

.logo-upload {
  width: 192rpx;
  height: 192rpx;
}

.cover-upload {
  width: 100%;
  height: 220rpx;
}

.upload-title {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #5f4a3e;
  font-weight: 600;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #f7f1e8;
  box-shadow: 0 -8rpx 24rpx rgba(78, 53, 36, 0.08);
  backdrop-filter: blur(18px);
}
