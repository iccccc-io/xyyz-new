<view class="page">
  <nav-bar
    title="编辑资料"
    showTitle="{{true}}"
    showBack="{{true}}"
    background="solid"
    dark="{{true}}"
    placeholder="{{true}}"
  />

  <view class="page-loading" wx:if="{{loading}}">
    <van-loading size="26px" color="#b63b36" vertical>加载中...</van-loading>
  </view>

  <view class="content" wx:else>
    <view class="panel">
      <view class="panel-head">
        <view class="panel-title-wrap">
          <text class="panel-index">01</text>
          <view class="panel-copy">
            <text class="panel-title">昵称</text>
          </view>
        </view>
      </view>

      <view class="field-block">
        <view class="field-head">
          <text class="field-label"><text class="required-mark">*</text>用户昵称</text>
          <text class="field-counter">{{nicknameLength}}/20</text>
        </view>
        <view class="field-input-shell">
          <input
            class="field-input"
            maxlength="20"
            placeholder="请输入昵称"
            placeholder-class="field-placeholder"
            value="{{form.nickname}}"
            bindinput="onNicknameInput"
          />
        </view>
      </view>
    </view>

    <view class="panel">
      <view class="panel-head">
        <view class="panel-title-wrap">
          <text class="panel-index">02</text>
          <view class="panel-copy">
            <text class="panel-title">头像与背景</text>
          </view>
        </view>
      </view>

      <view class="media-group">
        <view class="media-label-row">
          <text class="field-label"><text class="required-mark">*</text>个人头像</text>
        </view>
        <view class="single-upload">
          <view class="image-preview logo-preview" wx:if="{{avatarFiles.length > 0}}">
            <image class="preview-image" src="{{avatarFiles[0].url}}" mode="aspectFill" bindtap="previewImage" data-url="{{avatarFiles[0].url}}" />
            <view class="delete-btn" catchtap="removeAvatar">×</view>
          </view>
          <view class="upload-btn logo-upload" wx:else bindtap="chooseAvatar">
            <van-icon name="edit" size="22" color="#9D938A" />
            <text class="upload-title">更换头像</text>
          </view>
        </view>
      </view>

      <view class="media-group">
        <view class="media-label-row">
          <text class="field-label">个人背景图</text>
          <text class="field-unit">选填</text>
        </view>
        <view class="single-upload">
          <view class="image-preview cover-preview" wx:if="{{coverFiles.length > 0}}">
            <image class="preview-image" src="{{coverFiles[0].url}}" mode="aspectFill" bindtap="previewImage" data-url="{{coverFiles[0].url}}" />
            <view class="delete-btn" catchtap="clearProfileBg">×</view>
          </view>
          <view class="upload-btn cover-upload" wx:else bindtap="chooseProfileBg">
            <van-icon name="photo-o" size="24" color="#9D938A" />
            <text class="upload-title">上传背景图</text>
          </view>
        </view>
      </view>
    </view>

    <view class="panel">
      <view class="panel-head">
        <view class="panel-title-wrap">
          <text class="panel-index">03</text>
          <view class="panel-copy">
            <text class="panel-title">个人简介</text>
          </view>
        </view>
      </view>

      <view class="field-block">
        <view class="field-head">
          <text class="field-label">简介内容</text>
          <text class="field-counter">{{bioLength}}/80</text>
        </view>
        <textarea
          class="field-textarea profile-textarea"
          maxlength="80"
          placeholder="介绍一下自己吧"
          placeholder-class="field-placeholder"
          value="{{form.bio}}"
          bindinput="onBioInput"
        />
      </view>
    </view>
  </view>

  <view class="footer" wx:if="{{!loading}}">
    <van-button
      type="primary"
      block
      round
      color="#b63b36"
      loading="{{submitting}}"
      disabled="{{submitting}}"
      bind:click="onSave"
    >
      {{saveButtonText}}
    </van-button>
  </view>
</view>
