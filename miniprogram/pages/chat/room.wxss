/* pages/chat/room.wxss */

page {
  height: 100%;
  background: #e8e8e8;
  overflow: hidden;
}

.page {
  height: 100%;
  position: relative;
  background: #e8e8e8;
}

/* ========== 动画定义 ========== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in {
  animation: fadeInUp 0.25s ease-out;
}

/* ========== 导航栏 ========== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
  box-shadow: 0 1px 0 rgba(0,0,0,0.06);
}

.nav-content {
  display: flex;
  align-items: center;
  height: 44px;
  padding: 0 12px;
}

.back-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  transition: background 0.2s;
}

.back-btn:active {
  background: rgba(0, 0, 0, 0.1);
}

.nav-nickname {
  flex: 1;
  font-size: 17px;
  font-weight: 600;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-right {
  width: 32px;
}

/* ========== 消息列表 ========== */
.message-list {
  position: fixed;
  left: 0;
  right: 0;
  overflow-y: auto;
}

.message-list-inner {
  padding: 12px 12px 20px;
}

.load-tip {
  text-align: center;
  padding: 16px 0;
}

.tip-text {
  font-size: 12px;
  color: #bbb;
}

/* ========== 时间线 ========== */
.time-line {
  text-align: center;
  padding: 16px 0;
}

.time-line text {
  font-size: 12px;
  color: #8e8e93;
  background: rgba(0,0,0,0.04);
  padding: 4px 10px;
  border-radius: 10px;
}

/* ========== 消息行 ========== */
.msg-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 12px;
  gap: 8px;
  animation: msgFadeIn 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
}

@keyframes msgFadeIn {
  0% { 
    opacity: 0; 
    transform: translateY(10px);
  }
  100% { 
    opacity: 1; 
    transform: translateY(0);
  }
}

.msg-other {
  flex-direction: row;
  transform-origin: left bottom;
}

.msg-self {
  flex-direction: row-reverse;
  transform-origin: right bottom;
}

.avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  flex-shrink: 0;
}

.msg-content {
  display: flex;
  align-items: center;
  gap: 6px;
  max-width: 70%;
}

.msg-self .msg-content {
  flex-direction: row-reverse;
}

/* ========== 气泡 ========== */
.bubble {
  padding: 10px 14px;
  border-radius: 18px;
  max-width: 100%;
  word-break: break-all;
  transition: opacity 0.2s;
}

.bubble-other {
  background: #fff;
  border-top-left-radius: 4px;
}

.bubble-self {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border-top-right-radius: 4px;
}

.bubble-other .bubble-text {
  color: #1a1a1a;
  font-size: 16px;
  line-height: 1.4;
}

.bubble-self .bubble-text {
  color: #fff;
  font-size: 16px;
  line-height: 1.4;
}

.bubble.sending {
  opacity: 0.6;
}

/* ========== 图片消息 ========== */
.img-wrap {
  position: relative;
  max-width: 200px;
  border-radius: 12px;
  overflow: hidden;
}

.msg-img {
  width: 100%;
  display: block;
  border-radius: 12px;
}

.img-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== 失败标记 ========== */
.msg-fail {
  width: 18px;
  height: 18px;
  background: #e74c3c;
  color: #fff;
  font-size: 12px;
  font-weight: bold;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ========== 底部输入区域 (TG 风格) ========== */
.input-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  /* 使用 transform 做位移动画，GPU 加速避免 input 文字延迟 */
  transition: transform 0.25s cubic-bezier(0.25, 0.1, 0.25, 1);
  will-change: transform;
}

/* TG 风格胶囊输入框 */
.input-capsule {
  display: flex;
  align-items: center;
  margin: 8px;
  padding: 4px;
  /* 亮白色玻璃质感 */
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-radius: 22px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.capsule-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  transition: background-color 0.2s ease, transform 0.15s ease;
}

.capsule-btn:active {
  background-color: rgba(0, 0, 0, 0.06);
  transform: scale(0.88);
}

.capsule-btn.active {
  background-color: rgba(0, 122, 255, 0.12);
}

/* 左侧表情/键盘图标切换动画 */
.left-btn {
  position: relative;
  overflow: hidden;
}

.left-btn van-icon {
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.left-btn.active van-icon {
  animation: iconPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes iconPop {
  0% { transform: scale(0.5) rotate(-20deg); opacity: 0.5; }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

.input-field {
  flex: 1;
  height: 36px;
  font-size: 16px;
  color: #1a1a1a;
  background: transparent;
  padding: 0 8px;
}

.input-placeholder {
  color: rgba(0, 0, 0, 0.35);
}

/* 附件图标旋转 */
.attach-icon {
  transform: rotate(-45deg);
  transition: transform 0.15s ease;
}

.right-btn:active .attach-icon {
  transform: rotate(-45deg) scale(0.85);
}

/* 发送按钮 - 弹性动画 */
.send-btn {
  width: 0;
  height: 36px;
  background: linear-gradient(135deg, #007aff 0%, #0056b3 100%);
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  opacity: 0;
  margin-left: 0;
  box-shadow: 0 2px 8px rgba(0, 122, 255, 0);
  transition: 
    width 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
    opacity 0.2s ease,
    margin-left 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
    box-shadow 0.2s ease;
}

.send-btn.show {
  width: 36px;
  opacity: 1;
  margin-left: 4px;
  box-shadow: 0 2px 8px rgba(0, 122, 255, 0.3);
}

.send-btn:active {
  transform: scale(0.88);
  transition: transform 0.1s ease;
}

/* ========== 表情面板 (TG 风格) ========== */
.emoji-panel {
  height: 0;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 16px 16px 0 0;
  margin: 0 8px 8px;
  opacity: 0;
  transform: translateY(20px);
  transition: 
    height 0.28s cubic-bezier(0.25, 0.1, 0.25, 1),
    opacity 0.2s ease,
    transform 0.28s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.emoji-panel.show {
  height: 280px;
  opacity: 1;
  transform: translateY(0);
}

/* 搜索栏 */
.emoji-search {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 12px 12px 8px;
  padding: 8px 12px;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 10px;
  transition: background 0.2s;
}

.emoji-search:focus-within {
  background: rgba(0, 0, 0, 0.08);
}

.search-input {
  flex: 1;
  height: 24px;
  font-size: 14px;
  color: #1a1a1a;
  background: transparent;
}

.search-placeholder {
  color: rgba(0, 0, 0, 0.4);
}

.search-clear {
  padding: 4px;
  transition: transform 0.2s;
}

.search-clear:active {
  transform: scale(0.85);
}

/* 分类标签 */
.emoji-tabs {
  height: 40px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

.tabs-row {
  display: inline-flex;
  height: 40px;
  padding: 0 8px;
}

.tab-item {
  width: 40px;
  height: 40px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  opacity: 0.4;
  position: relative;
  transition: opacity 0.2s ease, transform 0.15s ease;
}

.tab-item:active {
  transform: scale(0.85);
}

.tab-item.active {
  opacity: 1;
}

.tab-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 20px;
  height: 2px;
  background: #007aff;
  border-radius: 1px;
  transform: translateX(-50%) scaleX(0);
  opacity: 0;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.2s ease;
}

.tab-item.active::after {
  transform: translateX(-50%) scaleX(1);
  opacity: 1;
}

/* 表情内容区 */
.emoji-content {
  height: calc(100% - 100px);
}

.emoji-section {
  padding: 8px 12px;
}

.section-title {
  font-size: 13px;
  color: rgba(0, 0, 0, 0.5);
  margin-bottom: 8px;
  font-weight: 500;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
}

.emoji-item {
  width: 12.5%;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  border-radius: 8px;
  transition: all 0.15s ease;
}

.emoji-item:active {
  background: rgba(0, 0, 0, 0.05);
  transform: scale(1.2);
}

.no-result {
  text-align: center;
  padding: 40px 0;
  color: rgba(0, 0, 0, 0.4);
  font-size: 14px;
}

/* ========== 空状态 & 加载 ========== */
.empty, .loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.empty-icon {
  font-size: 60px;
}

.empty-text {
  font-size: 15px;
  color: #8e8e93;
}
