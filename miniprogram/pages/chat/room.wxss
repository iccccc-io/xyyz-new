/* pages/chat/room.wxss */

page {
  height: 100%;
  background: #f5f7f8;
  overflow: hidden;
}

.page {
  height: 100%;
  position: relative;
  background: #f5f7f8;
}

/* ========== 动画定义 ========== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in {
  animation: fadeInUp 0.25s ease-out;
}

/* ========== 导航栏 ========== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 1px 0 rgba(15, 23, 42, 0.06);
}

.nav-content {
  display: flex;
  align-items: center;
  height: 44px;
  padding: 0 12px 0 10px;
}

.back-btn,
.nav-menu-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #f5f7f9;
  border: 1px solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}

.back-btn {
  margin-right: 10px;
}

.nav-menu-btn {
  margin-right: 14px;
}

.back-btn:active,
.nav-menu-btn:active {
  background: #edf1f4;
}

.nav-nickname {
  font-size: 17px;
  font-weight: 700;
  color: #18212b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.nav-subtitle {
  font-size: 11px;
  color: #7b8794;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 消息列表 ========== */
.message-list {
  position: fixed;
  left: 0;
  right: 0;
  overflow-y: auto;
}

.message-list-inner {
  padding: 16px 16px 24px;
}

.load-tip {
  text-align: center;
  padding: 16px 0;
}

.tip-text {
  font-size: 12px;
  color: #bbb;
}

/* ========== 时间线 ========== */
.time-line {
  text-align: center;
  padding: 16px 0;
}

.time-line text {
  font-size: 12px;
  color: #7b8794;
  background: #eef2f4;
  padding: 6px 12px;
  border-radius: 999px;
}

/* ========== 消息行 ========== */
.msg-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 16px;
  gap: 10px;
  animation: msgFadeIn 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
}

@keyframes msgFadeIn {
  0% { 
    opacity: 0; 
    transform: translateY(10px);
  }
  100% { 
    opacity: 1; 
    transform: translateY(0);
  }
}

.msg-other {
  flex-direction: row;
  transform-origin: left bottom;
}

.msg-self {
  flex-direction: row-reverse;
  transform-origin: right bottom;
}

.avatar {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 4px 12px rgba(148, 163, 184, 0.1);
}

.msg-content {
  display: flex;
  align-items: flex-end;
  gap: 8px;
  max-width: 74%;
}

.msg-self .msg-content {
  flex-direction: row-reverse;
}

/* 图片消息不需要受 max-width 限制 */
.msg-content .img-wrap {
  max-width: none;
}

/* ========== 气泡 ========== */
.bubble {
  padding: 12px 15px;
  border-radius: 22px;
  max-width: 100%;
  word-break: break-all;
  transition: opacity 0.2s, transform 0.2s;
  border: 1px solid #e5ebee;
}

.bubble-other {
  background: #ffffff;
  border-top-left-radius: 8px;
}

.bubble-self {
  background: #e8f3ef;
  border-top-right-radius: 8px;
  border-color: #dbe8e2;
}

.bubble-other .bubble-text {
  color: #1f2937;
  font-size: 16px;
  line-height: 1.55;
}

.bubble-self .bubble-text {
  color: #163040;
  font-size: 16px;
  line-height: 1.55;
}

.bubble.sending {
  opacity: 0.62;
}

/* ========== 图片消息 ========== */
.img-wrap {
  position: relative;
  min-width: 120px;
  max-width: 280px;
  border-radius: 18px;
  overflow: hidden;
  border: 1px solid #e3e8ec;
  box-shadow: 0 8px 20px rgba(148, 163, 184, 0.12);
}

.msg-img {
  width: 100%;
  display: block;
  border-radius: 18px;
}

/* 上传中状态 - 使用固定尺寸避免闪烁 */
.img-wrap.uploading {
  width: 180px;
  height: 180px;
  background: #f0f0f0;
}

.img-wrap.uploading .msg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.img-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.35);
  backdrop-filter: blur(2px);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== 失败标记 ========== */
.msg-fail {
  width: 18px;
  height: 18px;
  background: #e25c5c;
  color: #fff;
  font-size: 12px;
  font-weight: bold;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ========== 撤回消息 ========== */
.revoked-msg {
  text-align: center;
  padding: 8px 0;
  margin: 4px 0;
}

.revoked-msg text {
  font-size: 12px;
  color: #8a94a3;
  background: #eef2f5;
  padding: 5px 12px;
  border-radius: 999px;
  border: 1px solid #e5eaee;
}

/* ========== 引用块（气泡内） ========== */
.quote-block {
  background: #f4f7f8;
  border-left: 3px solid #b7c4ce;
  padding: 7px 10px;
  margin-bottom: 8px;
  border-radius: 10px;
  max-width: 100%;
}

.bubble-self .quote-block {
  background: #deebe6;
  border-left-color: #98b8ac;
}

.quote-name {
  font-size: 12px;
  font-weight: 600;
  color: rgba(31, 41, 55, 0.72);
  display: block;
  margin-bottom: 2px;
}

.bubble-self .quote-name {
  color: rgba(22, 48, 64, 0.78);
}

.quote-content {
  font-size: 12px;
  color: rgba(71, 85, 105, 0.76);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 180px;
}

.bubble-self .quote-content {
  color: rgba(51, 65, 85, 0.8);
}

/* 图片消息的引用块 */
.img-quote {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(17, 24, 39, 0.56);
  border-left: none;
  border-radius: 18px 18px 0 0;
  z-index: 1;
}

.img-quote .quote-name,
.img-quote .quote-content {
  color: rgba(255, 255, 255, 0.9);
}

/* ========== 引用预览栏 ========== */
.quote-preview {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 14px;
  background: #ffffff;
  border-radius: 18px 18px 0 0;
  margin: 0 10px;
  border-bottom: 1px solid #edf1f4;
}

.quote-preview-content {
  display: flex;
  align-items: stretch;
  flex: 1;
  min-width: 0;
}

.quote-preview-line {
  width: 3px;
  background: #93b7aa;
  border-radius: 2px;
  margin-right: 10px;
}

.quote-preview-info {
  flex: 1;
  min-width: 0;
}

.quote-preview-name {
  font-size: 13px;
  font-weight: 600;
  color: #347a98;
  display: block;
  margin-bottom: 2px;
}

.quote-preview-text {
  font-size: 12px;
  color: #6b7280;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quote-preview-close {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8px;
}

/* ========== 长按菜单 ========== */
.menu-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.15s ease;
}

.menu-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.msg-menu {
  position: fixed;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
  white-space: nowrap; /* 防止菜单项换行 */
}

.msg-menu.show {
  opacity: 1;
  pointer-events: auto;
}

/* 箭头在底部（菜单在消息上方） */
.menu-arrow {
  width: 10px;
  height: 10px;
  background: rgba(48, 48, 48, 0.96);
  transform: rotate(45deg);
  position: absolute;
  bottom: -5px;
}

/* 箭头在顶部（菜单在消息下方） */
.msg-menu.arrow-top .menu-arrow {
  bottom: auto;
  top: -5px;
}

.menu-content {
  display: flex;
  background: rgba(48, 48, 48, 0.96);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-radius: 10px;
  padding: 6px 4px;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 5px 10px;
  min-width: 36px;
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 6px;
}

.menu-item text {
  font-size: 10px;
  color: #fff;
  margin-top: 4px;
  letter-spacing: 0.5px;
}

/* ========== 底部输入区域 (TG 风格) ========== */
.input-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  /* 使用 transform 做位移动画，GPU 加速避免 input 文字延迟 */
  transition: transform 0.25s cubic-bezier(0.25, 0.1, 0.25, 1);
  will-change: transform;
}

.send-tip {
  margin: 0 14px 8px;
  padding: 11px 14px;
  border-radius: 16px;
  background: #eef3f4;
  border: 1px solid #e3e9ec;
}

.send-tip text {
  font-size: 12px;
  color: #768190;
}

/* TG 风格胶囊输入框 */
.input-capsule {
  display: flex;
  align-items: center;
  margin: 10px;
  padding: 6px;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 26px;
  border: 1px solid #e5e9ee;
  box-shadow: 0 10px 24px rgba(148, 163, 184, 0.1);
}

.capsule-btn {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  transition: background-color 0.2s ease, transform 0.15s ease;
}

.capsule-btn:active {
  background-color: rgba(148, 163, 184, 0.12);
  transform: scale(0.88);
}

.capsule-btn.active {
  background-color: rgba(124, 167, 156, 0.12);
}

.capsule-btn.disabled {
  opacity: 0.45;
}

/* 左侧表情/键盘图标切换动画 */
.left-btn {
  position: relative;
  overflow: hidden;
}

.left-btn van-icon {
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.left-btn.active van-icon {
  animation: iconPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes iconPop {
  0% { transform: scale(0.5) rotate(-20deg); opacity: 0.5; }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

.input-field {
  flex: 1;
  height: 40px;
  font-size: 16px;
  color: #18212b;
  background: transparent;
  padding: 0 10px;
}

.input-placeholder {
  color: rgba(0, 0, 0, 0.35);
}

.input-field[disabled] {
  color: #9a9aa0;
}

/* 附件图标旋转 */
.attach-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #f1f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 0 1px #e1e8ec;
  transition: transform 0.15s ease, background-color 0.15s ease;
}

.right-btn:active .attach-icon {
  transform: scale(0.88);
  background: #e8edf1;
}

/* 发送按钮 - 弹性动画 */
.send-btn {
  width: 0;
  height: 40px;
  background: #7ca79c;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  opacity: 0;
  margin-left: 0;
  box-shadow: 0 4px 12px rgba(124, 167, 156, 0);
  transition: 
    width 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
    opacity 0.2s ease,
    margin-left 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
    box-shadow 0.2s ease;
}

.send-btn.show {
  width: 40px;
  opacity: 1;
  margin-left: 6px;
  box-shadow: 0 8px 18px rgba(124, 167, 156, 0.2);
}

.send-btn:active {
  transform: scale(0.88);
  transition: transform 0.1s ease;
}

.send-btn.disabled {
  opacity: 0.4;
}

/* ========== 表情面板 (TG 风格) ========== */
.emoji-panel {
  height: 0;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 16px 16px 0 0;
  margin: 0 8px 8px;
  opacity: 0;
  transform: translateY(20px);
  transition: 
    height 0.28s cubic-bezier(0.25, 0.1, 0.25, 1),
    opacity 0.2s ease,
    transform 0.28s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.emoji-panel.show {
  height: 280px;
  opacity: 1;
  transform: translateY(0);
}

/* 搜索栏 */
.emoji-search {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 12px 12px 8px;
  padding: 8px 12px;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 10px;
  transition: background 0.2s;
}

.emoji-search:focus-within {
  background: rgba(0, 0, 0, 0.08);
}

.search-input {
  flex: 1;
  height: 24px;
  font-size: 14px;
  color: #1a1a1a;
  background: transparent;
}

.search-placeholder {
  color: rgba(0, 0, 0, 0.4);
}

.search-clear {
  padding: 4px;
  transition: transform 0.2s;
}

.search-clear:active {
  transform: scale(0.85);
}

/* 分类标签 */
.emoji-tabs {
  height: 40px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

.tabs-row {
  display: inline-flex;
  height: 40px;
  padding: 0 8px;
}

.tab-item {
  width: 40px;
  height: 40px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  opacity: 0.4;
  position: relative;
  transition: opacity 0.2s ease, transform 0.15s ease;
}

.tab-item:active {
  transform: scale(0.85);
}

.tab-item.active {
  opacity: 1;
}

.tab-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 20px;
  height: 2px;
  background: #007aff;
  border-radius: 1px;
  transform: translateX(-50%) scaleX(0);
  opacity: 0;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.2s ease;
}

.tab-item.active::after {
  transform: translateX(-50%) scaleX(1);
  opacity: 1;
}

/* 表情内容区 */
.emoji-content {
  height: calc(100% - 100px);
}

.emoji-section {
  padding: 8px 12px;
}

.section-title {
  font-size: 13px;
  color: rgba(0, 0, 0, 0.5);
  margin-bottom: 8px;
  font-weight: 500;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
}

.emoji-item {
  width: 12.5%;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  border-radius: 8px;
  transition: all 0.15s ease;
}

.emoji-item:active {
  background: rgba(0, 0, 0, 0.05);
  transform: scale(1.2);
}

.no-result {
  text-align: center;
  padding: 40px 0;
  color: rgba(0, 0, 0, 0.4);
  font-size: 14px;
}

/* ========== 空状态 & 加载 ========== */
.empty, .loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.empty-icon {
  font-size: 60px;
}

.empty-text {
  font-size: 15px;
  color: #8e8e93;
}
