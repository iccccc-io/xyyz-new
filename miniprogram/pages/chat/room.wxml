<!-- pages/chat/room.wxml -->
<view class="page">
  <!-- 顶部导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="back-btn" bindtap="goBack">
        <van-icon name="arrow-left" size="18px" color="#333" />
      </view>
      <view class="nav-menu-btn" bindtap="openManagePage">
        <van-icon name="ellipsis" size="18px" color="#333" />
      </view>
      <view class="nav-title-wrap" bindtap="goToUserProfile">
        <text class="nav-nickname">{{displayName || targetUser.nickname || '用户'}}</text>
        <text class="nav-subtitle" wx:if="{{relationMeta.remarkName}}">{{targetUser.nickname}}</text>
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view 
    class="message-list"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
    upper-threshold="50"
    bindscrolltoupper="loadMoreMessages"
    enhanced
    show-scrollbar="{{false}}"
    style="top: {{navBarHeight}}px; bottom: {{bottomHeight}}px;"
  >
    <view class="message-list-inner">
      <view class="load-tip" wx:if="{{loadingMore}}">
        <van-loading size="18px" color="#999">加载中...</van-loading>
      </view>
      <view class="load-tip" wx:elif="{{noMore && messages.length > 0}}">
        <text class="tip-text">— 没有更多消息了 —</text>
      </view>

      <block wx:for="{{messages}}" wx:key="_id">
        <view class="time-line" wx:if="{{item.showTime}}">
          <text>{{item.timeStr}}</text>
        </view>

        <!-- 撤回消息显示 -->
        <view wx:if="{{item.is_revoked}}" class="revoked-msg">
          <text>{{item.sender_id === currentUser.openid ? '你' : '对方'}}撤回了一条消息</text>
        </view>

        <!-- 正常消息 -->
        <view 
          wx:else
          id="msg-{{item._id}}" 
          class="msg-row {{item.sender_id === currentUser.openid ? 'msg-self' : 'msg-other'}} animate-fade-in"
        >
          <image 
            class="avatar" 
            src="{{item.sender_id === currentUser.openid ? (currentUser.avatar || '/images/avatar.png') : (targetUser.avatar || '/images/avatar.png')}}" 
            bindtap="{{item.sender_id !== currentUser.openid ? 'goToUserProfile' : ''}}"
          />
          <view class="msg-content">
            <view class="msg-fail" wx:if="{{item.sender_id === currentUser.openid && item.status === 'failed'}}" bindtap="resendMessage" data-msg="{{item}}">!</view>
            
            <!-- 文本消息 -->
            <view 
              wx:if="{{item.msg_type === 'text'}}" 
              class="bubble {{item.sender_id === currentUser.openid ? 'bubble-self' : 'bubble-other'}} {{item.status === 'sending' ? 'sending' : ''}}"
              bindlongpress="onMsgLongPress"
              data-msg="{{item}}"
            >
              <!-- 引用块 -->
              <view wx:if="{{item.quote_msg}}" class="quote-block" bindtap="scrollToQuote" data-id="{{item.quote_msg.msg_id}}">
                <text class="quote-name">{{item.quote_msg.sender_name}}</text>
                <text class="quote-content">{{item.quote_msg.content}}</text>
              </view>
              <text class="bubble-text" user-select decode>{{item.content}}</text>
            </view>
            
            <!-- 图片消息 -->
            <view 
              wx:elif="{{item.msg_type === 'image'}}" 
              class="img-wrap {{item.status === 'uploading' ? 'uploading' : ''}}"
              bindlongpress="onMsgLongPress"
              data-msg="{{item}}"
            >
              <!-- 引用块（图片消息也可以有引用） -->
              <view wx:if="{{item.quote_msg}}" class="quote-block img-quote" bindtap="scrollToQuote" data-id="{{item.quote_msg.msg_id}}">
                <text class="quote-name">{{item.quote_msg.sender_name}}</text>
                <text class="quote-content">{{item.quote_msg.content}}</text>
              </view>
              <image class="msg-img" src="{{item.content}}" mode="{{item.status === 'uploading' ? 'aspectFill' : 'widthFix'}}" bindtap="previewImage" data-src="{{item.content}}" />
              <view class="img-loading" wx:if="{{item.status === 'uploading'}}">
                <van-loading size="24px" color="#fff" />
              </view>
            </view>
          </view>
        </view>
      </block>

      <view id="msg-bottom" style="height: 1px;"></view>
    </view>
  </scroll-view>

  <!-- 底部输入区域 (TG 风格) -->
  <view class="input-area {{showEmojiPanel ? 'panel-open' : ''}}" style="transform: translateY(-{{keyboardHeight}}px); padding-bottom: {{safeAreaBottom}}px;">
    <view class="send-tip" wx:if="{{sendDisabled}}">
      <text>由于对方未关注你，需等待对方回复后才能继续发送</text>
    </view>

    <!-- 引用预览栏 -->
    <view class="quote-preview" wx:if="{{quoteMsg}}">
      <view class="quote-preview-content">
        <view class="quote-preview-line"></view>
        <view class="quote-preview-info">
          <text class="quote-preview-name">{{quoteMsg.sender_name}}</text>
          <text class="quote-preview-text">{{quoteMsg.content}}</text>
        </view>
      </view>
      <view class="quote-preview-close" bindtap="clearQuote">
        <van-icon name="cross" size="16px" color="#999" />
      </view>
    </view>

    <!-- TG 风格输入框 -->
    <view class="input-capsule">
      <!-- 左侧：表情/键盘切换 -->
      <view class="capsule-btn left-btn {{showEmojiPanel ? 'active' : ''}} {{sendDisabled ? 'disabled' : ''}}" bindtap="toggleEmojiPanel">
        <van-icon name="{{showEmojiPanel ? 'keyboard-o' : 'smile-o'}}" size="24px" color="{{showEmojiPanel ? '#007aff' : '#8e8e93'}}" />
      </view>

      <!-- 中间：输入框 -->
      <input 
        class="input-field"
        value="{{inputValue}}"
        placeholder="{{inputPlaceholder}}"
        placeholder-class="input-placeholder"
        bindinput="onInput"
        bindfocus="onInputFocus"
        bindblur="onInputBlur"
        bindconfirm="sendTextMessage"
        confirm-type="send"
        confirm-hold
        adjust-position="{{false}}"
        cursor-spacing="10"
        focus="{{inputFocus}}"
        disabled="{{sendDisabled}}"
      />

      <!-- 右侧：附件按钮 -->
      <view class="capsule-btn right-btn {{sendDisabled ? 'disabled' : ''}}" bindtap="showAttachMenu">
        <view class="attach-icon">
          <van-icon name="photo-o" size="20px" color="#5d7588" />
        </view>
      </view>

      <!-- 发送按钮（有内容时显示） -->
      <view class="send-btn {{inputValue && !sendDisabled ? 'show' : ''}} {{sendDisabled ? 'disabled' : ''}}" bindtap="sendTextMessage">
        <van-icon name="arrow-up" size="18px" color="#fff" />
      </view>
    </view>

    <!-- 表情面板 -->
    <view class="emoji-panel {{showEmojiPanel ? 'show' : ''}}">
      <!-- 搜索栏 -->
      <view class="emoji-search">
        <van-icon name="search" size="16px" color="#8e8e93" />
        <input 
          class="search-input"
          placeholder="搜索表情"
          placeholder-class="search-placeholder"
          value="{{emojiSearchKey}}"
          bindinput="onEmojiSearch"
          bindconfirm="onEmojiSearch"
        />
        <view class="search-clear" wx:if="{{emojiSearchKey}}" bindtap="clearEmojiSearch">
          <van-icon name="clear" size="16px" color="#c0c0c0" />
        </view>
      </view>

      <!-- 分类标签 -->
      <scroll-view scroll-x class="emoji-tabs" wx:if="{{!emojiSearchKey}}" enhanced show-scrollbar="{{false}}">
        <view class="tabs-row">
          <view 
            class="tab-item {{emojiActiveTab === idx ? 'active' : ''}}" 
            wx:for="{{emojiCategories}}" 
            wx:for-index="idx"
            wx:key="key"
            bindtap="switchEmojiTab"
            data-idx="{{idx}}"
          >{{item.icon}}</view>
        </view>
      </scroll-view>

      <!-- 表情内容 -->
      <scroll-view scroll-y class="emoji-content" scroll-into-view="{{emojiScrollTo}}">
        <!-- 搜索结果 -->
        <view wx:if="{{emojiSearchKey}}" class="emoji-section">
          <view class="section-title">搜索结果</view>
          <view class="emoji-grid" wx:if="{{emojiSearchResults.length > 0}}">
            <view 
              class="emoji-item" 
              wx:for="{{emojiSearchResults}}" 
              wx:key="*this"
              bindtap="insertEmoji"
              data-e="{{item}}"
            >{{item}}</view>
          </view>
          <view class="no-result" wx:else>
            <text>没有找到相关表情</text>
          </view>
        </view>

        <!-- 分类表情 -->
        <block wx:else>
          <view 
            class="emoji-section" 
            wx:for="{{emojiCategories}}" 
            wx:key="key"
            id="cat-{{item.key}}"
          >
            <view class="section-title">{{item.name}}</view>
            <view class="emoji-grid">
              <view 
                class="emoji-item" 
                wx:for="{{item.emojis}}" 
                wx:for-item="e"
                wx:key="*this"
                bindtap="insertEmoji"
                data-e="{{e}}"
              >{{e}}</view>
            </view>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && messages.length === 0}}">
    <text class="empty-icon">💬</text>
    <text class="empty-text">开始聊天吧</text>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <van-loading size="28px" color="#b63b36" vertical>加载中</van-loading>
  </view>

  <!-- 长按菜单遮罩 -->
  <view class="menu-overlay {{showMsgMenu ? 'show' : ''}}" bindtap="closeMsgMenu"></view>

  <!-- 长按菜单 -->
  <view class="msg-menu {{showMsgMenu ? 'show' : ''}} {{menuPosition.arrowPos}}" style="top: {{menuPosition.top}}px; left: {{menuPosition.left}}px;">
    <view class="menu-arrow" style="left: {{menuPosition.arrowLeft}}px;"></view>
    <view class="menu-content" id="menu-content">
      <!-- 复制（仅文本消息） -->
      <view class="menu-item" wx:if="{{menuMsg.msg_type === 'text'}}" bindtap="copyMessage">
        <van-icon name="description-o" size="16px" color="#fff" />
        <text>复制</text>
      </view>
      <!-- 引用 -->
      <view class="menu-item" bindtap="quoteMessage">
        <van-icon name="chat-o" size="16px" color="#fff" />
        <text>引用</text>
      </view>
      <!-- 撤回（仅自己的消息且2分钟内） -->
      <view class="menu-item" wx:if="{{menuMsg.isSelf && menuMsg.canRevoke}}" bindtap="revokeMessage">
        <van-icon name="revoke" size="16px" color="#fff" />
        <text>撤回</text>
      </view>
      <!-- 删除（仅自己的消息） -->
      <view class="menu-item" wx:if="{{menuMsg.isSelf}}" bindtap="deleteMessage">
        <van-icon name="delete-o" size="16px" color="#fff" />
        <text>删除</text>
      </view>
      <!-- 举报（仅对方的消息） -->
      <view class="menu-item" wx:if="{{!menuMsg.isSelf}}" bindtap="reportMessage">
        <van-icon name="warning-o" size="16px" color="#fff" />
        <text>举报</text>
      </view>
    </view>
  </view>
</view>
