<!--pages/address/list.wxml-->
<view class="address-list-page">
  <nav-bar
    title="收货地址"
    showTitle="{{true}}"
    showBack="{{true}}"
    background="solid"
    dark="{{true}}"
    placeholder="{{true}}"
  />

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <van-loading size="24px" color="#8B2E2A">加载中...</van-loading>
  </view>

  <!-- 空状态 -->
  <van-empty
    wx:elif="{{!loading && list.length === 0}}"
    image="search"
    description="还没有收货地址"
  >
    <van-button round type="primary" color="#8B2E2A" size="small" bind:click="goAdd">
      添加新地址
    </van-button>
  </van-empty>

  <!-- 地址列表 -->
  <view class="list-wrap" wx:else>
    <van-swipe-cell
      wx:for="{{list}}"
      wx:key="_id"
      right-width="{{65}}"
    >
      <!-- 地址卡片 -->
      <view class="addr-card" bindtap="onSelect" data-idx="{{index}}">
        <!-- 默认标签 -->
        <view class="default-badge" wx:if="{{item.is_default}}">
          <van-tag round color="#8B2E2A" size="medium">默认</van-tag>
        </view>

        <view class="addr-body">
          <view class="addr-user-row">
            <text class="addr-name">{{item.name}}</text>
            <text class="addr-phone">{{item.phone}}</text>
          </view>
          <text class="addr-detail">
            {{item.province}}{{item.city}}{{item.district}} {{item.detail}}
          </text>
        </view>

        <!-- 操作按钮 -->
        <view class="addr-actions">
          <view class="addr-action-btn" catchtap="setDefault" data-idx="{{index}}">
            <van-icon name="{{item.is_default ? 'checked' : 'circle'}}" size="20" color="{{item.is_default ? '#8B2E2A' : '#ccc'}}" />
            <text class="{{item.is_default ? 'checked-text' : ''}}">默认</text>
          </view>
          <view class="addr-action-btn" catchtap="goEdit" data-idx="{{index}}">
            <van-icon name="edit" size="18" color="#666" />
            <text>编辑</text>
          </view>
        </view>
      </view>

      <!-- 滑动删除 -->
      <view slot="right" class="swipe-delete-btn" catchtap="deleteAddr" data-idx="{{index}}">
        <van-icon name="delete-o" size="22" color="#fff" />
        <text class="swipe-delete-text">删除</text>
      </view>
    </van-swipe-cell>
  </view>

  <!-- 底部新增按钮 -->
  <view class="footer-bar" wx:if="{{!loading}}">
    <van-button
      block
      round
      type="primary"
      color="#8B2E2A"
      icon="plus"
      bind:click="goAdd"
    >
      新建收货地址
    </van-button>
  </view>
</view>

<van-dialog id="van-dialog" />
