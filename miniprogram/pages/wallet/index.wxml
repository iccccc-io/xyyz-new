<view class="wallet-page">
  <nav-bar
    title="我的钱包"
    showTitle="{{true}}"
    showBack="{{true}}"
    background="solid"
    dark="{{true}}"
    placeholder="{{true}}"
  />

  <view class="balance-card" wx:if="{{wallet}}">
    <view class="balance-bg"></view>
    <view class="balance-content">
      <view class="balance-label">可用余额（元）</view>
      <view class="balance-amount-row">
        <text class="balance-symbol">¥</text>
        <text class="balance-value">{{wallet.balanceDisplay}}</text>
      </view>

      <view class="wallet-meta-row" wx:if="{{wallet.settling_balance > 0 || wallet.frozen_balance > 0}}">
        <view class="wallet-meta-pill" wx:if="{{wallet.settling_balance > 0}}">
          <text>待结算 ¥{{wallet.settlingDisplay}}</text>
        </view>
        <view class="wallet-meta-pill" wx:if="{{wallet.frozen_balance > 0}}">
          <text>冻结中 ¥{{wallet.frozenDisplay}}</text>
        </view>
      </view>

      <view class="balance-actions">
        <view class="balance-btn pwd-btn" bindtap="onChangePwd">
          <van-icon name="shield-o" size="18" color="rgba(255,255,255,0.9)" />
          <text>{{wallet.has_pay_password ? '修改支付密码' : '设置支付密码'}}</text>
        </view>
        <view class="balance-btn finance-btn" wx:if="{{isCreator}}" bindtap="goToFinance">
          <van-icon name="gold-coin-o" size="18" color="#8B2E2A" />
          <text>工坊财务中心</text>
        </view>
      </view>
    </view>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <van-loading size="24px" color="#8B2E2A">加载中...</van-loading>
  </view>

  <view class="init-card" wx:if="{{!loading && !wallet}}">
    <van-empty description="钱包数据加载失败" />
  </view>

  <view class="ledger-section" wx:if="{{!loading && wallet}}">
    <view class="ledger-header">
      <view class="ledger-title-row">
        <view class="ledger-line"></view>
        <text class="ledger-title">账单流水</text>
        <view class="ledger-line"></view>
      </view>
    </view>

    <view class="ledger-loading" wx:if="{{ledgerLoading}}">
      <van-loading size="20px" color="#8B2E2A" />
    </view>

    <van-empty
      wx:elif="{{ledgerList.length === 0}}"
      image="search"
      description="暂无交易记录"
    />

    <view class="ledger-list" wx:else>
      <view class="ledger-item" wx:for="{{ledgerList}}" wx:key="_id">
        <view class="ledger-icon {{item.iconClass}}">
          <van-icon name="{{item.iconName}}" size="22" color="#fff" />
        </view>
        <view class="ledger-info">
          <text class="ledger-desc">{{item.description}}</text>
          <text class="ledger-time">{{item.timeDisplay}}</text>
        </view>
        <text class="ledger-amount {{item.amount > 0 ? 'amount-in' : 'amount-out'}}">
          {{item.amount > 0 ? '+' : ''}}{{item.amountDisplay}}
        </text>
      </view>
    </view>
  </view>

  <view class="pwd-mask" wx:if="{{showPwdPanel}}" bindtap="closePwdPanel">
    <view class="pwd-panel" catchtap>
      <view class="pwd-panel-handle"></view>
      <view class="pwd-panel-title">{{isNewPwd ? '设置支付密码' : '修改支付密码'}}</view>
      <view class="pwd-panel-desc">
        {{isNewPwd ? '首次设置，请输入 6 位数字密码' : '请输入当前旧密码，再输入新的 6 位数字密码'}}
      </view>
      <view class="pwd-step-label">
        {{isNewPwd ? (pwdStep === 2 ? '新密码' : '确认新密码') : (pwdStep === 1 ? '旧密码' : pwdStep === 2 ? '新密码' : '确认新密码')}}
      </view>
      <view class="pwd-dots-row">
        <view class="pwd-dot {{pwdInputArr.length > idx ? 'dot-filled' : 'dot-empty'}}" wx:for="{{dotIndexes}}" wx:key="idx" wx:for-item="idx">
          <view class="dot-inner" wx:if="{{pwdInputArr.length > idx}}"></view>
        </view>
      </view>
      <view class="pwd-msg-error" wx:if="{{pwdError}}">{{pwdError}}</view>
      <view class="mini-kb-grid">
        <view class="mini-kb-key {{item === '' ? 'mini-kb-empty' : ''}}" wx:for="{{keys}}" wx:key="index" bindtap="onPwdKeyTap" data-key="{{item}}">
          <van-icon wx:if="{{item === 'del'}}" name="arrow-left" size="20" color="#333" />
          <text wx:elif="{{item !== ''}}">{{item}}</text>
        </view>
      </view>
      <view class="pwd-cancel-btn" bindtap="closePwdPanel">取消</view>
    </view>
  </view>
</view>
