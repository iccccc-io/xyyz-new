.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(182, 59, 54, 0.06), rgba(182, 59, 54, 0) 28%),
    linear-gradient(180deg, #F8F5F1 0%, #F3F0EB 100%);
}

.content {
  padding: 22rpx 24rpx 196rpx;
}

.panel {
  margin-bottom: 24rpx;
  padding: 26rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow:
    0 14rpx 34rpx rgba(66, 48, 34, 0.05),
    0 1rpx 0 rgba(255, 255, 255, 0.85) inset;
}

.panel-media {
  background:
    linear-gradient(180deg, rgba(255, 250, 247, 0.98) 0%, rgba(255, 255, 255, 0.94) 100%);
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.panel-title-wrap {
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.panel-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: #F7EEE8;
  color: #B63B36;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
  flex-shrink: 0;
}

.panel-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.panel-title {
  font-size: 30rpx;
  line-height: 1.2;
  color: #2C231E;
  font-weight: 700;
}

.panel-meta {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #F7F2ED;
  color: #8A7A6E;
  font-size: 20rpx;
  line-height: 1;
}

.cover-tip {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #FAF3EC;
  color: #9A6A50;
  font-size: 22rpx;
  line-height: 1.6;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 22rpx;
}

.image-card,
.add-image-card {
  width: 198rpx;
  height: 198rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
}

.image-card {
  background: #EDE4DB;
  box-shadow: 0 14rpx 28rpx rgba(66, 48, 34, 0.08);
}

.image-card.is-cover {
  box-shadow:
    0 18rpx 34rpx rgba(182, 59, 54, 0.12),
    0 0 0 2rpx rgba(182, 59, 54, 0.16);
}

.preview-image {
  width: 100%;
  height: 100%;
  display: block;
}

.image-overlay {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 72rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.34) 100%);
}

.cover-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(182, 59, 54, 0.92);
  color: #FFFFFF;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 600;
}

.delete-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(21, 16, 13, 0.48);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.delete-icon {
  color: #FFFFFF;
  font-size: 30rpx;
  line-height: 1;
  margin-top: -4rpx;
}

.add-image-card {
  border: 2rpx dashed #D9CFC4;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 244, 238, 0.95) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-title {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #5F544D;
  font-weight: 600;
}

.add-desc {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #A39A91;
}

.field-grid {
  display: flex;
  gap: 18rpx;
}

.field-half {
  flex: 1;
}

.field-block,
.select-block {
  margin-top: 22rpx;
  padding: 22rpx 22rpx 18rpx;
  border-radius: 22rpx;
  background: #FBFAF8;
  border: 1rpx solid rgba(125, 100, 81, 0.06);
}

.field-block-disabled {
  background: #F6F3F0;
  border-color: rgba(125, 100, 81, 0.04);
}

.field-block-disabled .field-label {
  color: #BDB3AA;
}

.field-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.field-label {
  font-size: 24rpx;
  line-height: 1.2;
  color: #5B5048;
  font-weight: 600;
}

.required-mark {
  margin-right: 6rpx;
  color: #E0544E;
}

.field-counter,
.field-unit {
  font-size: 20rpx;
  line-height: 1.2;
  color: #B0A59A;
}

.field-input {
  width: 100%;
  margin-top: 16rpx;
  font-size: 30rpx;
  line-height: 1.4;
  color: #2C231E;
  min-height: 44rpx;
}

.field-number-input {
  text-align: right;
}

.field-textarea {
  width: 100%;
  margin-top: 16rpx;
  min-height: 136rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #2C231E;
}

.field-placeholder {
  color: #BEB4AB;
}

.select-block {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.project-select-block {
  display: block;
}

.project-select-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.project-select-value {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #BEB4AB;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

.project-select-value.is-filled {
  color: #2C231E;
}

.select-block.single-line-row {
  min-height: 88rpx;
  padding-top: 0;
  padding-bottom: 0;
}

.select-block.single-line-row .select-copy {
  justify-content: center;
  min-height: 88rpx;
}

.select-block.is-disabled {
  background: #F6F3F0;
  border-color: rgba(125, 100, 81, 0.04);
}

.select-block.is-disabled .field-label,
.select-value.is-disabled {
  color: #BDB3AA;
}

.select-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.field-helper {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #AAA095;
}

.select-value-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  min-width: 0;
  align-self: center;
  min-height: 40rpx;
}

.select-value {
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  font-size: 26rpx;
  color: #BEB4AB;
  line-height: 40rpx;
  text-align: right;
}

.select-value.is-filled {
  color: #2C231E;
}

.logistics-disabled-tip {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #B89A72;
}

.select-arrow {
  height: 40rpx;
  display: flex;
  align-items: center;
}

.hint-card {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #FFF4F3;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.hint-text {
  font-size: 22rpx;
  line-height: 1.6;
  color: #B63B36;
}

.preset-tags-scroll {
  width: 100%;
  white-space: nowrap;
  margin-top: 20rpx;
  padding-bottom: 4rpx;
  box-sizing: border-box;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.preset-tags-scroll::-webkit-scrollbar {
  display: none !important;
  width: 0 !important;
  height: 0 !important;
  background: transparent !important;
}

.preset-tag {
  display: inline-flex;
  align-items: center;
  margin-right: 16rpx;
  padding: 14rpx 24rpx;
  background: #F5F2EE;
  border-radius: 32rpx;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.preset-tag:last-child {
  margin-right: 0;
}

.preset-tag .tag-hash {
  font-size: 26rpx;
  color: #999999;
  margin-right: 4rpx;
}

.preset-tag .tag-name {
  font-size: 26rpx;
  color: #666666;
}

.preset-tag.selected {
  background: linear-gradient(135deg, rgba(182, 59, 54, 0.12) 0%, rgba(212, 87, 79, 0.18) 100%);
  border: 1rpx solid rgba(182, 59, 54, 0.3);
}

.preset-tag.selected .tag-hash,
.preset-tag.selected .tag-name {
  color: #B63B36;
  font-weight: 500;
}

.preset-tag:active {
  transform: scale(0.96);
}

.selected-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 20rpx;
  align-items: center;
}

.topic-entry-btn {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 20rpx;
  border-radius: 32rpx;
  background: rgba(182, 59, 54, 0.08);
  color: #B63B36;
  font-size: 24rpx;
  font-weight: 600;
}

.selected-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 16rpx 14rpx 20rpx;
  background: linear-gradient(135deg, #B63B36 0%, #D4574F 100%);
  border-radius: 32rpx;
  animation: tagPopIn 0.25s ease-out;
}

@keyframes tagPopIn {
  0% {
    opacity: 0;
    transform: scale(0.8);
  }

  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.selected-tag-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selected-tag-close {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 32rpx;
  height: 32rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
}

.selected-tag-close:active {
  background: rgba(255, 255, 255, 0.4);
}

.tags-count-tip {
  padding-top: 16rpx;
}

.tags-count-tip text {
  font-size: 22rpx;
  color: #999999;
}

.logistics-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.logistics-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #F5F2EE;
  color: #6F6258;
  font-size: 24rpx;
  line-height: 1.2;
  border: 1rpx solid transparent;
}

.logistics-chip.selected {
  background: linear-gradient(135deg, rgba(182, 59, 54, 0.12) 0%, rgba(212, 87, 79, 0.18) 100%);
  border-color: rgba(182, 59, 54, 0.28);
  color: #B63B36;
  font-weight: 600;
  box-shadow: 0 10rpx 22rpx rgba(182, 59, 54, 0.08);
}

.logistics-chip.disabled {
  background: #F1ECE6;
  border-color: transparent;
  color: #BDB3AA;
  box-shadow: none;
}

.logistics-chip.disabled.selected {
  background: #F1ECE6;
  border-color: rgba(189, 179, 170, 0.36);
  color: #A89C91;
  font-weight: 500;
}

.sku-list {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.sku-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #FBFAF8;
  border: 1rpx solid rgba(125, 100, 81, 0.08);
}

.sku-card-existing {
  background: linear-gradient(180deg, #FBFAF8 0%, #FFFDFC 100%);
  border-color: rgba(159, 122, 100, 0.14);
}

.sku-card-new {
  background: linear-gradient(180deg, rgba(255, 250, 247, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  border-color: rgba(182, 59, 54, 0.16);
  box-shadow:
    inset 0 0 0 2rpx rgba(182, 59, 54, 0.04),
    0 10rpx 24rpx rgba(182, 59, 54, 0.05);
}

.sku-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.sku-title-wrap {
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.sku-index-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #F7EEE8;
  color: #B63B36;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 40rpx;
  text-align: center;
  flex-shrink: 0;
}

.sku-title-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sku-title-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.sku-title {
  font-size: 28rpx;
  line-height: 1.3;
  color: #2C231E;
  font-weight: 700;
}

.sku-mode-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 700;
}

.sku-mode-badge.is-existing {
  background: rgba(159, 122, 100, 0.10);
  color: #8F5D49;
  border: 1rpx solid rgba(159, 122, 100, 0.14);
}

.sku-mode-badge.is-new {
  background: rgba(182, 59, 54, 0.08);
  color: #B63B36;
  border: 1rpx solid rgba(182, 59, 54, 0.16);
}

.sku-lock-tip {
  font-size: 20rpx;
  line-height: 1.5;
  color: #9F7A64;
}

.sku-fresh-tip {
  font-size: 20rpx;
  line-height: 1.5;
  color: #B0634A;
}

.stock-input {
  text-align: right;
}

.sku-stock-block.is-new {
  background: linear-gradient(180deg, rgba(255, 248, 244, 0.98) 0%, rgba(255, 252, 249, 0.98) 100%);
  border-color: rgba(182, 59, 54, 0.10);
}

.sku-stock-block.is-existing {
  background: linear-gradient(180deg, rgba(251, 250, 248, 1) 0%, rgba(255, 255, 255, 1) 100%);
  border-color: rgba(159, 122, 100, 0.08);
}

.initial-stock-tip {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(182, 59, 54, 0.05);
  border: 1rpx solid rgba(182, 59, 54, 0.10);
}

.initial-stock-title {
  display: block;
  font-size: 22rpx;
  line-height: 1.2;
  color: #B63B36;
  font-weight: 700;
}

.initial-stock-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #A36D57;
}

.quick-stock-panel {
  margin-top: 16rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  background: #fffcf8;
  border: 1rpx solid #efe1d4;
}

.quick-stock-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.quick-field-label {
  display: block;
  font-size: 20rpx;
  line-height: 1.2;
  color: #8A7C71;
}

.quick-stock-current {
  font-size: 20rpx;
  line-height: 1.2;
  color: #9a8c83;
}

.quick-stock-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 16rpx;
}

.quick-stock-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.quick-step-btn {
  min-width: 78rpx;
  height: 56rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 1rpx solid #eadfd6;
  background: #ffffff;
  transition: transform 160ms ease, opacity 160ms ease;
}

.quick-step-btn text {
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
}

.quick-step-btn.is-minus text {
  color: #8f5d49;
}

.quick-step-btn.is-plus {
  background: rgba(182, 59, 54, 0.08);
  border-color: rgba(182, 59, 54, 0.18);
}

.quick-step-btn.is-plus text {
  color: #b63b36;
}

.quick-step-btn:active {
  transform: scale(0.97);
}

.quick-stock-input-shell {
  height: 56rpx;
  min-width: 116rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid #eadfd6;
  background: #ffffff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  box-sizing: border-box;
}

.quick-stock-input-prefix {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1;
  color: #8f5d49;
  font-weight: 700;
}

.quick-stock-input {
  width: 64rpx;
  height: 100%;
  text-align: center;
  font-size: 24rpx;
  color: #2c231e;
  font-weight: 700;
}

.quick-stock-preview {
  flex-shrink: 0;
  min-width: 152rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.quick-stock-delta {
  font-size: 30rpx;
  line-height: 1;
  font-weight: 700;
}

.quick-stock-delta.is-plus {
  color: #b63b36;
}

.quick-stock-delta.is-minus {
  color: #8f5d49;
}

.quick-stock-delta.is-neutral {
  color: #9a8c83;
}

.quick-stock-next {
  font-size: 22rpx;
  line-height: 1.3;
  color: #9a8c83;
  font-weight: 500;
}

.sku-remove {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: rgba(182, 59, 54, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sku-image-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.sku-image-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #EDE4DB;
  flex-shrink: 0;
}

.sku-image {
  width: 100%;
  height: 100%;
  display: block;
}

.sku-image-picker {
  flex: 1;
  min-height: 96rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  border: 2rpx dashed #D9CFC4;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.9);
}

.sku-image-picker.has-image {
  min-height: 80rpx;
}

.sku-image-picker-text {
  font-size: 24rpx;
  color: #6F6258;
}

.sku-image-clear {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #F5F2EE;
  color: #8A7A6E;
  font-size: 22rpx;
  line-height: 1;
}

.sku-add-btn {
  margin-top: 20rpx;
  height: 84rpx;
  border-radius: 22rpx;
  border: 2rpx dashed rgba(182, 59, 54, 0.32);
  background: rgba(182, 59, 54, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #B63B36;
  font-size: 26rpx;
  font-weight: 600;
}

.category-picker {
  height: 100%;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #FCFAF7 0%, #FFFFFF 20%, #FFFFFF 100%);
}

.category-picker-header {
  position: relative;
  flex-shrink: 0;
  padding: 28rpx 32rpx 18rpx;
  text-align: center;
}

.category-picker-title {
  font-size: 32rpx;
  line-height: 1.2;
  color: #2C231E;
  font-weight: 700;
}

.category-picker-close {
  position: absolute;
  top: 50%;
  right: 28rpx;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F7F2EC;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-picker-summary {
  flex-shrink: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 24rpx 12rpx;
}

.category-summary-text {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #F7F2ED;
  color: #8B7C70;
  font-size: 20rpx;
  line-height: 1;
}

.category-summary-text.is-active {
  background: #FFF0EB;
  color: #B63B36;
}

.category-grid {
  flex: 1;
  padding: 12rpx 24rpx 28rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  box-sizing: border-box;
}

.category-card {
