.page {
  min-height: 100vh;
  background-color: #f6f6f6;
}

.content {
  padding: 24rpx 28rpx 40rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.section-desc {
  margin: 12rpx 0 20rpx;
  font-size: 24rpx;
  color: #888;
}

.value-placeholder {
  color: #c8c9cc;
}

.value-text {
  color: #333;
}

.hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #b63b36;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 16rpx;
}

.tag-item {
  padding: 10rpx 28rpx;
  border-radius: 36rpx;
  background-color: #f7f7f7;
  font-size: 24rpx;
  color: #666;
}

.tag-item.selected {
  background-color: #fff0f0;
  color: #b63b36;
  border: 2rpx solid #b63b36;
}

.footer {
  margin-top: 32rpx;
}

/* ========== 自定义图片上传区域 ========== */
.image-upload-area {
  margin-top: 20rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #f5f5f5;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.first-badge {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  padding: 4rpx 0;
  background: linear-gradient(135deg, #b63b36 0%, #d64937 100%);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  font-weight: 500;
}

.delete-btn {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1;
  margin-top: -4rpx;
}

.add-image-btn {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.add-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

