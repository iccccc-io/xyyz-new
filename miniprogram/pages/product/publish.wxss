.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 24rpx 20rpx;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(22rpx);
  -webkit-backdrop-filter: blur(22rpx);
  box-shadow: 0 -10rpx 32rpx rgba(55, 40, 28, 0.08);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #C44437 0%, #A92E2A 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 14rpx 28rpx rgba(169, 46, 42, 0.2);
  box-sizing: border-box;
  animation: submitBreath 3s ease-in-out infinite;
}

.submit-btn.is-disabled {
  opacity: 0.72;
  animation: none;
}

@keyframes submitBreath {
  0%,
  100% {
    transform: translateY(0);
    box-shadow: 0 14rpx 28rpx rgba(169, 46, 42, 0.18);
  }

  50% {
    transform: translateY(-2rpx);
    box-shadow: 0 18rpx 34rpx rgba(169, 46, 42, 0.24);
  }
}
