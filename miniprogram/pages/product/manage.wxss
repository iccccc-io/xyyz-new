.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.content {
  padding: 20rpx;
}

.dashboard-card,
.product-card,
.empty-card,
.loading-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.dashboard-card {
  padding: 24rpx;
  background: linear-gradient(180deg, #fffaf6 0%, #ffffff 100%);
  border: 1rpx solid #efe4db;
}

.dashboard-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.dashboard-copy {
  flex: 1;
  min-width: 0;
}

.dashboard-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.15;
  color: #222;
  font-weight: 700;
}

.dashboard-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7f736c;
}

.publish-btn {
  min-width: 176rpx;
  height: 68rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #bf463f 0%, #b63b36 60%, #a9332d 100%);
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 20rpx rgba(182, 59, 54, 0.16);
  transition: transform 160ms ease, opacity 160ms ease, box-shadow 160ms ease;
}

.publish-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 14rpx rgba(182, 59, 54, 0.12);
}

.dashboard-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.stat-item {
  flex: 1;
  min-width: 0;
  padding: 24rpx 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid #f0e6df;
  box-shadow: 0 4rpx 14rpx rgba(181, 83, 40, 0.04);
  transition: all 180ms ease;
}

.stat-item:active {
  transform: scale(0.98);
}

.stat-item.is-active {
  background: #fff7f6;
  border-color: rgba(182, 59, 54, 0.24);
  box-shadow:
    inset 0 0 0 2rpx rgba(182, 59, 54, 0.08),
    0 8rpx 18rpx rgba(182, 59, 54, 0.08);
}

.stat-num {
  display: block;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 700;
  color: #b63b36;
}

.stat-label {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.2;
  color: #222;
  font-weight: 600;
}

.stat-note {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #9a8c83;
}

.list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-card {
  padding: 18rpx;
  overflow: hidden;
}

.product-top {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}

.thumb-wrap {
  position: relative;
  width: 176rpx;
  min-height: 184rpx;
  height: auto;
  align-self: stretch;
  flex-shrink: 0;
  border-radius: 18rpx;
  overflow: hidden;
  background: #f0f0f0;
  box-shadow: 0 6rpx 14rpx rgba(40, 29, 20, 0.08);
}

.thumb {
  width: 100%;
  height: 100%;
}

.card-main {
  flex: 1;
  min-width: 0;
  min-height: 184rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 2rpx;
}

.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.title-block {
  flex: 1;
  min-width: 0;
}

.title {
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  font-size: 30rpx;
  line-height: 1.4;
  color: #222;
  font-weight: 600;
}

.price {
  flex-shrink: 0;
  font-size: 38rpx;
  line-height: 1.1;
  color: #d04a43;
  font-weight: 700;
}

.meta-pills {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}

.meta-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f6f6f6;
}

.meta-key,
.meta-value {
  font-size: 22rpx;
  line-height: 1;
}

.meta-key {
  color: #888;
}

.meta-value {
  color: #555;
  font-weight: 600;
}

.card-middle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 12rpx;
}

.stock-line {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-text {
  font-size: 24rpx;
  line-height: 1.3;
  color: #777;
}

.stock-edit {
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
  background: #f8eeeb;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.actions {
  display: grid;
  gap: 10rpx;
  margin-top: auto;
  padding-top: 14rpx;
}

.actions-two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.actions-three {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.action {
  height: 56rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: #5f5146;
  border: 1rpx solid #eadfd6;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  box-sizing: border-box;
  box-shadow: 0 6rpx 14rpx rgba(66, 48, 34, 0.05);
  transition: transform 160ms ease, opacity 160ms ease, box-shadow 160ms ease;
}

.action text {
  max-width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.action:active {
  transform: scale(0.97);
  box-shadow: 0 3rpx 8rpx rgba(66, 48, 34, 0.04);
}

.sku-rail {
  width: 92rpx;
  min-height: 184rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #FFF6F3 0%, #F9EEE8 100%);
  border: 1rpx solid rgba(182, 59, 54, 0.14);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex-shrink: 0;
  transition: transform 180ms ease, box-shadow 180ms ease, background 220ms ease;
}

.sku-rail:active {
  transform: scale(0.97);
}

.sku-rail.is-open {
  background: linear-gradient(180deg, #FFF2EE 0%, #F7E6DE 100%);
  box-shadow:
    inset 0 0 0 2rpx rgba(182, 59, 54, 0.08),
    0 8rpx 18rpx rgba(182, 59, 54, 0.08);
}

.sku-rail-count {
  font-size: 34rpx;
  line-height: 1;
  color: #B63B36;
  font-weight: 700;
}

.sku-rail-label {
  font-size: 20rpx;
  line-height: 1.2;
  color: #6D5A4D;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.sku-rail-tip {
  font-size: 18rpx;
  line-height: 1.2;
  color: #A07E69;
}

.sku-rail-arrow {
  transform: rotate(0deg);
  transition: transform 220ms ease;
}

.sku-rail.is-open .sku-rail-arrow {
  transform: rotate(180deg);
}

.sku-drawer {
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transform: translateY(-8rpx);
  transition:
    max-height 300ms ease,
    opacity 220ms ease,
    transform 260ms ease,
    margin-top 260ms ease;
}

.sku-drawer.is-open {
  max-height: 1600rpx;
  opacity: 1;
  transform: translateY(0);
  margin-top: 16rpx;
}

.sku-drawer-inner {
  border-radius: 20rpx;
  background: linear-gradient(180deg, #FFFCF8 0%, #F8F2EA 100%);
  border: 1rpx solid #EFE1D4;
  padding: 22rpx;
}

.sku-drawer-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.sku-drawer-title {
  font-size: 28rpx;
  line-height: 1.3;
  color: #2B231E;
  font-weight: 700;
}

.sku-drawer-subtitle {
  font-size: 22rpx;
  line-height: 1.5;
  color: #9A8C83;
  text-align: right;
}

.quick-sku-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(232, 220, 210, 0.88);
}

.quick-sku-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.quick-sku-name {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  line-height: 1.4;
  color: #2E241E;
  font-weight: 700;
}

.quick-sku-note {
  font-size: 20rpx;
  line-height: 1.2;
  color: #AA9788;
}

.quick-sku-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.quick-field {
  min-width: 0;
}

.quick-field-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 20rpx;
  line-height: 1.2;
  color: #8A7C71;
}

.quick-input-shell {
  height: 72rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  background: #FFF;
  border: 1rpx solid #E8DDD3;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.quick-input-prefix,
.quick-input-suffix {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #AA7A63;
}

.quick-input {
  flex: 1;
  min-width: 0;
  height: 100%;
  font-size: 26rpx;
  color: #2C231E;
  text-align: right;
}

.quick-stock-panel {
  margin-top: 16rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  background: #fffcf8;
  border: 1rpx solid #efe1d4;
}

.quick-stock-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.quick-stock-current {
  font-size: 20rpx;
  line-height: 1.2;
  color: #9a8c83;
}

.quick-stock-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 16rpx;
}

.quick-stock-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.quick-step-btn {
  min-width: 78rpx;
  height: 56rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 1rpx solid #eadfd6;
  background: #ffffff;
  transition: transform 160ms ease, opacity 160ms ease;
}

.quick-step-btn text {
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
}

.quick-step-btn.is-minus text {
  color: #8f5d49;
}

.quick-step-btn.is-plus {
  background: rgba(182, 59, 54, 0.08);
  border-color: rgba(182, 59, 54, 0.18);
}

.quick-step-btn.is-plus text {
  color: #b63b36;
}

.quick-step-btn:active {
  transform: scale(0.97);
}

.quick-stock-input-shell {
  height: 56rpx;
  min-width: 116rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid #eadfd6;
  background: #ffffff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  box-sizing: border-box;
}

.quick-stock-input-prefix {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1;
  color: #8f5d49;
  font-weight: 700;
}

.quick-stock-input {
  width: 64rpx;
  height: 100%;
  text-align: center;
  font-size: 24rpx;
  color: #2c231e;
  font-weight: 700;
}

.quick-stock-preview {
  flex-shrink: 0;
  min-width: 152rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.quick-stock-delta {
  font-size: 30rpx;
  line-height: 1;
  font-weight: 700;
}

.quick-stock-delta.is-plus {
  color: #b63b36;
}

.quick-stock-delta.is-minus {
  color: #8f5d49;
}

.quick-stock-delta.is-neutral {
  color: #9a8c83;
}

.quick-stock-next {
  font-size: 22rpx;
  line-height: 1.3;
  color: #9a8c83;
  font-weight: 500;
}

.sku-drawer-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.sku-save-btn {
  min-width: 220rpx;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #C44437 0%, #A92E2A 100%);
  color: #FFF;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 20rpx rgba(182, 59, 54, 0.16);
  transition: transform 160ms ease, opacity 160ms ease, box-shadow 160ms ease;
}

.sku-save-btn:active {
  transform: scale(0.97);
}

.sku-save-btn.is-saving {
  opacity: 0.76;
}

.empty-wrap,
.loading-wrap {
  padding: 120rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-card {
  width: 100%;
  padding: 16rpx 16rpx 12rpx;
  text-align: center;
}

.empty-action {
  width: 220rpx;
  height: 68rpx;
  margin: 8rpx auto 20rpx;
  border-radius: 999rpx;
  background: #b63b36;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.loading-card {
  width: 320rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-fade {
  animation: fadeUp 320ms ease both;
}

.card-rise {
  animation: fadeUp 360ms ease both;
}

.delay-1 {
  animation-delay: 60ms;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
