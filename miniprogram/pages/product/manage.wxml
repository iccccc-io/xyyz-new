<view class="page">
  <nav-bar
    title="商品管理"
    showTitle="{{true}}"
    showBack="{{true}}"
    background="solid"
    dark="{{true}}"
    placeholder="{{true}}"
  />

  <view class="content" wx:if="{{!loading}}">
    <view class="dashboard-card card-fade">
      <view class="dashboard-head">
        <view class="dashboard-copy">
          <text class="dashboard-title">商品管理</text>
          <text class="dashboard-subtitle">{{workshopInfo ? workshopInfo.name : '我的工坊'}}，SKU 库存、价格与上下架都在这里统一维护。</text>
        </view>
        <view class="publish-btn" bindtap="goToPublish">
          <van-icon name="plus" size="16" color="#fff" />
          <text>发布商品</text>
        </view>
      </view>

      <view class="dashboard-stats">
        <view
          class="stat-item {{activeTab === 'selling' ? 'is-active' : ''}}"
          data-tab="selling"
          bindtap="switchTab"
        >
          <text class="stat-num">{{stats.selling}}</text>
          <text class="stat-label">在售中</text>
          <text class="stat-note">正在对外展示</text>
        </view>
        <view
          class="stat-item {{activeTab === 'sold_out' ? 'is-active' : ''}}"
          data-tab="sold_out"
          bindtap="switchTab"
        >
          <text class="stat-num">{{stats.soldOut}}</text>
          <text class="stat-label">已售罄</text>
          <text class="stat-note">等待补货后上架</text>
        </view>
        <view
          class="stat-item {{activeTab === 'warehouse' ? 'is-active' : ''}}"
          data-tab="warehouse"
          bindtap="switchTab"
        >
          <text class="stat-num">{{stats.warehouse}}</text>
          <text class="stat-label">仓库中</text>
          <text class="stat-note">当前不对买家展示</text>
        </view>
      </view>
    </view>

    <view class="list" wx:if="{{filteredProducts.length}}">
      <view
        class="product-card card-rise"
        wx:for="{{filteredProducts}}"
        wx:key="_id"
        wx:for-index="index"
        style="animation-delay: {{index * 50}}ms;"
      >
        <view class="product-top">
          <view class="thumb-wrap">
            <image class="thumb" src="{{item.cover_img}}" mode="aspectFill" />
          </view>

          <view class="card-main">
            <view class="card-top">
              <view class="title-block">
                <text class="title">{{item.title}}</text>
                <view class="meta-pills">
                  <view class="meta-pill">
                    <text class="meta-key">销量</text>
                    <text class="meta-value">{{item.sales}}</text>
                  </view>
                  <view class="meta-pill">
                    <text class="meta-key">浏览</text>
                    <text class="meta-value">{{item.views}}</text>
                  </view>
                  <view class="meta-pill" wx:if="{{item.skuCount}}">
                    <text class="meta-key">SKU</text>
                    <text class="meta-value">{{item.skuCount}}</text>
                  </view>
                </view>
              </view>
              <text class="price">¥{{item.priceDisplay}}{{item.priceSuffix}}</text>
            </view>

            <view class="card-middle">
              <text class="info-text">总库存 {{item.totalStock}} 件</text>
              <text class="info-text">{{item.isOnSale ? '当前可售' : '当前下架'}}</text>
            </view>

            <view class="actions actions-{{item.canDelete ? 'three' : 'two'}}">
              <view class="action" data-id="{{item._id}}" bindtap="editProduct">
                <text>编辑</text>
              </view>
              <view class="action" data-id="{{item._id}}" bindtap="toggleSale">
                <text>{{item.isOnSale ? '下架商品' : '重新上架'}}</text>
              </view>
              <view class="action" wx:if="{{item.canDelete}}" data-id="{{item._id}}" bindtap="deleteProduct">
                <text>删除</text>
              </view>
            </view>
          </view>

          <view class="sku-rail {{item.skuExpanded ? 'is-open' : ''}}" data-id="{{item._id}}" bindtap="toggleSkuDrawer">
            <text class="sku-rail-count">{{item.skuCount}}</text>
            <text class="sku-rail-label">SKU</text>
            <text class="sku-rail-tip">{{item.skuExpanded ? '收起' : '快改'}}</text>
            <van-icon class="sku-rail-arrow" name="arrow-down" size="16" color="#B63B36" />
          </view>
        </view>

        <view class="sku-drawer {{item.skuExpanded ? 'is-open' : ''}}">
          <view class="sku-drawer-inner">
            <view class="sku-drawer-head">
              <text class="sku-drawer-title">快速修改 SKU</text>
              <text class="sku-drawer-subtitle">支持直接调整现价、原价与库存</text>
            </view>

            <view
              class="quick-sku-card"
              wx:for="{{item.quickSkuDrafts}}"
              wx:key="sku_id"
              wx:for-item="sku"
              wx:for-index="skuIndex"
            >
              <view class="quick-sku-head">
                <text class="quick-sku-name">{{sku.sku_name}}</text>
                <text class="quick-sku-note">直接修改后保存</text>
              </view>

              <view class="quick-sku-grid">
                <view class="quick-field">
                  <text class="quick-field-label">现价</text>
                  <view class="quick-input-shell">
                    <text class="quick-input-prefix">¥</text>
                    <input
                      class="quick-input"
                      type="digit"
                      value="{{sku.price}}"
                      data-id="{{item._id}}"
                      data-sku-index="{{skuIndex}}"
                      data-field="price"
                      bindinput="onQuickSkuInput"
                    />
                  </view>
                </view>

                <view class="quick-field">
                  <text class="quick-field-label">原价</text>
                  <view class="quick-input-shell">
                    <text class="quick-input-prefix">¥</text>
                    <input
                      class="quick-input"
                      type="digit"
                      value="{{sku.original_price}}"
                      data-id="{{item._id}}"
                      data-sku-index="{{skuIndex}}"
                      data-field="original_price"
                      bindinput="onQuickSkuInput"
                    />
                  </view>
                </view>
              </view>

              <view class="quick-stock-panel">
                <view class="quick-stock-head">
                  <text class="quick-field-label">库存调整</text>
                  <text class="quick-stock-current">当前 {{sku.current_stock}} 件</text>
                </view>

                <view class="quick-stock-body">
                  <view class="quick-stock-actions">
                    <view class="quick-step-btn is-minus" data-id="{{item._id}}" data-sku-index="{{skuIndex}}" data-step="-1" bindtap="onQuickStockAdjust">
                      <text>-1</text>
                    </view>
                    <view class="quick-stock-input-shell">
                      <text class="quick-stock-input-prefix">{{sku.stock_delta > 0 ? '+' : ''}}</text>
                      <input
                        class="quick-stock-input"
                        type="text"
                        value="{{sku.stock_delta}}"
                        data-id="{{item._id}}"
                        data-sku-index="{{skuIndex}}"
                        bindinput="onQuickStockDeltaInput"
                      />
                    </view>
                    <view class="quick-step-btn is-plus" data-id="{{item._id}}" data-sku-index="{{skuIndex}}" data-step="1" bindtap="onQuickStockAdjust">
                      <text>+1</text>
                    </view>
                  </view>

                  <view class="quick-stock-preview">
                    <text class="quick-stock-delta {{sku.stock_delta > 0 ? 'is-plus' : (sku.stock_delta < 0 ? 'is-minus' : 'is-neutral')}}">
                      {{sku.stock_delta > 0 ? '+' : ''}}{{sku.stock_delta}}
                    </text>
                    <text class="quick-stock-next">预计库存 {{sku.next_stock}} 件</text>
                  </view>
                </view>
              </view>
            </view>

            <view class="sku-drawer-actions">
              <view class="sku-save-btn {{item.skuSaving ? 'is-saving' : ''}}" data-id="{{item._id}}" bindtap="saveQuickSkuChanges">
                {{item.skuSaving ? '保存中...' : '保存 SKU 修改'}}
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-wrap card-fade delay-1" wx:else>
      <view class="empty-card">
        <van-empty
          description="{{activeTab === 'selling' ? '暂无在售商品，去发布第一件作品吧' : activeTab === 'sold_out' ? '当前还没有售罄商品，继续保持' : '仓库中暂时没有下架商品'}}"
        />
        <view class="empty-action" wx:if="{{activeTab === 'selling'}}" bindtap="goToPublish">去发布商品</view>
      </view>
    </view>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-card">
      <van-loading size="24px" color="#b63b36">加载商品中...</van-loading>
    </view>
  </view>
</view>
